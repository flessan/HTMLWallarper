<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #0d1117; color: #c9d1d9; }
        .card:hover { border-color: #58a6ff; transform: translateY(-5px); transition: all 0.3s; }
    </style>
</head>
<body class="font-sans">
    <nav class="p-6 border-b border-gray-800 flex justify-between items-center">
        <h1 class="text-xl font-bold text-white">HTML KDE Wallpapers</h1>
        <a href="https://github.com/flessan/html-kde-live-wallpaper" class="text-gray-400 hover:text-white">GitHub Repo</a>
    </nav>
    
    <main class="max-w-6xl mx-auto p-6">
        {{ content | safe }}
    </main>

    <footer class="p-10 text-center text-sm text-gray-500 border-t border-gray-800 mt-20">
        Dibuat dengan Eleventy & ❤️ untuk komunitas KDE.
    </footer>
</body>
</html>