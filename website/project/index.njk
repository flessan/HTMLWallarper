<style>
  /* === Custom styles for gallery enhancements === */

  /* Toast notification */
  .toast-container {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    pointer-events: none;
  }
  .toast {
    pointer-events: auto;
    padding: 0.75rem 1.25rem;
    border-radius: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #fff;
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.1);
    animation: toastIn 0.35s cubic-bezier(0.16,1,0.3,1), toastOut 0.3s ease 2.2s forwards;
    box-shadow: 0 10px 40px rgba(0,0,0,0.4);
  }
  .toast.success { background: rgba(16,185,129,0.9); }
  .toast.info    { background: rgba(37,99,235,0.9); }
  .toast.warn    { background: rgba(245,158,11,0.9); color: #1a1a1a; }

  @keyframes toastIn {
    from { opacity: 0; transform: translateY(1rem) scale(0.95); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes toastOut {
    to { opacity: 0; transform: translateY(-0.5rem) scale(0.95); }
  }

  /* Card entrance animation */
  .card-animate {
    opacity: 0;
    transform: translateY(2rem);
    transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1);
  }
  .card-animate.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* List view card overrides */
  .list-view .wallpaper-card {
    grid-column: 1 / -1;
  }
  .list-view .wallpaper-card .card-inner {
    display: grid;
    grid-template-columns: 320px 1fr;
  }
  .list-view .wallpaper-card .preview-area {
    aspect-ratio: auto;
    height: 100%;
    min-height: 200px;
    border-bottom: none !important;
    border-right: 1px solid rgba(255,255,255,0.06);
  }
  .list-view .wallpaper-card .card-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Lightbox */
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 9000;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(20px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .lightbox-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }
  .lightbox-overlay .lightbox-content {
    width: 90vw;
    height: 80vh;
    max-width: 1400px;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 0 80px rgba(37,99,235,0.15);
    transform: scale(0.92);
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
  }
  .lightbox-overlay.active .lightbox-content {
    transform: scale(1);
  }
  .lightbox-overlay .lightbox-content iframe {
    width: 100%;
    height: 100%;
    border: none;
  }
  .lightbox-overlay .lightbox-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(to bottom, rgba(0,0,0,0.6), transparent);
  }
  .lightbox-overlay .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 3rem;
    height: 3rem;
    border-radius: 9999px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
  }
  .lightbox-overlay .lightbox-nav:hover {
    background: rgba(37,99,235,0.3);
    border-color: rgba(37,99,235,0.5);
  }
  .lightbox-overlay .lightbox-nav.prev { left: 1.5rem; }
  .lightbox-overlay .lightbox-nav.next { right: 1.5rem; }

  /* Favorite heart */
  .fav-btn {
    transition: transform 0.2s cubic-bezier(0.16,1,0.3,1);
  }
  .fav-btn:hover { transform: scale(1.2); }
  .fav-btn.active svg { fill: #f43f5e; color: #f43f5e; }

  /* Search input glow */
  .search-input:focus {
    box-shadow: 0 0 0 2px rgba(37,99,235,0.3), 0 0 20px rgba(37,99,235,0.1);
  }

  /* Stat counter pulse */
  .stat-glow {
    animation: statPulse 3s ease-in-out infinite;
  }
  @keyframes statPulse {
    0%, 100% { text-shadow: 0 0 8px rgba(37,99,235,0.3); }
    50%      { text-shadow: 0 0 16px rgba(37,99,235,0.6); }
  }

  /* Hide card when filtered out */
  .wallpaper-card.hidden-by-filter {
    display: none;
  }

  /* No-results animation */
  @keyframes emptyBounce {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-8px); }
  }
  .empty-icon {
    animation: emptyBounce 2s ease-in-out infinite;
  }

  /* Scrollbar styling */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #0a0a0a; }
  ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #555; }
</style>

<div class="py-12 px-4 max-w-7xl mx-auto" id="galleryRoot">

  <!-- ===== HEADER ===== -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 gap-4">
    <div>
      <div class="flex items-center gap-3 mb-1">
        <div class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <h2 class="text-4xl font-black text-white tracking-tight">HTMLWallarper</h2>
      </div>
      <p class="text-gray-400 mt-2 text-lg ml-11">Live preview of all static HTML works for KDE Plasma.</p>
    </div>
    <div class="flex items-center gap-3 ml-11 md:ml-0">
      <span class="flex items-center gap-2 text-sm text-gray-500 font-mono">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
        </span>
        ON-the-LINE
      </span>
      <span class="bg-blue-600/20 text-blue-400 px-4 py-1.5 rounded-full text-sm font-bold border border-blue-500/30 shadow-[0_0_15px_rgba(37,99,235,0.2)] stat-glow">
        {{ wallpapers | length }} Koleksi
      </span>
    </div>
  </div>

  <!-- ===== QUICK STATS BAR ===== -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
    <div class="bg-[#0d1117] border border-gray-800/60 rounded-xl px-4 py-3 flex items-center gap-3">
      <div class="w-9 h-9 rounded-lg bg-blue-500/10 flex items-center justify-center">
        <svg class="w-4 h-4 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
      </div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wider font-medium">Total</p>
        <p class="text-white font-bold text-lg leading-none mt-0.5">{{ wallpapers | length }}</p>
      </div>
    </div>
    <div class="bg-[#0d1117] border border-gray-800/60 rounded-xl px-4 py-3 flex items-center gap-3">
      <div class="w-9 h-9 rounded-lg bg-rose-500/10 flex items-center justify-center">
        <svg class="w-4 h-4 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
      </div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wider font-medium">Favorites</p>
        <p class="text-white font-bold text-lg leading-none mt-0.5" id="favCount">0</p>
      </div>
    </div>
    <div class="bg-[#0d1117] border border-gray-800/60 rounded-xl px-4 py-3 flex items-center gap-3">
      <div class="w-9 h-9 rounded-lg bg-emerald-500/10 flex items-center justify-center">
        <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wider font-medium">Status</p>
        <p class="text-emerald-400 font-bold text-lg leading-none mt-0.5">Active</p>
      </div>
    </div>
    <div class="bg-[#0d1117] border border-gray-800/60 rounded-xl px-4 py-3 flex items-center gap-3">
      <div class="w-9 h-9 rounded-lg bg-amber-500/10 flex items-center justify-center">
        <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
      </div>
      <div>
        <p class="text-xs text-gray-500 uppercase tracking-wider font-medium">Platform</p>
        <p class="text-white font-bold text-sm leading-none mt-0.5">KDE Plasma</p>
      </div>
    </div>
  </div>

  <!-- ===== TOOLBAR: Search / Sort / View ===== -->
  <div class="flex flex-col sm:flex-row gap-3 mb-8">
    <!-- Search -->
    <div class="relative flex-1">
      <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input type="text" id="searchInput" placeholder="Search wallpapers..." 
             class="search-input w-full bg-[#0d1117] border border-gray-800 text-white text-sm rounded-xl pl-10 pr-4 py-2.5 outline-none focus:border-blue-500/50 transition-all placeholder:text-gray-600">
    </div>

    <!-- Sort -->
    <div class="relative">
      <select id="sortSelect" class="appearance-none bg-[#0d1117] border border-gray-800 text-white text-sm rounded-xl pl-4 pr-10 py-2.5 outline-none focus:border-blue-500/50 transition-all cursor-pointer">
        <option value="default">Default Order</option>
        <option value="az">Name A → Z</option>
        <option value="za">Name Z → A</option>
      </select>
      <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
    </div>

    <!-- Filter favs -->
    <button id="filterFavBtn" class="flex items-center gap-2 bg-[#0d1117] border border-gray-800 text-gray-400 text-sm rounded-xl px-4 py-2.5 outline-none hover:border-rose-500/50 hover:text-rose-400 transition-all">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
      <span>Favs Only</span>
    </button>

    <!-- View toggle -->
    <div class="flex bg-[#0d1117] border border-gray-800 rounded-xl overflow-hidden">
      <button id="viewGrid" class="view-btn p-2.5 text-blue-400 bg-blue-500/10 transition-colors" title="Grid view">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
      </button>
      <button id="viewList" class="view-btn p-2.5 text-gray-500 hover:text-gray-300 transition-colors" title="List view">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <!-- ===== RESULTS COUNT ===== -->
  <div class="flex items-center justify-between mb-6">
    <p class="text-xs text-gray-600 font-mono uppercase tracking-wider" id="resultsCount">Showing {{ wallpapers | length }} results</p>
    <button id="clearFavsBtn" class="text-xs text-gray-600 hover:text-rose-400 transition-colors hidden">
      <svg class="w-3 h-3 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
      Clear all favorites
    </button>
  </div>

  <!-- ===== GALLERY GRID ===== -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="galleryGrid">
    {% for wp in wallpapers %}
    <div class="wallpaper-card card-animate" data-name="{{ wp.name | lower }}" data-index="{{ loop.index0 }}">
      <div class="card-inner group relative bg-[#0d1117] border border-gray-800 rounded-2xl overflow-hidden hover:border-blue-500/50 transition-all duration-500 hover:shadow-[0_0_30px_rgba(0,0,0,0.5)]">
        
        <!-- Preview area -->
        <div class="preview-area relative aspect-video bg-black overflow-hidden border-b border-gray-800">
          <div class="absolute inset-0 z-0 flex items-center justify-center">
            <iframe src="{{ wp.htmlUrl }}" 
                    class="absolute w-[1280px] h-[720px] origin-center scale-[0.3125] opacity-80 group-hover:opacity-100 transition-all duration-700"
                    frameborder="0" 
                    scrolling="no"
                    loading="lazy">
            </iframe>
          </div>

          <!-- Hover overlay -->
          <div class="absolute inset-0 z-20 bg-black/60 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-300 flex flex-col items-center justify-center gap-3">
            <button onclick="openLightbox({{ loop.index0 }})" 
                    class="px-6 py-2 bg-blue-600 text-white rounded-full font-bold text-sm transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300 hover:bg-blue-500 shadow-lg cursor-pointer">
              Live Preview
            </button>
            <a href="{{ wp.htmlUrl }}" target="_blank" 
               class="px-6 py-2 bg-white/10 text-gray-200 rounded-full font-bold text-sm transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500 hover:bg-white/20 border border-white/10 backdrop-blur-sm">
              Open Fullscreen
            </a>
            <a href="{{ wp.url }}" target="_blank" 
               class="px-6 py-2 bg-gray-800 text-gray-300 rounded-full font-bold text-sm transform translate-y-4 group-hover:translate-y-0 transition-transform duration-[600ms] hover:bg-gray-700 border border-gray-700">
              View Source
            </a>
          </div>

          <!-- Index badge -->
          <div class="absolute top-3 left-3 z-30 bg-black/60 backdrop-blur-sm text-gray-400 text-[10px] font-mono px-2 py-1 rounded-md border border-white/5">
            #{{ loop.index }}
          </div>

          <!-- Favorite button -->
          <button onclick="toggleFav('{{ wp.name }}', this)" 
                  class="fav-btn absolute top-3 right-3 z-30 w-8 h-8 rounded-full bg-black/60 backdrop-blur-sm flex items-center justify-center border border-white/5 hover:border-rose-500/50 transition-all cursor-pointer"
                  data-name="{{ wp.name }}">
            <svg class="w-4 h-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </button>
        </div>

        <!-- Card body -->
        <div class="card-body p-6">
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors capitalize">{{ wp.name }}</h3>
            <span class="flex items-center gap-1.5 shrink-0 ml-3">
              <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
              <span class="text-[10px] text-green-500/70 font-mono">LIVE</span>
            </span>
          </div>
          
          <!-- Path row with copy -->
          <div class="flex items-center text-xs font-mono text-gray-500 bg-gray-900/50 p-2.5 rounded-lg group/path cursor-pointer" 
               onclick="copyPath('/wallpapers/{{ wp.folderName }}', this)" title="Click to copy path">
            <svg class="w-3.5 h-3.5 text-blue-500 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
            <span class="truncate flex-1">/wallpapers/{{ wp.folderName }}</span>
            <svg class="w-3.5 h-3.5 text-gray-600 group-hover/path:text-blue-400 transition-colors shrink-0 ml-2 copy-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          </div>

          <!-- Footer -->
          <div class="mt-5 pt-4 border-t border-gray-800/50 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <span class="text-[10px] uppercase tracking-widest text-gray-600 font-bold">KDE Plasma</span>
            </div>
            <a href="https://github.com/flessan/HTMLWallarper/archive/refs/heads/main.zip" 
               class="group/dl p-2 rounded-lg bg-gray-900 hover:bg-blue-600/10 transition-colors" title="Download all">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-500 group-hover/dl:text-blue-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
    {% else %}
    <!-- Empty state -->
    <div class="col-span-full py-32 text-center bg-gray-900/20 rounded-3xl border-2 border-dashed border-gray-800">
      <div class="inline-flex p-6 rounded-full bg-gray-900/50 mb-6 empty-icon">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
        </svg>
      </div>
      <p class="text-gray-400 font-medium text-xl">Gudang masih kosong melompong.</p>
      <p class="text-gray-600 mt-2">Pastikan folder wallpapers di root repo sudah ada isinya dan terintegrasi API.</p>
    </div>
    {% endfor %}
  </div>

  <!-- ===== NO RESULTS (hidden by default) ===== -->
  <div id="noResults" class="hidden py-24 text-center">
    <div class="inline-flex p-6 rounded-full bg-gray-900/50 mb-6 empty-icon">
      <svg class="w-12 h-12 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
    </div>
    <p class="text-gray-400 font-medium text-xl">Tidak ada wallpaper yang cocok.</p>
    <p class="text-gray-600 mt-2">Coba kata kunci lain atau hapus filter favorit.</p>
  </div>

</div>

<!-- ===== LIGHTBOX ===== -->
<div class="lightbox-overlay" id="lightbox" onclick="closeLightboxOnBg(event)">
  <div class="lightbox-bar">
    <div class="flex items-center gap-3">
      <span class="text-white font-bold text-sm" id="lightboxTitle">Preview</span>
      <span class="text-gray-500 text-xs font-mono" id="lightboxIndex">#1</span>
    </div>
    <div class="flex items-center gap-2">
      <a id="lightboxOpenFull" href="#" target="_blank" class="px-3 py-1.5 bg-white/10 text-gray-300 rounded-lg text-xs font-bold hover:bg-white/20 border border-white/10 transition-colors">
        Open Fullscreen ↗
      </a>
      <button onclick="closeLightbox()" class="p-2 rounded-lg bg-white/10 text-gray-300 hover:bg-white/20 hover:text-white transition-colors cursor-pointer">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>
  <button class="lightbox-nav prev" onclick="lightboxNav(-1)">
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
  </button>
  <div class="lightbox-content">
    <iframe id="lightboxFrame" src="" frameborder="0" scrolling="no"></iframe>
  </div>
  <button class="lightbox-nav next" onclick="lightboxNav(1)">
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
  </button>
</div>

<!-- ===== TOAST CONTAINER ===== -->
<div class="toast-container" id="toastContainer"></div>

<!-- ===== SCRIPTS ===== -->
<script>
(function() {
  // --- Data ---
  const cards = Array.from(document.querySelectorAll('.wallpaper-card'));
  const totalCards = cards.length;

  // Wallpaper URLs array for lightbox navigation (extracted from DOM)
  const wallpaperData = cards.map(card => {
    const iframe = card.querySelector('.preview-area iframe');
    const name = card.dataset.name;
    return {
      url: iframe ? iframe.src : '',
      name: name,
      fullName: card.querySelector('h3') ? card.querySelector('h3').textContent.trim() : name
    };
  });

  // --- Favorites (localStorage) ---
  const FAV_KEY = 'htmlwallarper_favs';
  let favorites = JSON.parse(localStorage.getItem(FAV_KEY) || '[]');

  function saveFavs() {
    localStorage.setItem(FAV_KEY, JSON.stringify(favorites));
    updateFavCount();
  }

  function updateFavCount() {
    document.getElementById('favCount').textContent = favorites.length;
    document.getElementById('clearFavsBtn').classList.toggle('hidden', favorites.length === 0);
  }

  function isFav(name) {
    return favorites.includes(name);
  }

  // Initialize fav button states
  function initFavButtons() {
    document.querySelectorAll('.fav-btn').forEach(btn => {
      if (isFav(btn.dataset.name)) {
        btn.classList.add('active');
      }
    });
    updateFavCount();
  }

  window.toggleFav = function(name, btn) {
    if (isFav(name)) {
      favorites = favorites.filter(f => f !== name);
      btn.classList.remove('active');
      showToast('Removed from favorites', 'info');
    } else {
      favorites.push(name);
      btn.classList.add('active');
      showToast('Added to favorites ❤️', 'success');
    }
    saveFavs();
    // If favs-only filter is on, re-apply
    if (favFilterOn) applyFilters();
  };

  window.clearAllFavs = function() {
    favorites = [];
    saveFavs();
    document.querySelectorAll('.fav-btn.active').forEach(b => b.classList.remove('active'));
    showToast('All favorites cleared', 'warn');
    if (favFilterOn) applyFilters();
  };
  document.getElementById('clearFavsBtn').addEventListener('click', clearAllFavs);

  // --- Search ---
  const searchInput = document.getElementById('searchInput');
  let searchTerm = '';

  searchInput.addEventListener('input', function() {
    searchTerm = this.value.toLowerCase().trim();
    applyFilters();
  });

  // --- Sort ---
  const sortSelect = document.getElementById('sortSelect');
  let sortMode = 'default';

  sortSelect.addEventListener('change', function() {
    sortMode = this.value;
    applyFilters();
  });

  // --- Fav filter ---
  let favFilterOn = false;
  const filterFavBtn = document.getElementById('filterFavBtn');

  filterFavBtn.addEventListener('click', function() {
    favFilterOn = !favFilterOn;
    this.classList.toggle('border-rose-500/50', favFilterOn);
    this.classList.toggle('text-rose-400', favFilterOn);
    this.classList.toggle('bg-rose-500/5', favFilterOn);
    this.classList.toggle('border-gray-800', !favFilterOn);
    this.classList.toggle('text-gray-400', !favFilterOn);
    applyFilters();
  });

  // --- Combined filter & sort ---
  function applyFilters() {
    let visible = [...cards];

    // Filter by search
    if (searchTerm) {
      visible = visible.filter(c => c.dataset.name.includes(searchTerm));
    }

    // Filter by favs
    if (favFilterOn) {
      visible = visible.filter(c => isFav(c.dataset.name));
    }

    // Sort
    if (sortMode === 'az') {
      visible.sort((a, b) => a.dataset.name.localeCompare(b.dataset.name));
    } else if (sortMode === 'za') {
      visible.sort((a, b) => b.dataset.name.localeCompare(a.dataset.name));
    }

    // Hide all first
    cards.forEach(c => c.classList.add('hidden-by-filter'));

    // Show & reorder
    visible.forEach(c => {
      c.classList.remove('hidden-by-filter');
      document.getElementById('galleryGrid').appendChild(c);
    });

    // Update count
    const count = visible.length;
    document.getElementById('resultsCount').textContent = 
      count === totalCards ? `Showing ${count} results` : `Showing ${count} of ${totalCards} results`;

    // No results
    document.getElementById('noResults').classList.toggle('hidden', count > 0);
  }

  // --- View toggle ---
  const grid = document.getElementById('galleryGrid');
  const viewGridBtn = document.getElementById('viewGrid');
  const viewListBtn = document.getElementById('viewList');

  viewGridBtn.addEventListener('click', function() {
    grid.classList.remove('list-view');
    grid.classList.remove('grid-cols-1');
    grid.classList.add('md:grid-cols-2', 'lg:grid-cols-3');
    this.classList.add('text-blue-400', 'bg-blue-500/10');
    this.classList.remove('text-gray-500');
    viewListBtn.classList.remove('text-blue-400', 'bg-blue-500/10');
    viewListBtn.classList.add('text-gray-500');
  });

  viewListBtn.addEventListener('click', function() {
    grid.classList.add('list-view');
    grid.classList.add('grid-cols-1');
    grid.classList.remove('md:grid-cols-2', 'lg:grid-cols-3');
    this.classList.add('text-blue-400', 'bg-blue-500/10');
    this.classList.remove('text-gray-500');
    viewGridBtn.classList.remove('text-blue-400', 'bg-blue-500/10');
    viewGridBtn.classList.add('text-gray-500');
  });

  // --- Lightbox ---
  let currentLightboxIndex = -1;
  const lightbox = document.getElementById('lightbox');
  const lightboxFrame = document.getElementById('lightboxFrame');
  const lightboxTitle = document.getElementById('lightboxTitle');
  const lightboxIndex = document.getElementById('lightboxIndex');
  const lightboxOpenFull = document.getElementById('lightboxOpenFull');

  function getVisibleData() {
    const visibleCards = Array.from(document.querySelectorAll('.wallpaper-card:not(.hidden-by-filter)'));
    return visibleCards.map(c => {
      const idx = parseInt(c.dataset.index);
      return { ...wallpaperData[idx], cardIndex: idx };
    });
  }

  window.openLightbox = function(cardIndex) {
    const visibleData = getVisibleData();
    const vIdx = visibleData.findIndex(d => d.cardIndex === cardIndex);
    if (vIdx === -1) return;
    showLightboxAt(vIdx, visibleData);
  };

  function showLightboxAt(vIdx, visibleData) {
    currentLightboxIndex = vIdx;
    const data = visibleData[vIdx];
    lightboxFrame.src = data.url;
    lightboxTitle.textContent = data.fullName;
    lightboxIndex.textContent = `#${vIdx + 1} / ${visibleData.length}`;
    lightboxOpenFull.href = data.url;
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  window.lightboxNav = function(dir) {
    const visibleData = getVisibleData();
    let newIdx = currentLightboxIndex + dir;
    if (newIdx < 0) newIdx = visibleData.length - 1;
    if (newIdx >= visibleData.length) newIdx = 0;
    showLightboxAt(newIdx, visibleData);
  };

  window.closeLightbox = function() {
    lightbox.classList.remove('active');
    lightboxFrame.src = '';
    document.body.style.overflow = '';
  };

  window.closeLightboxOnBg = function(e) {
    if (e.target === lightbox) closeLightbox();
  };

  // Keyboard nav
  document.addEventListener('keydown', function(e) {
    if (!lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') lightboxNav(-1);
    if (e.key === 'ArrowRight') lightboxNav(1);
  });

  // --- Copy path ---
  window.copyPath = function(path, el) {
    navigator.clipboard.writeText(path).then(() => {
      showToast(`Copied: ${path}`, 'success');
      const icon = el.querySelector('.copy-icon');
      if (icon) {
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>';
        icon.classList.add('text-emerald-400');
        setTimeout(() => {
          icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>';
          icon.classList.remove('text-emerald-400');
        }, 1500);
      }
    }).catch(() => {
      showToast('Failed to copy', 'warn');
    });
  };

  // --- Toast ---
  window.showToast = function(msg, type = 'info') {
    const container = document.getElementById('toastContainer');
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    toast.textContent = msg;
    container.appendChild(toast);
    setTimeout(() => toast.remove(), 2600);
  };

  // --- Entrance animations (Intersection Observer) ---
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 80);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.05, rootMargin: '0px 0px -40px 0px' });

  cards.forEach(c => observer.observe(c));

  // --- Keyboard shortcut: focus search with / ---
  document.addEventListener('keydown', function(e) {
    if (e.key === '/' && document.activeElement !== searchInput) {
      e.preventDefault();
      searchInput.focus();
    }
  });

  // --- Init ---
  initFavButtons();
})();
</script>
