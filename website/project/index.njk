title: Project Gallery
permalink: /project/index.html
---

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>
  :root {
    --bg: #FEF6E8; --bg-alt: #FFF0DB; --bg-dot: #F0D9B5;
    --card: #FFFFFF; --card-border: #E8CFA8; --card-border-hover: #E8A85C;
    --text: #3D2C1E; --text-muted: #8B7355; --text-light: #A89279;
    --primary: #FF7043; --primary-hover: #FF5722; --primary-light: #FFCCBC;
    --secondary: #26A69A; --secondary-light: #B2DFDB;
    --accent: #FFD54F; --accent-light: #FFF8E1; --accent-dark: #F57F17;
    --purple: #CE93D8; --purple-light: #F3E5F5;
    --pink: #F48FB1; --pink-light: #FCE4EC; --pink-dark: #E91E63;
    --sky: #81D4FA; --sky-light: #E1F5FE; --sky-dark: #0288D1;
    --green: #81C784; --green-light: #E8F5E9; --green-dark: #2E7D32;
    --shadow-card: 0 3px 0 0 var(--card-border), 0 5px 16px rgba(61,44,30,0.06);
    --shadow-card-hover: 0 3px 0 0 var(--card-border-hover), 0 8px 24px rgba(255,112,67,0.1);
    --radius-sm: 0.625rem; --radius-md: 0.875rem; --radius-lg: 1.125rem; --radius-xl: 1.5rem;
    --bounce: cubic-bezier(0.68,-0.4,0.265,1.4); --smooth: cubic-bezier(0.4,0,0.2,1);
    --nav-h: 56px;
  }
  [data-theme="dark"] {
    --bg: #1A192B; --bg-alt: #22213A; --bg-dot: #2D2C4A;
    --card: #272643; --card-border: #3A3960; --card-border-hover: #FF8A65;
    --text: #F0E6D6; --text-muted: #9E93A8; --text-light: #6E6585;
    --primary: #FF8A65; --primary-hover: #FFAB91; --primary-light: rgba(255,138,101,0.14);
    --secondary: #4DB6AC; --secondary-light: rgba(77,182,172,0.14);
    --accent: #FFE082; --accent-light: rgba(255,224,130,0.1); --accent-dark: #FFB300;
    --purple: #CE93D8; --purple-light: rgba(206,147,216,0.12);
    --pink: #F48FB1; --pink-light: rgba(244,143,177,0.12); --pink-dark: #FF80AB;
    --sky: #81D4FA; --sky-light: rgba(129,212,250,0.12); --sky-dark: #4FC3F7;
    --green: #81C784; --green-light: rgba(129,199,132,0.12); --green-dark: #66BB6A;
    --shadow-card: 0 3px 0 0 var(--card-border), 0 5px 16px rgba(0,0,0,0.18);
    --shadow-card-hover: 0 3px 0 0 var(--card-border-hover), 0 8px 24px rgba(255,138,101,0.08);
  }

  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;transition:background .5s var(--smooth),color .5s var(--smooth);line-height:1.6}
  body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;background-image:radial-gradient(var(--bg-dot) 1px,transparent 1px);background-size:22px 22px;opacity:.4;transition:opacity .5s}
  h1,h2,h3,h4{font-family:'Fredoka',sans-serif;line-height:1.2}
  a{text-decoration:none;color:inherit}
  :focus-visible{outline:3px solid var(--primary);outline-offset:2px;border-radius:4px}

  /* ===== SCROLL PROGRESS ===== */
  #scrollProgress{position:fixed;top:0;left:0;height:4px;z-index:10001;background:linear-gradient(90deg,var(--primary),var(--accent),var(--secondary),var(--primary));background-size:300% 100%;animation:progressSlide 4s linear infinite;width:0%;border-radius:0 4px 4px 0;transition:width .06s linear}
  @keyframes progressSlide{to{background-position:300% 0}}

  /* ===== SUBPAGE NAV ===== */
  .sub-nav{position:fixed;top:0;left:0;right:0;z-index:10000;height:var(--nav-h);background:var(--bg);border-bottom:2.5px solid var(--card-border);transition:background .4s var(--smooth),border-color .4s,box-shadow .3s}
  .sub-nav.scrolled{box-shadow:0 2px 8px rgba(61,44,30,0.06)}
  .sub-nav-inner{max-width:1200px;margin:0 auto;height:100%;display:flex;align-items:center;justify-content:space-between;padding:0 1.25rem}
  .sub-nav-left{display:flex;align-items:center;gap:.625rem}
  .sub-nav-back{width:32px;height:32px;border-radius:var(--radius-sm);background:var(--card);border:2px solid var(--card-border);box-shadow:1px 1px 0 var(--card-border);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text-muted);transition:all .25s var(--bounce)}
  .sub-nav-back:hover{transform:translate(-1px,-1px);box-shadow:2px 2px 0 var(--card-border-hover);color:var(--primary);border-color:var(--card-border-hover)}
  .sub-nav-logo{width:30px;height:30px;border-radius:var(--radius-sm);background:var(--primary);border:2px solid var(--text);display:flex;align-items:center;justify-content:center;box-shadow:1px 1px 0 var(--text);flex-shrink:0}
  .sub-nav-title{font-family:'Fredoka',sans-serif;font-weight:600;font-size:.9rem;color:var(--text);transition:color .4s}
  .sub-nav-sep{color:var(--text-light);font-size:.8rem;font-weight:700;transition:color .4s}
  .theme-toggle{width:36px;height:36px;border-radius:50%;background:var(--accent-light);border:2.5px solid var(--card-border);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .3s var(--bounce);position:relative;overflow:hidden;flex-shrink:0}
  .theme-toggle:hover{transform:scale(1.1) rotate(12deg);border-color:var(--accent-dark)}
  .theme-toggle .sun,.theme-toggle .moon{position:absolute;transition:all .45s var(--bounce)}
  .theme-toggle .sun{opacity:1;transform:scale(1) rotate(0)}
  .theme-toggle .moon{opacity:0;transform:scale(.4) rotate(-90deg)}
  [data-theme="dark"] .theme-toggle .sun{opacity:0;transform:scale(.4) rotate(90deg)}
  [data-theme="dark"] .theme-toggle .moon{opacity:1;transform:scale(1) rotate(0)}

  /* ===== DECORATIONS ===== */
  .cartoon-deco{position:absolute;pointer-events:none;z-index:0}
  .deco-star{width:18px;height:18px;background:var(--accent);clip-path:polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%);animation:twinkle 3s ease-in-out infinite}
  .deco-heart{width:16px;height:14px;background:var(--pink);transform:rotate(-45deg);border-radius:0 50% 0 50%;animation:floatHeart 4s ease-in-out infinite}
  .deco-heart::before{content:'';position:absolute;width:16px;height:14px;background:var(--pink);border-radius:50% 50% 0 0;top:-7px;left:0}
  .deco-bubble{border-radius:50%;border:2.5px solid var(--card-border);background:var(--card);box-shadow:2px 2px 0 var(--card-border);animation:floatBubble 6s ease-in-out infinite}
  @keyframes twinkle{0%,100%{transform:scale(1) rotate(0);opacity:.7}50%{transform:scale(1.2) rotate(10deg);opacity:1}}
  @keyframes floatHeart{0%,100%{transform:rotate(-45deg) translateY(0) scale(1)}50%{transform:rotate(-45deg) translateY(-7px) scale(1.1)}}
  @keyframes floatBubble{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}

  /* ===== GALLERY ROOT ===== */
  .gallery-root{position:relative;z-index:1;padding:calc(var(--nav-h) + 2rem) 1.25rem 3rem;max-width:1200px;margin:0 auto}

  /* ===== GALLERY HEADER ===== */
  .gallery-header{display:flex;flex-wrap:wrap;justify-content:space-between;align-items:flex-end;gap:1rem;margin-bottom:1.5rem}
  .gallery-header-left{display:flex;align-items:center;gap:.75rem}
  .gallery-header-icon{width:44px;height:44px;border-radius:var(--radius-md);background:var(--primary);border:2.5px solid var(--text);box-shadow:2px 2px 0 var(--text);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .3s var(--bounce)}
  .gallery-header-icon:hover{transform:rotate(-6deg) scale(1.08)}
  .gallery-header h2{font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;color:var(--text);transition:color .4s}
  .gallery-header-right{display:flex;align-items:center;gap:.625rem;flex-wrap:wrap}
  .live-badge{display:flex;align-items:center;gap:.375rem;font-size:.7rem;font-weight:700;color:var(--text-muted);transition:color .4s}
  .live-dot{width:7px;height:7px;border-radius:50%;background:var(--green);border:2px solid var(--text);animation:pulse 2s ease-in-out infinite;flex-shrink:0}
  @keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.2)}}
  .count-badge{padding:.3rem .75rem;border-radius:999px;font-size:.7rem;font-weight:800;background:var(--primary-light);border:2px solid var(--primary);color:var(--primary);box-shadow:1px 1px 0 var(--primary);transition:all .4s}

  /* ===== STATS BAR ===== */
  .stats-bar{display:grid;grid-template-columns:repeat(2,1fr);gap:.625rem;margin-bottom:1.5rem}
  @media(min-width:640px){.stats-bar{grid-template-columns:repeat(4,1fr)}}
  .stat-card{background:var(--card);border:2.5px solid var(--card-border);border-radius:var(--radius-lg);padding:.75rem;display:flex;align-items:center;gap:.625rem;box-shadow:var(--shadow-card);transition:all .3s var(--bounce)}
  .stat-card:hover{transform:translateY(-2px) rotate(-.5deg)}
  .stat-icon{width:36px;height:36px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;border:2px solid;flex-shrink:0;box-shadow:1px 1px 0 currentColor}
  .si-primary{background:var(--primary-light);border-color:var(--primary);color:var(--primary)}
  .si-pink{background:var(--pink-light);border-color:var(--pink);color:var(--pink)}
  .si-green{background:var(--green-light);border-color:var(--green);color:var(--green)}
  .si-accent{background:var(--accent-light);border-color:var(--accent-dark);color:var(--accent-dark)}
  .stat-info-label{font-size:.6rem;text-transform:uppercase;letter-spacing:.06em;font-weight:700;color:var(--text-light);transition:color .4s}
  .stat-info-value{font-family:'Fredoka',sans-serif;font-weight:700;font-size:1.05rem;color:var(--text);line-height:1.2;transition:color .4s}
  .stat-info-value.sv-green{color:var(--green-dark)}

  /* ===== TOOLBAR ===== */
  .toolbar{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1.25rem;align-items:center}
  .toolbar-search{position:relative;flex:1;min-width:180px}
  .toolbar-search svg{position:absolute;left:.75rem;top:50%;transform:translateY(-50%);color:var(--text-light);pointer-events:none;transition:color .4s}
  .toolbar-search input{width:100%;background:var(--card);border:2.5px solid var(--card-border);border-radius:var(--radius-md);padding:.6rem .75rem .6rem 2.25rem;font-family:'Nunito',sans-serif;font-size:.8125rem;font-weight:600;color:var(--text);outline:none;box-shadow:2px 2px 0 var(--card-border);transition:all .25s var(--bounce)}
  .toolbar-search input::placeholder{color:var(--text-light)}
  .toolbar-search input:focus{border-color:var(--primary);box-shadow:2px 2px 0 var(--primary);transform:translate(-1px,-1px)}
  .toolbar-select{appearance:none;background:var(--card);border:2.5px solid var(--card-border);border-radius:var(--radius-md);padding:.6rem 2rem .6rem .75rem;font-family:'Nunito',sans-serif;font-size:.8125rem;font-weight:600;color:var(--text);outline:none;cursor:pointer;box-shadow:2px 2px 0 var(--card-border);transition:all .25s var(--bounce)}
  .toolbar-select:focus{border-color:var(--primary);box-shadow:2px 2px 0 var(--primary)}
  .toolbar-btn{display:inline-flex;align-items:center;gap:.375rem;background:var(--card);border:2.5px solid var(--card-border);border-radius:var(--radius-md);padding:.6rem .75rem;font-family:'Nunito',sans-serif;font-size:.8125rem;font-weight:700;color:var(--text-muted);cursor:pointer;box-shadow:2px 2px 0 var(--card-border);transition:all .25s var(--bounce);white-space:nowrap}
  .toolbar-btn:hover{transform:translate(-1px,-1px);box-shadow:3px 3px 0 var(--card-border-hover);color:var(--text)}
  .toolbar-btn:active{transform:translate(1px,1px);box-shadow:1px 1px 0 var(--card-border)}
  .toolbar-btn.active{background:var(--pink-light);border-color:var(--pink);color:var(--pink-dark);box-shadow:2px 2px 0 var(--pink)}
  .view-toggle{display:flex;border-radius:var(--radius-md);overflow:hidden;border:2.5px solid var(--card-border);box-shadow:2px 2px 0 var(--card-border)}
  .view-toggle-btn{padding:.5rem .625rem;background:var(--card);color:var(--text-light);cursor:pointer;border:none;border-right:2px solid var(--card-border);transition:all .2s;display:flex;align-items:center}
  .view-toggle-btn:last-child{border-right:none}
  .view-toggle-btn.active{background:var(--primary-light);color:var(--primary)}
  .view-toggle-btn:hover:not(.active){color:var(--text-muted)}

  /* ===== RESULTS BAR ===== */
  .results-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;gap:.5rem}
  .results-count{font-size:.68rem;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:.06em;transition:color .4s}
  .clear-favs-btn{font-size:.68rem;font-weight:700;color:var(--text-light);cursor:pointer;background:none;border:none;font-family:'Nunito',sans-serif;transition:color .2s}
  .clear-favs-btn:hover{color:var(--pink-dark)}

  /* ===== GALLERY GRID ===== */
  .gallery-grid{display:grid;grid-template-columns:1fr;gap:1.25rem}
  @media(min-width:768px){.gallery-grid{grid-template-columns:repeat(2,1fr)}}
  @media(min-width:1024px){.gallery-grid{grid-template-columns:repeat(3,1fr)}}
  .gallery-grid.list-view{grid-template-columns:1fr}

  /* ===== WALLPAPER CARD ===== */
  .wallpaper-card{opacity:0;transform:translateY(24px) scale(.97);transition:opacity .6s var(--bounce),transform .6s var(--bounce)}
  .wallpaper-card.visible{opacity:1;transform:translateY(0) scale(1)}
  .wallpaper-card.hidden-by-filter{display:none}

  .card-inner{background:var(--card);border:2.5px solid var(--card-border);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-card);transition:border-color .35s var(--smooth),box-shadow .35s var(--smooth),background .4s;position:relative}
  .card-inner:hover{border-color:var(--card-border-hover);box-shadow:var(--shadow-card-hover)}

  /* Preview area */
  .preview-area{position:relative;aspect-ratio:16/9;background:var(--bg-alt);overflow:hidden;border-bottom:2.5px solid var(--card-border);transition:background .4s,border-color .4s}
  .preview-area iframe{position:absolute;left:50%;top:50%;width:1280px;height:720px;margin-left:-640px;margin-top:-360px;transform:scale(.3125);border:none;pointer-events:none;opacity:.75;transition:opacity .5s var(--smooth)}
  .card-inner:hover .preview-area iframe{opacity:1}

  /* Hover overlay */
  .hover-overlay{position:absolute;inset:0;z-index:20;background:color-mix(in srgb, var(--bg) 80%, transparent);backdrop-filter:blur(4px);opacity:0;transition:opacity .3s;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem}
  .card-inner:hover .hover-overlay{opacity:1}
  .overlay-btn{padding:.5rem 1.25rem;border-radius:999px;font-family:'Fredoka',sans-serif;font-weight:600;font-size:.8rem;cursor:pointer;border:2.5px solid;transition:all .25s var(--bounce);transform:translateY(8px);opacity:0}
  .card-inner:hover .overlay-btn{transform:translateY(0);opacity:1}
  .card-inner:hover .overlay-btn:nth-child(2){transition-delay:.05s}
  .card-inner:hover .overlay-btn:nth-child(3){transition-delay:.1s}
  .overlay-btn-primary{background:var(--primary);color:#fff;border-color:var(--text);box-shadow:2px 2px 0 var(--text)}
  .overlay-btn-primary:hover{transform:translateY(-1px) !important;box-shadow:3px 3px 0 var(--text);background:var(--primary-hover)}
  .overlay-btn-secondary{background:var(--card);color:var(--text-muted);border-color:var(--card-border);box-shadow:2px 2px 0 var(--card-border)}
  .overlay-btn-secondary:hover{transform:translateY(-1px) !important;box-shadow:3px 3px 0 var(--card-border-hover);border-color:var(--card-border-hover)}

  /* Index badge */
  .index-badge{position:absolute;top:.5rem;left:.5rem;z-index:30;padding:.15rem .5rem;border-radius:999px;font-size:.6rem;font-weight:800;background:var(--card);border:2px solid var(--card-border);color:var(--text-muted);box-shadow:1px 1px 0 var(--card-border);transition:all .4s}

  /* Fav button */
  .fav-btn{position:absolute;top:.5rem;right:.5rem;z-index:30;width:32px;height:32px;border-radius:50%;background:var(--card);border:2.5px solid var(--card-border);box-shadow:1px 1px 0 var(--card-border);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .3s var(--bounce)}
  .fav-btn:hover{transform:scale(1.15);border-color:var(--pink);box-shadow:1px 1px 0 var(--pink)}
  .fav-btn.active{background:var(--pink-light);border-color:var(--pink);box-shadow:1px 1px 0 var(--pink)}
  .fav-btn.active svg{fill:var(--pink-dark);color:var(--pink-dark)}
  .fav-btn.bounce{animation:favBounce .4s var(--bounce)}
  @keyframes favBounce{0%{transform:scale(1)}30%{transform:scale(1.35)}60%{transform:scale(.9)}100%{transform:scale(1)}}

  /* Card body */
  .card-body{padding:1rem 1.125rem}
  .card-body-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.625rem;gap:.5rem}
  .card-body h3{font-size:1rem;font-weight:600;color:var(--text);transition:color .4s;text-transform:capitalize}
  .card-inner:hover .card-body h3{color:var(--primary)}
  .live-tag{display:flex;align-items:center;gap:.25rem;flex-shrink:0}
  .live-tag-dot{width:5px;height:5px;border-radius:50%;background:var(--green);animation:pulse 2s ease-in-out infinite}
  .live-tag span{font-size:.55rem;font-weight:800;color:var(--green-dark);letter-spacing:.05em;transition:color .4s}

  /* Path row */
  .path-row{display:flex;align-items:center;font-size:.7rem;font-weight:600;color:var(--text-muted);background:var(--bg-alt);padding:.5rem .625rem;border-radius:var(--radius-sm);border:2px solid var(--card-border);cursor:pointer;transition:all .2s;gap:.375rem}
  .path-row:hover{border-color:var(--primary);background:var(--primary-light)}
  .path-row svg{flex-shrink:0;color:var(--primary);transition:color .4s}
  .path-row .path-text{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:'Courier New',monospace;font-size:.65rem}
  .path-row .copy-icon{flex-shrink:0;color:var(--text-light);transition:color .2s}
  .path-row:hover .copy-icon{color:var(--primary)}
  .path-row .copy-icon.copied{color:var(--green-dark)}

  /* Card footer */
  .card-footer{margin-top:.75rem;padding-top:.625rem;border-top:2px solid color-mix(in srgb, var(--card-border) 40%, transparent);display:flex;align-items:center;justify-content:space-between;transition:border-color .4s}
  .card-footer-left{display:flex;align-items:center;gap:.375rem}
  .card-footer-left svg{color:var(--text-light);transition:color .4s}
  .card-footer-left span{font-size:.55rem;text-transform:uppercase;letter-spacing:.08em;font-weight:800;color:var(--text-light);transition:color .4s}
  .card-dl-btn{width:28px;height:28px;border-radius:var(--radius-sm);background:var(--bg-alt);border:2px solid var(--card-border);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text-light);transition:all .25s var(--bounce);box-shadow:1px 1px 0 var(--card-border)}
  .card-dl-btn:hover{transform:translate(-1px,-1px);box-shadow:2px 2px 0 var(--primary);color:var(--primary);border-color:var(--primary)}

  /* ===== LIST VIEW OVERRIDES ===== */
  .list-view .wallpaper-card{grid-column:1/-1}
  .list-view .card-inner{display:grid;grid-template-columns:320px 1fr}
  .list-view .preview-area{aspect-ratio:auto;height:100%;min-height:200px;border-bottom:none;border-right:2.5px solid var(--card-border)}
  .list-view .card-body{display:flex;flex-direction:column;justify-content:center}
  @media(max-width:640px){.list-view .card-inner{grid-template-columns:1fr}.list-view .preview-area{aspect-ratio:16/9;height:auto;min-height:0;border-bottom:2.5px solid var(--card-border);border-right:none}}

  /* ===== LIGHTBOX ===== */
  .lightbox-overlay{position:fixed;inset:0;z-index:9000;background:color-mix(in srgb, var(--bg) 90%, transparent);backdrop-filter:blur(16px);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .35s var(--smooth)}
  .lightbox-overlay.active{opacity:1;pointer-events:auto}
  .lightbox-content{width:90vw;height:75vh;max-width:1400px;border-radius:var(--radius-xl);overflow:hidden;border:3px solid var(--card-border);box-shadow:4px 4px 0 var(--card-border),0 16px 48px rgba(0,0,0,.15);transform:scale(.92);transition:transform .4s var(--bounce),border-color .4s}
  .lightbox-overlay.active .lightbox-content{transform:scale(1)}
  .lightbox-content iframe{width:100%;height:100%;border:none}
  .lightbox-bar{position:absolute;top:0;left:0;right:0;padding:.75rem 1rem;display:flex;align-items:center;justify-content:space-between;background:linear-gradient(to bottom,color-mix(in srgb, var(--bg) 85%, transparent),transparent);z-index:5}
  .lightbox-bar-left{display:flex;align-items:center;gap:.5rem}
  .lightbox-bar-left span:first-child{font-family:'Fredoka',sans-serif;font-weight:600;font-size:.875rem;color:var(--text);transition:color .4s}
  .lightbox-bar-left span:last-child{font-size:.65rem;font-weight:700;color:var(--text-light);font-family:'Courier New',monospace;transition:color .4s}
  .lightbox-bar-right{display:flex;align-items:center;gap:.375rem}
  .lb-btn{padding:.35rem .625rem;border-radius:var(--radius-sm);background:var(--card);border:2px solid var(--card-border);box-shadow:1px 1px 0 var(--card-border);cursor:pointer;font-family:'Nunito',sans-serif;font-size:.7rem;font-weight:700;color:var(--text-muted);transition:all .25s var(--bounce)}
  .lb-btn:hover{transform:translate(-1px,-1px);box-shadow:2px 2px 0 var(--card-border-hover);color:var(--text)}
  .lb-close{width:32px;height:32px;border-radius:var(--radius-sm);background:var(--card);border:2.5px solid var(--card-border);box-shadow:1px 1px 0 var(--card-border);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text-muted);transition:all .25s var(--bounce);padding:0}
  .lb-close:hover{transform:translate(-1px,-1px);box-shadow:2px 2px 0 var(--pink);color:var(--pink);border-color:var(--pink)}
  .lightbox-nav{position:absolute;top:50%;transform:translateY(-50%);width:40px;height:40px;border-radius:50%;background:var(--card);border:2.5px solid var(--text);box-shadow:2px 2px 0 var(--text);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text);transition:all .25s var(--bounce);z-index:5}
  .lightbox-nav:hover{transform:translateY(-50%) translate(-1px,-1px);box-shadow:3px 3px 0 var(--text)}
  .lightbox-nav:active{transform:translateY(-50%) translate(1px,1px);box-shadow:1px 1px 0 var(--text)}
  .lightbox-nav.prev{left:1rem}
  .lightbox-nav.next{right:1rem}

  /* ===== EMPTY / NO RESULTS ===== */
  .empty-state{grid-column:1/-1;padding:3rem 1rem;text-align:center;background:var(--card);border:3px dashed var(--card-border);border-radius:var(--radius-xl);transition:all .4s}
  .empty-icon{display:inline-flex;width:64px;height:64px;border-radius:50%;background:var(--bg-alt);border:2.5px solid var(--card-border);align-items:center;justify-content:center;margin-bottom:1rem;animation:emptyBounce 2.5s ease-in-out infinite}
  @keyframes emptyBounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
  .empty-state p:first-of-type{font-family:'Fredoka',sans-serif;font-weight:600;font-size:1.1rem;color:var(--text);margin-bottom:.25rem;transition:color .4s}
  .empty-state p:last-of-type{font-size:.8125rem;color:var(--text-muted);transition:color .4s}

  /* ===== TOAST ===== */
  .toast-container{position:fixed;bottom:4.5rem;right:1.25rem;z-index:99999;display:flex;flex-direction:column;gap:.5rem;pointer-events:none}
  .toast{pointer-events:auto;padding:.5rem .875rem;border-radius:var(--radius-sm);font-size:.75rem;font-weight:700;border:2.5px solid var(--text);box-shadow:2px 2px 0 var(--text);animation:toastIn .4s var(--bounce),toastOut .3s ease 2.2s forwards}
  .toast.success{background:var(--green);color:var(--green-dark);border-color:var(--green-dark);box-shadow:2px 2px 0 var(--green-dark)}
  .toast.info{background:var(--sky);color:var(--sky-dark);border-color:var(--sky-dark);box-shadow:2px 2px 0 var(--sky-dark)}
  .toast.warn{background:var(--accent);color:var(--accent-dark);border-color:var(--accent-dark);box-shadow:2px 2px 0 var(--accent-dark)}
  @keyframes toastIn{from{opacity:0;transform:translateY(.75rem) scale(.9)}to{opacity:1;transform:translateY(0) scale(1)}}
  @keyframes toastOut{to{opacity:0;transform:translateY(-.5rem) scale(.9)}}

  /* ===== SPARKLE ===== */
  .sparkle{position:fixed;pointer-events:none;z-index:99997;width:6px;height:6px;clip-path:polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%);animation:sparkleFade .5s ease-out forwards}
  @keyframes sparkleFade{0%{opacity:1;transform:scale(1) rotate(0)}100%{opacity:0;transform:scale(0) rotate(70deg)}}

  /* ===== MASCOT ===== */
  #mascot{position:fixed;bottom:1.25rem;left:1.25rem;z-index:9989;width:48px;height:48px;border-radius:50% 50% 50% 45%;background:var(--primary);border:3px solid var(--text);box-shadow:2px 2px 0 var(--text);cursor:pointer;overflow:hidden;transition:transform .4s var(--bounce),background .4s}
  #mascot:hover{transform:scale(1.1) rotate(-5deg)}
  #mascot .eye{position:absolute;width:6px;height:8px;background:var(--text);border-radius:50%;top:15px;transition:background .4s}
  #mascot .eye.left{left:11px}#mascot .eye.right{right:11px}
  #mascot .eye::after{content:'';position:absolute;width:2.5px;height:2.5px;background:#fff;border-radius:50%;top:1px;right:0}
  #mascot .mouth{position:absolute;bottom:12px;left:50%;transform:translateX(-50%);width:8px;height:4px;border-bottom:2px solid var(--text);border-radius:0 0 50% 50%;transition:border-color .4s}
  #mascot .blush{position:absolute;width:8px;height:4px;background:var(--pink);border-radius:50%;top:26px;opacity:.4;transition:background .4s}
  #mascot .blush.left{left:3px}#mascot .blush.right{right:3px}
  #mascot.bounce{animation:mBounce .4s var(--bounce)}
  @keyframes mBounce{0%{transform:scale(1)}30%{transform:scale(1.2) rotate(7deg)}60%{transform:scale(.93) rotate(-3deg)}100%{transform:scale(1) rotate(0)}}
  #mascotTip{position:fixed;bottom:3.75rem;left:1.25rem;z-index:9989;background:var(--card);border:2.5px solid var(--card-border);border-radius:var(--radius-sm);padding:.35rem .625rem;font-size:.68rem;font-weight:700;color:var(--text-muted);box-shadow:2px 2px 0 var(--card-border);opacity:0;transform:translateY(5px);pointer-events:none;transition:all .3s var(--bounce);white-space:nowrap}
  #mascotTip.show{opacity:1;transform:translateY(0)}
  #mascotTip::after{content:'';position:absolute;bottom:-5px;left:.875rem;width:8px;height:8px;background:var(--card);border-right:2.5px solid var(--card-border);border-bottom:2.5px solid var(--card-border);transform:rotate(45deg)}

  /* ===== BACK TO TOP ===== */
  #backToTop{position:fixed;bottom:1.25rem;right:1.25rem;z-index:9990;width:42px;height:42px;border-radius:50%;background:var(--primary);border:2.5px solid var(--text);box-shadow:2px 2px 0 var(--text);cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;transition:all .3s var(--bounce),background .4s;opacity:0;transform:translateY(14px) scale(.8);pointer-events:none}
  #backToTop.visible{opacity:1;transform:translateY(0) scale(1);pointer-events:auto}
  #backToTop:hover{transform:translateY(-2px) scale(1.06);box-shadow:3px 3px 0 var(--text)}
  #backToTop:active{transform:translateY(1px) scale(.95);box-shadow:1px 1px 0 var(--text)}

  /* ===== RESPONSIVE ===== */
  @media(max-width:640px){
    .gallery-header{flex-direction:column;align-items:flex-start}
    .gallery-header-right{width:100%}
    .toolbar{flex-direction:column}
    .toolbar-search{min-width:0;width:100%}
    .toolbar .toolbar-select,.toolbar .toolbar-btn{flex:1}
    .view-toggle{align-self:stretch}
    .view-toggle-btn{flex:1;justify-content:center}
    .list-view .card-inner{grid-template-columns:1fr}
    .list-view .preview-area{aspect-ratio:16/9;height:auto;min-height:0;border-bottom:2.5px solid var(--card-border);border-right:none}
    .lightbox-nav{width:32px;height:32px}
    .lightbox-nav.prev{left:.5rem}
    .lightbox-nav.next{right:.5rem}
    .lightbox-content{width:96vw;height:60vh}
  }

  /* Fix: Added space after { to prevent {# from being interpreted as a Nunjucks comment */
  @media(max-width:768px){ #mascot,#mascotTip{display:none} }

  /* ===== REDUCED MOTION ===== */
  @media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;animation-iteration-count:1!important;transition-duration:.15ms!important}.sparkle{display:none!important}}

  /* ===== SCROLLBAR ===== */
  ::-webkit-scrollbar{width:7px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--card-border);border-radius:4px;border:2px solid var(--bg)}::-webkit-scrollbar-thumb:hover{background:var(--primary)}
</style>

<!-- ===== SCROLL PROGRESS ===== -->
<div id="scrollProgress"></div>

<!-- ===== SUBPAGE NAV ===== -->
