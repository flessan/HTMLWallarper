      <svg class="sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32l1.41-1.41"/></svg>
      <svg class="moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
    </button>
  </div>
</nav>

<!-- ===== GALLERY ===== -->
<div class="gallery-root" id="galleryRoot">

  <!-- Decorations -->
  <div class="cartoon-deco deco-star" style="top:calc(var(--nav-h) + .5rem);right:5%;animation-delay:.3s"></div>
  <div class="cartoon-deco deco-heart" style="top:calc(var(--nav-h) + 2rem);left:3%;animation-delay:1.5s"></div>
  <div class="cartoon-deco deco-bubble" style="top:calc(var(--nav-h) + 6rem);right:2%;width:14px;height:14px;animation-delay:1s"></div>
  <div class="cartoon-deco deco-star" style="top:calc(var(--nav-h) + 12rem);left:6%;width:14px;height:14px;background:var(--secondary);animation-delay:2s"></div>

  <!-- Header -->
  <div class="gallery-header">
    <div class="gallery-header-left">
      <div class="gallery-header-icon">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <div>
        <h2>Project Gallery</h2>
        <p style="font-size:.8125rem;color:var(--text-muted);margin-top:.125rem;transition:color .4s">Live preview of all static HTML works for KDE Plasma.</p>
      </div>
    </div>
    <div class="gallery-header-right">
      <span class="live-badge"><span class="live-dot"></span>ON-THE-LINE</span>
      <span class="count-badge">{{ wallpapers | length }} Koleksi</span>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="stats-bar">
    <div class="stat-card">
      <div class="stat-icon si-primary"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg></div>
      <div><p class="stat-info-label">Total</p><p class="stat-info-value">{{ wallpapers | length }}</p></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon si-pink"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg></div>
      <div><p class="stat-info-label">Favorites</p><p class="stat-info-value" id="favCount">0</p></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon si-green"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
      <div><p class="stat-info-label">Status</p><p class="stat-info-value sv-green">Active</p></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon si-accent"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg></div>
      <div><p class="stat-info-label">Platform</p><p class="stat-info-value" style="font-size:.85rem">KDE Plasma</p></div>
    </div>
  </div>

  <!-- Toolbar -->
  <div class="toolbar">
    <div class="toolbar-search">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input type="text" id="searchInput" placeholder="Search wallpapers...">
    </div>
    <select id="sortSelect" class="toolbar-select">
      <option value="default">Default Order</option>
      <option value="az">Name A → Z</option>
      <option value="za">Name Z → A</option>
    </select>
    <button id="filterFavBtn" class="toolbar-btn">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
      Favs Only
    </button>
    <div class="view-toggle">
      <button id="viewGrid" class="view-toggle-btn active" title="Grid view">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
      </button>
      <button id="viewList" class="view-toggle-btn" title="List view">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <!-- Results bar -->
  <div class="results-bar">
    <p class="results-count" id="resultsCount">Showing {{ wallpapers | length }} results</p>
    <button id="clearFavsBtn" class="clear-favs-btn" style="display:none">
      <svg class="w-3 h-3" style="display:inline;vertical-align:middle;margin-right:3px" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
      Clear all favorites
    </button>
  </div>

  <!-- Gallery grid -->
  <div class="gallery-grid" id="galleryGrid">
    {% for wp in wallpapers %}
    <div class="wallpaper-card" data-name="{{ wp.name | lower }}" data-index="{{ loop.index0 }}">
      <div class="card-inner">
        <!-- Preview -->
        <div class="preview-area">
          <iframe src="{{ wp.htmlUrl }}" frameborder="0" scrolling="no" loading="lazy"></iframe>

          <!-- Hover overlay -->
          <div class="hover-overlay">
            <button onclick="openLightbox({{ loop.index0 }})" class="overlay-btn overlay-btn-primary">Live Preview</button>
            <a href="{{ wp.htmlUrl }}" target="_blank" class="overlay-btn overlay-btn-secondary">Open Fullscreen</a>
            <a href="{{ wp.url }}" target="_blank" class="overlay-btn overlay-btn-secondary">View Source</a>
          </div>

          <!-- Index badge -->
          <div class="index-badge">#{{ loop.index }}</div>

          <!-- Fav -->
          <button onclick="toggleFav('{{ wp.name }}', this)" class="fav-btn" data-name="{{ wp.name }}">
            <svg class="w-4 h-4" style="color:var(--text-light)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </button>
        </div>

        <!-- Body -->
        <div class="card-body">
          <div class="card-body-header">
            <h3>{{ wp.name }}</h3>
            <span class="live-tag"><span class="live-tag-dot"></span><span>LIVE</span></span>
          </div>
          <div class="path-row" onclick="copyPath('/wallpapers/{{ wp.folderName }}', this)" title="Click to copy path">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
            <span class="path-text">/wallpapers/{{ wp.folderName }}</span>
            <svg class="copy-icon w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          </div>
          <div class="card-footer">
            <div class="card-footer-left">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <span>KDE Plasma</span>
            </div>
            <a href="https://github.com/flessan/HTMLWallarper/archive/refs/heads/main.zip" class="card-dl-btn" title="Download all">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
    {% else %}
    <div class="empty-state">
      <div class="empty-icon">
        <svg class="w-7 h-7" style="color:var(--text-light)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
      </div>
      <p>Gudang masih kosong melompong.</p>
      <p>Pastikan folder wallpapers di root repo sudah ada isinya dan terintegrasi API.</p>
    </div>
    {% endfor %}
  </div>

  <!-- No results -->
  <div id="noResults" style="display:none">
    <div class="empty-state">
      <div class="empty-icon">
        <svg class="w-7 h-7" style="color:var(--text-light)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      </div>
      <p>Tidak ada wallpaper yang cocok.</p>
      <p>Coba kata kunci lain atau hapus filter favorit.</p>
    </div>
  </div>
</div>

<!-- ===== LIGHTBOX ===== -->
<div class="lightbox-overlay" id="lightbox" onclick="closeLightboxOnBg(event)">
  <div class="lightbox-bar">
    <div class="lightbox-bar-left">
      <span id="lightboxTitle">Preview</span>
      <span id="lightboxIndex">#1</span>
    </div>
    <div class="lightbox-bar-right">
      <a id="lightboxOpenFull" href="#" target="_blank" class="lb-btn">Open Fullscreen ↗</a>
      <button onclick="closeLightbox()" class="lb-close" aria-label="Close preview">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>
  <button class="lightbox-nav prev" onclick="lightboxNav(-1)" aria-label="Previous">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
  </button>
  <div class="lightbox-content">
    <iframe id="lightboxFrame" src="" frameborder="0" scrolling="no"></iframe>
  </div>
  <button class="lightbox-nav next" onclick="lightboxNav(1)" aria-label="Next">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
  </button>
</div>

<!-- ===== BACK TO TOP ===== -->
<button id="backToTop" aria-label="Back to top">
  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
</button>

<!-- ===== MASCOT ===== -->
<div id="mascot" aria-hidden="true">
  <div class="eye left"></div><div class="eye right"></div>
  <div class="mouth"></div>
  <div class="blush left"></div><div class="blush right"></div>
</div>
<div id="mascotTip">Cari wallpaper favoritmu!</div>

<!-- ===== TOAST ===== -->
<div class="toast-container" id="toastContainer"></div>

<!-- ===== SCRIPTS ===== -->
<script>
(function() {
  'use strict';

  /* ── Theme ── */
  var html = document.documentElement;
  var saved = localStorage.getItem('hw-theme');
  if (saved) html.setAttribute('data-theme', saved);
  else if (window.matchMedia('(prefers-color-scheme: dark)').matches) html.setAttribute('data-theme', 'dark');

  document.getElementById('themeToggle').addEventListener('click', function() {
    var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('hw-theme', next);
    showToast(next === 'dark' ? 'Dark mode activated!' : 'Light mode activated!', 'info');
  });

  /* ── Scroll progress & nav & back-to-top ── */
  var progressBar = document.getElementById('scrollProgress');
  var subNav = document.getElementById('subNav');
  var backToTopBtn = document.getElementById('backToTop');
  var ticking = false;

  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(function() {
      var st = window.scrollY;
      var dh = document.documentElement.scrollHeight - window.innerHeight;
      progressBar.style.width = (dh > 0 ? (st / dh) * 100 : 0) + '%';
      subNav.classList.toggle('scrolled', st > 30);
      backToTopBtn.classList.toggle('visible', st > 400);
      ticking = false;
    });
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
  backToTopBtn.addEventListener('click', function() { window.scrollTo({ top: 0, behavior: 'smooth' }); });

  /* ── Data ── */
  var cards = Array.from(document.querySelectorAll('.wallpaper-card'));
  var totalCards = cards.length;
  var wallpaperData = cards.map(function(card) {
    var iframe = card.querySelector('.preview-area iframe');
    var name = card.dataset.name;
    return {
      url: iframe ? iframe.src : '',
      name: name,
      fullName: card.querySelector('h3') ? card.querySelector('h3').textContent.trim() : name
    };
  });

  /* ── Favorites ── */
  var FAV_KEY = 'htmlwallarper_favs';
  var favorites = JSON.parse(localStorage.getItem(FAV_KEY) || '[]');

  function saveFavs() {
    localStorage.setItem(FAV_KEY, JSON.stringify(favorites));
    updateFavCount();
  }
  function updateFavCount() {
    document.getElementById('favCount').textContent = favorites.length;
    document.getElementById('clearFavsBtn').style.display = favorites.length > 0 ? '' : 'none';
  }
  function isFav(name) { return favorites.indexOf(name) !== -1; }

  function initFavButtons() {
    document.querySelectorAll('.fav-btn').forEach(function(btn) {
      if (isFav(btn.dataset.name)) btn.classList.add('active');
    });
    updateFavCount();
  }

  window.toggleFav = function(name, btn) {
    if (isFav(name)) {
      favorites = favorites.filter(function(f) { return f !== name; });
      btn.classList.remove('active');
      showToast('Removed from favorites', 'info');
    } else {
      favorites.push(name);
      btn.classList.add('active');
      showToast('Added to favorites', 'success');
    }
    btn.classList.remove('bounce');
    void btn.offsetWidth;
    btn.classList.add('bounce');
    saveFavs();
    if (favFilterOn) applyFilters();
  };

  document.getElementById('clearFavsBtn').addEventListener('click', function() {
    favorites = [];
    saveFavs();
    document.querySelectorAll('.fav-btn.active').forEach(function(b) { b.classList.remove('active'); });
    showToast('All favorites cleared', 'warn');
    if (favFilterOn) applyFilters();
  });

  /* ── Search ── */
  var searchInput = document.getElementById('searchInput');
  var searchTerm = '';
  searchInput.addEventListener('input', function() { searchTerm = this.value.toLowerCase().trim(); applyFilters(); });

  /* ── Sort ── */
  var sortSelect = document.getElementById('sortSelect');
  var sortMode = 'default';
  sortSelect.addEventListener('change', function() { sortMode = this.value; applyFilters(); });

  /* ── Fav filter ── */
  var favFilterOn = false;
  var filterFavBtn = document.getElementById('filterFavBtn');
  filterFavBtn.addEventListener('click', function() {
    favFilterOn = !favFilterOn;
    this.classList.toggle('active', favFilterOn);
    applyFilters();
  });

  /* ── Combined filter & sort ── */
  function applyFilters() {
    var visible = cards.slice();

    if (searchTerm) {
      visible = visible.filter(function(c) { return c.dataset.name.indexOf(searchTerm) !== -1; });
    }
    if (favFilterOn) {
      visible = visible.filter(function(c) { return isFav(c.dataset.name); });
    }
    if (sortMode === 'az') {
      visible.sort(function(a, b) { return a.dataset.name.localeCompare(b.dataset.name); });
    } else if (sortMode === 'za') {
      visible.sort(function(a, b) { return b.dataset.name.localeCompare(a.dataset.name); });
    }

    cards.forEach(function(c) { c.classList.add('hidden-by-filter'); });
    visible.forEach(function(c) {
      c.classList.remove('hidden-by-filter');
      document.getElementById('galleryGrid').appendChild(c);
    });

    var count = visible.length;
    document.getElementById('resultsCount').textContent =
      count === totalCards ? 'Showing ' + count + ' results' : 'Showing ' + count + ' of ' + totalCards + ' results';

    var noResults = document.getElementById('noResults');
    noResults.style.display = count > 0 ? 'none' : '';
  }

  /* ── View toggle ── */
  var grid = document.getElementById('galleryGrid');
  var viewGridBtn = document.getElementById('viewGrid');
  var viewListBtn = document.getElementById('viewList');

  viewGridBtn.addEventListener('click', function() {
    grid.classList.remove('list-view');
    this.classList.add('active');
    viewListBtn.classList.remove('active');
  });
  viewListBtn.addEventListener('click', function() {
    grid.classList.add('list-view');
    this.classList.add('active');
    viewGridBtn.classList.remove('active');
  });

  /* ── Lightbox ── */
  var currentLightboxIndex = -1;
  var lightbox = document.getElementById('lightbox');
  var lightboxFrame = document.getElementById('lightboxFrame');
  var lightboxTitle = document.getElementById('lightboxTitle');
  var lightboxIndex = document.getElementById('lightboxIndex');
  var lightboxOpenFull = document.getElementById('lightboxOpenFull');

  function getVisibleData() {
    var vc = document.querySelectorAll('.wallpaper-card:not(.hidden-by-filter)');
    return Array.from(vc).map(function(c) {
      var idx = parseInt(c.dataset.index, 10);
      var d = wallpaperData[idx] || { url: '', name: '', fullName: '' };
      return { url: d.url, name: d.name, fullName: d.fullName, cardIndex: idx };
    });
  }

  window.openLightbox = function(cardIndex) {
    var vd = getVisibleData();
    var vi = -1;
    for (var i = 0; i < vd.length; i++) { if (vd[i].cardIndex === cardIndex) { vi = i; break; } }
    if (vi === -1) return;
    showLightboxAt(vi, vd);
  };

  function showLightboxAt(vi, vd) {
    currentLightboxIndex = vi;
    var d = vd[vi];
    lightboxFrame.src = d.url;
    lightboxTitle.textContent = d.fullName;
    lightboxIndex.textContent = '#' + (vi + 1) + ' / ' + vd.length;
    lightboxOpenFull.href = d.url;
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  window.lightboxNav = function(dir) {
    var vd = getVisibleData();
    var ni = currentLightboxIndex + dir;
    if (ni < 0) ni = vd.length - 1;
    if (ni >= vd.length) ni = 0;
    showLightboxAt(ni, vd);
  };

  window.closeLightbox = function() {
    lightbox.classList.remove('active');
    lightboxFrame.src = '';
    document.body.style.overflow = '';
  };

  window.closeLightboxOnBg = function(e) { if (e.target === lightbox) closeLightbox(); };

  document.addEventListener('keydown', function(e) {
    if (!lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') lightboxNav(-1);
    if (e.key === 'ArrowRight') lightboxNav(1);
  });

  /* ── Copy path ── */
  window.copyPath = function(path, el) {
    var doCopy = function() {
      var icon = el.querySelector('.copy-icon');
      if (icon) {
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>';
        icon.classList.add('copied');
        setTimeout(function() {
          icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>';
          icon.classList.remove('copied');
        }, 1500);
      }
      showToast('Copied: ' + path, 'success');
    };

    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(path).then(doCopy).catch(function() {
        fallbackCopy(path); doCopy();
      });
    } else {
      fallbackCopy(path); doCopy();
    }
  };

  function fallbackCopy(text) {
    var ta = document.createElement('textarea');
    ta.value = text; ta.style.cssText = 'position:fixed;opacity:0';
    document.body.appendChild(ta); ta.select();
    try { document.execCommand('copy'); } catch(e) {}
    document.body.removeChild(ta);
  }

  /* ── Toast ── */
  window.showToast = function(msg, type) {
    var c = document.getElementById('toastContainer');
    var t = document.createElement('div');
    t.className = 'toast ' + (type || 'info');
    t.textContent = msg;
    c.appendChild(t);
    setTimeout(function() { if (t.parentNode) t.remove(); }, 2600);
  };

  /* ── Entrance animation ── */
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        var idx = cards.indexOf(entry.target);
        var delay = Math.min(idx * 50, 400);
        setTimeout(function() { entry.target.classList.add('visible'); }, delay);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.03, rootMargin: '0px 0px -30px 0px' });
  cards.forEach(function(c) { observer.observe(c); });

  /* ── Keyboard: / to focus search ── */
  document.addEventListener('keydown', function(e) {
    if (e.key === '/' && document.activeElement !== searchInput && !lightbox.classList.contains('active')) {
      e.preventDefault(); searchInput.focus();
    }
  });

  /* ── Sparkle cursor ── */
  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var lastSparkle = 0;
  var sparkleColors = ['#FFD54F','#FF7043','#26A69A','#F48FB1','#CE93D8','#81D4FA','#81C784'];

  if (!reducedMotion) {
    document.addEventListener('mousemove', function(e) {
      var now = Date.now();
      if (now - lastSparkle < 60) return;
      lastSparkle = now;
      var s = document.createElement('div');
      s.className = 'sparkle';
      s.style.left = (e.clientX - 3) + 'px';
      s.style.top = (e.clientY - 3) + 'px';
      s.style.background = sparkleColors[Math.floor(Math.random() * sparkleColors.length)];
      document.body.appendChild(s);
      setTimeout(function() { if (s.parentNode) s.remove(); }, 520);
    });
  }

  /* ── Mascot ── */
  var mascot = document.getElementById('mascot');
  var mascotTip = document.getElementById('mascotTip');
  var mascotTimer = null;
  var mascotIdx = 0;
  var mascotMsgs = ['Cari wallpaper favoritmu!','Klik hati ya!','Zero CPU lho!','Coba dark mode!','Grid atau List?','Sort by nama bisa'];

  function showMascotTip() {
    mascotTip.textContent = mascotMsgs[mascotIdx % mascotMsgs.length];
    mascotIdx++;
    mascotTip.classList.add('show');
    clearTimeout(mascotTimer);
    mascotTimer = setTimeout(function() { mascotTip.classList.remove('show'); }, 3000);
  }

  if (mascot) {
    mascot.addEventListener('click', function() {
      mascot.classList.remove('bounce'); void mascot.offsetWidth; mascot.classList.add('bounce');
      showMascotTip();
    });
    var lastMS = 0;
    window.addEventListener('scroll', function() {
      var y = window.scrollY;
      if (Math.abs(y - lastMS) > 300) { lastMS = y; mascot.classList.remove('bounce'); void mascot.offsetWidth; mascot.classList.add('bounce'); }
    }, { passive: true });
    setTimeout(showMascotTip, 2500);
  }

  /* ── Init ── */
  initFavButtons();
})();
</script>
