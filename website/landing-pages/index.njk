---
layout: layout.njk
title: Welcome to HTMLWallarper
permalink: landing-pages/index.html
---

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">

{% raw %}
<style>
  /* ===== CSS VARIABLES ===== */
  :root {
    /* Palette */
    --bg: #FEF6E8; --bg-alt: #FFF0DB; --bg-dot: #F0D9B5;
    --card: #FFFFFF; --card-border: #E8CFA8; --card-border-hover: #E8A85C;
    --text: #3D2C1E; --text-muted: #8B7355; --text-light: #A89279;
    
    /* Brand Colors */
    --primary: #FF7043; --primary-hover: #FF5722; --primary-light: #FFCCBC;
    --secondary: #26A69A; --secondary-light: #B2DFDB;
    --accent: #FFD54F; --accent-light: #FFF8E1; --accent-dark: #F57F17;
    --purple: #CE93D8; --purple-light: #F3E5F5;
    --pink: #F48FB1; --pink-light: #FCE4EC; --pink-dark: #E91E63;
    --sky: #81D4FA; --sky-light: #E1F5FE; --sky-dark: #0288D1;
    --green: #81C784; --green-light: #E8F5E9; --green-dark: #2E7D32;

    /* Effects & Spacing */
    --shadow-sm: 0 4px 12px rgba(61,44,30,0.08);
    --shadow-card: 0 5px 0 0 var(--card-border), 0 8px 24px rgba(61,44,30,0.08);
    --shadow-card-hover: 0 5px 0 0 var(--card-border-hover), 0 12px 32px rgba(255,112,67,0.15);
    --shadow-glass: 0 8px 32px rgba(0,0,0,0.05);
    
    --radius-sm: 0.75rem; --radius-md: 1rem; --radius-lg: 1.5rem; --radius-xl: 2rem;
    --bounce: cubic-bezier(0.68, -0.4, 0.265, 1.4);
    --smooth: cubic-bezier(0.4, 0, 0.2, 1);
    --nav-h: 70px;
  }

  [data-theme="dark"] {
    --bg: #1A192B; --bg-alt: #22213A; --bg-dot: #2D2C4A;
    --card: #272643; --card-border: #3A3960; --card-border-hover: #FF8A65;
    --text: #F0E6D6; --text-muted: #9E93A8; --text-light: #6E6585;
    --primary: #FF8A65; --primary-hover: #FFAB91; --primary-light: rgba(255,138,101,0.14);
    --secondary: #4DB6AC; --secondary-light: rgba(77,182,172,0.14);
    --accent: #FFE082; --accent-light: rgba(255,224,130,0.12); --accent-dark: #FFB300;
    --purple: #CE93D8; --purple-light: rgba(206,147,216,0.12);
    --pink: #F48FB1; --pink-light: rgba(244,143,177,0.12); --pink-dark: #FF80AB;
    --sky: #81D4FA; --sky-light: rgba(129,212,250,0.12); --sky-dark: #4FC3F7;
    --green: #81C784; --green-light: rgba(129,199,132,0.12); --green-dark: #66BB6A;
    --shadow-sm: 0 4px 12px rgba(0,0,0,0.25);
    --shadow-card: 0 5px 0 0 var(--card-border), 0 8px 24px rgba(0,0,0,0.25);
    --shadow-card-hover: 0 5px 0 0 var(--card-border-hover), 0 12px 32px rgba(255,138,101,0.12);
    --shadow-glass: 0 8px 32px rgba(0,0,0,0.25);
  }

  /* ===== BASE ===== */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Nunito', sans-serif; background: var(--bg); color: var(--text);
    overflow-x: hidden; transition: background 0.5s var(--smooth), color 0.5s var(--smooth); line-height: 1.6;
  }
  /* Dot pattern */
  body::before {
    content: ''; position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background-image: radial-gradient(var(--bg-dot) 1px, transparent 1px);
    background-size: 24px 24px; opacity: 0.4; transition: opacity 0.5s;
  }
  h1, h2, h3, h4 { font-family: 'Fredoka', sans-serif; line-height: 1.2; }
  a { text-decoration: none; color: inherit; }
  img { max-width: 100%; display: block; }
  code, .code-block code { font-family: 'Courier New', Courier, monospace; }
  :focus-visible { outline: 3px solid var(--primary); outline-offset: 2px; border-radius: 4px; }

  /* ===== SCROLL PROGRESS ===== */
  #scrollProgress {
    position: fixed; top: 0; left: 0; height: 4px; z-index: 10001;
    background: linear-gradient(90deg, var(--primary), var(--accent), var(--secondary), var(--primary));
    background-size: 300% 100%; animation: progressSlide 4s linear infinite;
    width: 0%; border-radius: 0 4px 4px 0; transition: width 0.06s linear;
  }
  @keyframes progressSlide { to { background-position: 300% 0; } }

  /* ===== NAVIGATION ===== */
  #mainNav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 10000;
    height: var(--nav-h); background: rgba(254, 246, 232, 0.85);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border-bottom: 2px solid var(--card-border);
    transition: background 0.4s, border-color 0.4s, box-shadow 0.3s;
  }
  [data-theme="dark"] #mainNav {
    background: rgba(26, 25, 43, 0.85);
  }
  #mainNav.scrolled { background: var(--bg); box-shadow: var(--shadow-sm); }
  .nav-inner {
    max-width: 1100px; margin: 0 auto; height: 100%; display: flex;
    align-items: center; justify-content: space-between; padding: 0 1.5rem;
  }
  .nav-logo {
    display: flex; align-items: center; gap: 0.75rem;
    font-family: 'Fredoka', sans-serif; font-weight: 700; font-size: 1.1rem;
    color: var(--text); transition: color 0.4s;
  }
  .nav-logo-icon {
    width: 36px; height: 36px; border-radius: var(--radius-sm);
    background: var(--primary); border: 2px solid var(--text);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 2px 2px 0 var(--text);
    transition: transform 0.3s var(--bounce);
  }
  .nav-logo:hover .nav-logo-icon { transform: rotate(-10deg) scale(1.1); }
  .nav-links { display: flex; align-items: center; gap: 0.5rem; }
  .nav-links a {
    padding: 0.5rem 0.9rem; border-radius: var(--radius-sm);
    font-size: 0.85rem; font-weight: 700; color: var(--text-muted);
    transition: all 0.2s; border: 2px solid transparent;
  }
  .nav-links a:hover { color: var(--primary); background: var(--primary-light); }
  .nav-cta {
    padding: 0.5rem 1.2rem !important; background: var(--primary) !important; color: #fff !important;
    border: 2.5px solid var(--text) !important; border-radius: var(--radius-sm) !important;
    box-shadow: 2px 2px 0 var(--text); transition: all 0.25s var(--bounce) !important;
  }
  .nav-cta:hover {
    background: var(--primary-hover) !important; transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--text) !important;
  }
  
  /* Theme Toggle */
  .theme-toggle {
    width: 40px; height: 40px; border-radius: 50%; background: var(--accent-light);
    border: 2px solid var(--card-border); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.3s var(--bounce); position: relative; overflow: hidden;
    flex-shrink: 0;
  }
  .theme-toggle:hover { transform: scale(1.1) rotate(15deg); border-color: var(--accent-dark); }
  .theme-toggle .sun { opacity: 1; transform: scale(1) rotate(0deg); position: absolute; transition: all 0.4s; }
  .theme-toggle .moon { opacity: 0; transform: scale(0.4) rotate(-90deg); position: absolute; transition: all 0.4s; }
  [data-theme="dark"] .theme-toggle .sun { opacity: 0; transform: scale(0.4) rotate(90deg); }
  [data-theme="dark"] .theme-toggle .moon { opacity: 1; transform: scale(1) rotate(0deg); }

  /* Hamburger & Mobile Menu */
  .hamburger {
    display: none; width: 40px; height: 40px; border-radius: var(--radius-sm);
    background: var(--card); border: 2px solid var(--card-border); cursor: pointer;
    flex-direction: column; align-items: center; justify-content: center; gap: 5px; flex-shrink: 0;
  }
  .hamburger span { display: block; width: 20px; height: 2.5px; background: var(--text); border-radius: 2px; transition: all 0.3s; transform-origin: center; }
  .hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }
  
  .mobile-menu {
    display: none; position: fixed; top: var(--nav-h); left: 0; right: 0;
    background: var(--bg); border-bottom: 3px solid var(--card-border);
    padding: 1rem; z-index: 9999; box-shadow: var(--shadow-glass);
    transform: translateY(-10px); opacity: 0; pointer-events: none;
    transition: all 0.3s var(--bounce);
  }
  .mobile-menu.open { transform: translateY(0); opacity: 1; pointer-events: auto; }
  .mobile-menu a {
    display: block; padding: 0.8rem 1rem; border-radius: var(--radius-sm);
    font-weight: 700; font-size: 0.95rem; color: var(--text-muted); margin-bottom: 0.5rem;
    transition: all 0.2s;
  }
  .mobile-menu a:hover { background: var(--primary-light); color: var(--primary); }

  @media (max-width: 768px) {
    .nav-links { display: none !important; }
    .hamburger { display: flex; }
    .mobile-menu { display: block; }
  }

  /* ===== DECORATIONS ===== */
  .cartoon-deco { position: absolute; pointer-events: none; z-index: 0; }
  .deco-cloud {
    width: 80px; height: 40px; background: var(--card); border-radius: 40px;
    border: 2.5px solid var(--card-border); box-shadow: 3px 3px 0 var(--card-border);
    animation: floatCloud 9s ease-in-out infinite; transition: background 0.4s, border-color 0.4s;
  }
  .deco-cloud::before {
    content: ''; position: absolute; width: 36px; height: 36px; background: var(--card);
    border-radius: 50%; border: 2.5px solid var(--card-border); border-bottom-color: transparent;
    top: -20px; left: 14px;
  }
  .deco-cloud::after {
    content: ''; position: absolute; width: 24px; height: 24px; background: var(--card);
    border-radius: 50%; border: 2.5px solid var(--card-border); border-bottom-color: transparent;
    top: -12px; left: 42px;
  }
  @keyframes floatCloud {
    0%, 100% { transform: translateY(0) translateX(0); }
    50% { transform: translateY(-12px) translateX(8px); }
  }

  .deco-star {
    width: 18px; height: 18px; background: var(--accent);
    clip-path: polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%);
    animation: twinkle 3s ease-in-out infinite;
  }
  @keyframes twinkle {
    0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.8; }
    50% { transform: scale(1.3) rotate(15deg); opacity: 1; }
  }
  .deco-heart {
    width: 16px; height: 14px; background: var(--pink); transform: rotate(-45deg);
    border-radius: 0 50% 0 50%; animation: floatHeart 4s ease-in-out infinite;
  }
  .deco-heart::before {
    content: ''; position: absolute; width: 16px; height: 14px; background: var(--pink);
    border-radius: 50% 50% 0 0; top: -7px; left: 0;
  }
  @keyframes floatHeart {
    0%, 100% { transform: rotate(-45deg) translateY(0) scale(1); }
    50% { transform: rotate(-45deg) translateY(-8px) scale(1.1); }
  }

  /* ===== REVEAL ANIMATION ===== */
  .reveal {
    opacity: 0; transform: translateY(30px) scale(0.95);
    transition: opacity 0.7s var(--bounce), transform 0.7s var(--bounce);
  }
  .reveal.visible { opacity: 1; transform: translateY(0) scale(1); }
  .d-1 { transition-delay: 0.1s; }
  .d-2 { transition-delay: 0.2s; }
  .d-3 { transition-delay: 0.3s; }
  .d-4 { transition-delay: 0.4s; }
  .d-5 { transition-delay: 0.5s; }

  /* ===== HERO ===== */
  .hero-section {
    position: relative; min-height: 100vh; display: flex; align-items: center; justify-content: center;
    padding: calc(var(--nav-h) + 2rem) 1.25rem 5rem; overflow: hidden;
  }
  /* Background Blobs */
  .hero-bg-blob {
    position: absolute; border-radius: 50%; pointer-events: none; filter: blur(90px); opacity: 0.25;
    transition: background 0.6s;
  }
  .blob-1 { width: 500px; height: 500px; background: var(--primary); top: -10%; right: -10%; }
  .blob-2 { width: 400px; height: 400px; background: var(--secondary); bottom: -5%; left: -5%; }
  .blob-3 { width: 250px; height: 250px; background: var(--accent); top: 40%; left: 50%; margin-left: -125px; opacity: 0.15; }

  .hero-content { position: relative; z-index: 2; text-align: center; max-width: 700px; margin: 0 auto; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem;
    border-radius: 999px; background: var(--card); border: 2.5px solid var(--card-border);
    box-shadow: 3px 3px 0 var(--card-border); font-size: 0.75rem; font-weight: 700;
    color: var(--text-muted); margin-bottom: 2rem; transition: all 0.4s;
  }
  .dot-live {
    width: 8px; height: 8px; border-radius: 50%; background: var(--green);
    border: 2px solid var(--text); animation: pulse 2s ease-in-out infinite; flex-shrink: 0;
  }
  @keyframes pulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.2); } }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.2rem); font-weight: 700; color: var(--text);
    margin-bottom: 1rem; line-height: 1.1; transition: color 0.4s;
  }
  .hero-title-accent {
    color: var(--primary); position: relative; display: inline-block;
    transition: color 0.4s; text-shadow: 0 0 20px var(--primary-light);
  }
  .hero-sub {
    font-size: clamp(1rem, 2.2vw, 1.15rem); color: var(--text-muted);
    line-height: 1.7; max-width: 550px; margin: 0 auto 2.5rem; transition: color 0.4s;
  }

  /* Buttons */
  .btn {
    display: inline-flex; align-items: center; gap: 0.6rem; padding: 0.85rem 1.75rem;
    border-radius: var(--radius-md); font-family: 'Fredoka', sans-serif; font-weight: 600;
    font-size: 1rem; cursor: pointer; border: 2.5px solid var(--text);
    transition: all 0.25s var(--bounce); text-decoration: none; position: relative; overflow: hidden;
  }
  .btn:active { transform: scale(0.95) !important; }
  .btn-primary {
    background: var(--primary); color: #fff; box-shadow: 4px 4px 0 var(--text);
  }
  .btn-primary:hover { background: var(--primary-hover); transform: translateY(-3px); box-shadow: 6px 6px 0 var(--text); }
  .btn-secondary {
    background: var(--card); color: var(--text); box-shadow: 4px 4px 0 var(--card-border);
    transition: all 0.25s var(--bounce), background 0.4s, color 0.4s;
  }
  .btn-secondary:hover {
    transform: translateY(-3px); box-shadow: 6px 6px 0 var(--card-border-hover);
    border-color: var(--primary); color: var(--primary);
  }

  .hero-hint {
    margin-top: 1.5rem; font-size: 0.75rem; color: var(--text-light);
    font-weight: 600; transition: color 0.4s;
  }
  .hero-hint kbd {
    display: inline-block; padding: 0.1rem 0.5rem; background: var(--card);
    border: 2px solid var(--card-border); border-radius: 0.3rem; font-family: 'Nunito', sans-serif;
    font-size: 0.7rem; box-shadow: 1px 1px 0 var(--card-border); color: var(--text-muted);
  }

  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
    animation: scrollBounce 2.5s ease-in-out infinite;
  }
  .scroll-indicator span {
    font-size: 0.65rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.15em; color: var(--text-light);
  }
  @keyframes scrollBounce {
    0%,100% { transform: translateX(-50%) translateY(0); opacity: 1; }
    50% { transform: translateX(-50%) translateY(10px); opacity: 0.5; }
  }

  /* ===== PREVIEW FLOAT WINDOWS ===== */
  .preview-float {
    position: absolute; border-radius: var(--radius-md); overflow: hidden;
    border: 3px solid var(--card-border); box-shadow: 6px 6px 0 var(--card-border);
    transition: transform 0.5s var(--bounce), border-color 0.4s;
    backdrop-filter: blur(4px);
  }
  /* Positioning Utilities */
  .pos-1 { top: 8%; right: 4%; transform: rotate(3deg); }
  .pos-2 { bottom: 15%; left: 3%; transform: rotate(-4deg); }
  .pos-3 { top: 20%; left: 8%; transform: rotate(5deg); opacity: 0.6; }
  
  .pw-bar {
    height: 24px; background: rgba(0,0,0,0.05); border-bottom: 2px solid var(--card-border);
    display: flex; align-items: center; padding: 0 8px; gap: 5px;
  }
  [data-theme="dark"] .pw-bar { background: rgba(0,0,0,0.2); }
  
  .pw-dot { width: 7px; height: 7px; border-radius: 50%; border: 1.5px solid var(--text); flex-shrink: 0; }
  .pw-dot.r { background: #EF5350; }
  .pw-dot.y { background: #FFC107; }
  .pw-dot.g { background: #66BB6A; }
  .pw-body { transition: background 0.4s; }

  /* ===== CAROUSEL ===== */
  .carousel-wrap {
    position: relative; border-radius: var(--radius-xl); overflow: hidden;
    border: 3px solid var(--card-border); box-shadow: 6px 6px 0 var(--card-border);
    background: var(--card); transition: all 0.4s;
  }
  .carousel-area {
    overflow: hidden; position: relative; aspect-ratio: 16/9;
    background: var(--bg-alt); transition: background 0.4s;
  }
  .carousel-track {
    display: flex; height: 100%; transition: transform 0.6s var(--bounce);
  }
  .carousel-slide { min-width: 100%; height: 100%; position: relative; }
  .carousel-slide iframe {
    position: absolute; left: 50%; top: 50%; width: 1280px; height: 720px;
    margin-left: -640px; margin-top: -360px; transform: scale(0.3125);
    transform-origin: center center; border: none; pointer-events: none;
  }
  .carousel-controls {
    position: absolute; bottom: 0; left: 0; right: 0; padding: 1rem;
    display: flex; align-items: center; justify-content: space-between; z-index: 5;
  }
  .carousel-controls::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.3), transparent); pointer-events: none; z-index: -1;
  }
  .carousel-btn {
    width: 36px; height: 36px; border-radius: 50%; background: var(--card);
    border: 2.5px solid var(--text); box-shadow: 2px 2px 0 var(--text);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    color: var(--text); transition: all 0.2s var(--bounce); flex-shrink: 0;
  }
  .carousel-btn:hover { transform: scale(1.1); box-shadow: 3px 3px 0 var(--text); }
  .carousel-dots { display: flex; gap: 6px; }
  .carousel-dot {
    width: 10px; height: 10px; border-radius: 50%; background: rgba(0,0,0,0.2);
    border: 2px solid rgba(255,255,255,0.5); cursor: pointer;
    transition: all 0.3s var(--bounce);
  }
  .carousel-dot.active { background: var(--primary); border-color: #fff; transform: scale(1.25); }
  .carousel-dot:hover { transform: scale(1.15); }

  /* ===== FEATURES ===== */
  .feature-card {
    background: var(--card); border: 2.5px solid var(--card-border);
    border-radius: var(--radius-lg); padding: 2rem; box-shadow: var(--shadow-card);
    transition: all 0.4s; position: relative; overflow: hidden; cursor: default;
  }
  .feature-card:hover {
    border-color: var(--card-border-hover); box-shadow: var(--shadow-card-hover); transform: translateY(-4px);
  }
  .feature-icon {
    width: 56px; height: 56px; border-radius: var(--radius-md); display: flex;
    align-items: center; justify-content: center; border: 2.5px solid;
    margin-bottom: 1.25rem; box-shadow: 3px 3px 0 currentColor; flex-shrink: 0;
    transition: background 0.4s, border-color 0.4s;
  }
  /* Feature Colors */
  .fc-primary { background: var(--primary-light); border-color: var(--primary); color: var(--primary); }
  .fc-secondary { background: var(--secondary-light); border-color: var(--secondary); color: var(--secondary); }
  .fc-purple { background: var(--purple-light); border-color: var(--purple); color: var(--purple); }
  .fc-accent { background: var(--accent-light); border-color: var(--accent-dark); color: var(--accent-dark); }
  .fc-pink { background: var(--pink-light); border-color: var(--pink); color: var(--pink); }
  .fc-sky { background: var(--sky-light); border-color: var(--sky-dark); color: var(--sky-dark); }

  .feature-card h3 { font-size: 1.2rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text); transition: color 0.4s; }
  .feature-card p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; transition: color 0.4s; }

  /* ===== STATS ===== */
  .stats-section {
    border-top: 3px solid var(--card-border); border-bottom: 3px solid var(--card-border);
    background: var(--bg-alt); position: relative; overflow: hidden; transition: background 0.4s;
  }
  .stat-card {
    text-align: center; padding: 1.5rem 1rem; background: var(--card);
    border: 2.5px solid var(--card-border); border-radius: var(--radius-lg);
    box-shadow: 4px 4px 0 var(--card-border); transition: transform 0.3s var(--bounce);
  }
  .stat-card:hover { transform: translateY(-4px) rotate(-1deg); }
  .stat-value {
    font-family: 'Fredoka', sans-serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 700;
    color: var(--primary); transition: color 0.4s; font-variant-numeric: tabular-nums;
  }
  .stat-label { font-size: 0.85rem; font-weight: 700; color: var(--text-muted); margin-top: 0.3rem; }

  /* ===== COMPARISON ===== */
  .comparison-container {
    position: relative; overflow: hidden; border-radius: var(--radius-xl);
    border: 3px solid var(--card-border); box-shadow: 6px 6px 0 var(--card-border);
    cursor: col-resize; user-select: none; aspect-ratio: 16/9; transition: border-color 0.4s;
  }
  .comp-layer { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
  .comp-slider-line {
    position: absolute; top: 0; bottom: 0; width: 4px; background: var(--primary);
    z-index: 10; box-shadow: 0 0 0 2px var(--text); transition: background 0.4s;
  }
  .comp-handle {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 40px; height: 40px; border-radius: 50%; background: var(--primary);
    border: 3px solid var(--text); box-shadow: 3px 3px 0 var(--text);
    display: flex; align-items: center; justify-content: center; color: #fff; transition: background 0.4s;
  }
  .comp-label {
    position: absolute; top: 1rem; padding: 0.3rem 0.8rem; border-radius: 999px;
    font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em;
    border: 2px solid var(--text); box-shadow: 2px 2px 0 var(--text); z-index: 5; transition: background 0.4s;
  }
  .comp-label-before { left: 1rem; background: var(--bg-alt); color: var(--text-muted); }
  .comp-label-after { right: 1rem; background: var(--primary); color: #fff; }

  /* ===== INSTALL STEPS ===== */
  .step-connector {
    width: 4px; height: 3rem; margin: 0.5rem auto; background: var(--card-border);
    border-radius: 4px; position: relative; overflow: hidden; transition: background 0.4s;
  }
  .step-connector-fill {
    position: absolute; inset: 0; background: var(--primary); border-radius: 4px;
    transform: scaleY(0); transform-origin: top; transition: transform 0.8s var(--smooth);
  }
  .step-item.completed .step-connector-fill { transform: scaleY(1); }

  .step-number {
    width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-family: 'Fredoka', sans-serif; font-weight: 700; font-size: 1.2rem;
    background: var(--card); border: 3px solid var(--card-border); color: var(--text-muted);
    box-shadow: 3px 3px 0 var(--card-border); transition: all 0.4s var(--bounce); flex-shrink: 0;
  }
  .step-item.active .step-number {
    background: var(--primary); border-color: var(--text); color: #fff;
    box-shadow: 3px 3px 0 var(--text); transform: scale(1.1) rotate(5deg);
  }
  .step-item.completed .step-number {
    background: var(--green); border-color: var(--text); color: #fff;
    box-shadow: 3px 3px 0 var(--text);
  }

  .code-block {
    background: #1e1e1e; border: 2.5px solid var(--card-border); border-radius: var(--radius-sm);
    padding: 0.8rem 1rem; font-size: 0.8rem; color: #a5d6ff;
    display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
    box-shadow: 3px 3px 0 var(--card-border); transition: border-color 0.3s; overflow-x: auto;
  }
  .code-block:hover { border-color: var(--primary); }
  .code-ck { color: #ff79c6; font-weight: 700; }
  .code-cf { color: #8be9fd; }
  .code-cp { color: #f1fa8c; }
  
  .copy-btn {
    padding: 0.4rem 0.7rem; border-radius: var(--radius-sm); background: var(--card);
    border: 2px solid var(--card-border); color: var(--text-muted); font-size: 0.7rem;
    font-weight: 800; font-family: 'Nunito', sans-serif; cursor: pointer;
    transition: all 0.2s var(--bounce); box-shadow: 1px 1px 0 var(--card-border); white-space: nowrap;
  }
  .copy-btn:hover { border-color: var(--primary); color: var(--primary); transform: translate(-1px,-1px); }
  .copy-btn:active { transform: translate(1px,1px); }
  .copy-btn.copied { background: var(--green-light); border-color: var(--green); color: var(--green-dark); }

  /* ===== FAQ ===== */
  .faq-item {
    border: 2.5px solid var(--card-border); border-radius: var(--radius-lg);
    overflow: hidden; background: var(--card); box-shadow: 4px 4px 0 var(--card-border);
    transition: all 0.3s var(--bounce); cursor: pointer;
  }
  .faq-item.open { border-color: var(--primary); box-shadow: 4px 4px 0 var(--primary); }
  .faq-question {
    padding: 1.2rem 1.25rem; cursor: pointer; display: flex; align-items: center;
    justify-content: space-between; font-family: 'Fredoka', sans-serif; font-weight: 600;
    font-size: 1rem; color: var(--text); transition: color 0.3s; gap: 1rem;
  }
  .faq-item.open .faq-question { color: var(--primary); }
  .faq-chevron { transition: transform 0.4s var(--bounce); color: var(--text-light); flex-shrink: 0; }
  .faq-item.open .faq-chevron { transform: rotate(180deg); color: var(--primary); }
  .faq-answer {
    max-height: 0; overflow: hidden; transition: max-height 0.5s var(--smooth), padding 0.3s;
    padding: 0 1.25rem; cursor: default;
  }
  .faq-item.open .faq-answer { max-height: 300px; padding: 0 1.25rem 1.25rem; }
  .faq-answer p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.7; }
  .faq-answer code {
    background: var(--primary-light); color: var(--primary); padding: 0.15rem 0.4rem;
    border-radius: 0.3rem; font-size: 0.8rem; font-weight: 700; border: 1.5px solid var(--primary);
  }
  .faq-answer strong { color: var(--text); }

  /* ===== CTA SECTION ===== */
  .cta-section {
    position: relative; overflow: hidden; padding: 5rem 1.25rem; background: var(--bg-alt);
    border-top: 3px solid var(--card-border); transition: background 0.4s, border-color 0.4s;
  }
  .cta-inner { position: relative; z-index: 2; text-align: center; max-width: 600px; margin: 0 auto; }
  .cta-section h2 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; color: var(--text); margin-bottom: 1rem; }
  .cta-section p { font-size: 1.1rem; color: var(--text-muted); line-height: 1.7; margin-bottom: 2rem; }

  /* ===== FOOTER ===== */
  .site-footer {
    border-top: 3px solid var(--card-border); padding: 2rem 1.25rem; background: var(--bg);
    transition: background 0.4s, border-color 0.4s;
  }
  .footer-inner {
    max-width: 1100px; margin: 0 auto; display: flex; flex-wrap: wrap; align-items: center;
    justify-content: space-between; gap: 1rem;
  }
  .footer-logo { display: flex; align-items: center; gap: 0.6rem; }
  .footer-logo-icon {
    width: 30px; height: 30px; border-radius: 0.5rem; background: var(--primary);
    border: 2px solid var(--text); display: flex; align-items: center; justify-content: center;
    box-shadow: 1px 1px 0 var(--text);
  }
  .footer-logo span { font-family: 'Fredoka', sans-serif; font-weight: 600; font-size: 0.9rem; color: var(--text-muted); }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a { font-size: 0.85rem; font-weight: 700; color: var(--text-light); transition: color 0.2s; }
  .footer-links a:hover { color: var(--primary); }
  .footer-copy { font-size: 0.8rem; font-weight: 700; color: var(--text-light); }

  /* ===== BACK TO TOP ===== */
  #backToTop {
    position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9990; width: 48px; height: 48px;
    border-radius: 50%; background: var(--primary); border: 2.5px solid var(--text);
    box-shadow: 3px 3px 0 var(--text); cursor: pointer; display: flex; align-items: center;
    justify-content: center; color: #fff; transition: all 0.3s var(--bounce), background 0.4s;
    opacity: 0; transform: translateY(20px) scale(0.8); pointer-events: none;
  }
  #backToTop.visible { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
  #backToTop:hover { transform: translateY(-3px) scale(1.1); box-shadow: 4px 4px 0 var(--text); }

  /* ===== TOAST ===== */
  .toast-container {
    position: fixed; bottom: 5rem; right: 1.5rem; z-index: 99999;
    display: flex; flex-direction: column; gap: 0.6rem; pointer-events: none;
  }
  .toast {
    pointer-events: auto; padding: 0.75rem 1.1rem; border-radius: var(--radius-sm);
    font-size: 0.85rem; font-weight: 700; border: 2.5px solid var(--text);
    box-shadow: 3px 3px 0 var(--text); animation: toastIn 0.4s var(--bounce), toastOut 0.3s ease 2.2s forwards;
  }
  .toast.success { background: var(--green); color: var(--green-dark); border-color: var(--green-dark); box-shadow: 3px 3px 0 var(--green-dark); }
  .toast.info { background: var(--sky); color: var(--sky-dark); border-color: var(--sky-dark); box-shadow: 3px 3px 0 var(--sky-dark); }
  @keyframes toastIn { from { opacity:0; transform: translateY(1rem) scale(0.9); } to { opacity:1; transform: translateY(0) scale(1); } }
  @keyframes toastOut { to { opacity:0; transform: translateY(-0.5rem) scale(0.9); } }

  /* ===== SPARKLE ===== */
  .sparkle {
    position: fixed; pointer-events: none; z-index: 99997; width: 8px; height: 8px;
    clip-path: polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%);
    animation: sparkleFade 0.6s ease-out forwards;
  }
  @keyframes sparkleFade { 0% { opacity:1; transform:scale(1) rotate(0); } 100% { opacity:0; transform:scale(0) rotate(90deg); } }

  /* ===== CONFETTI ===== */
  @keyframes confettiBurst {
    0% { opacity: 1; transform: translate(0, 0) rotate(0) scale(1); }
    100% { opacity: 0; transform: translate(var(--cx), var(--cy)) rotate(var(--cr)) scale(0.15); }
  }
  .confetti-piece {
    position: fixed; pointer-events: none; z-index: 99998;
    animation: confettiBurst 1s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  /* ===== MASCOT ===== */
  #mascot {
    position: fixed; bottom: 1.5rem; left: 1.5rem; z-index: 9989; width: 56px; height: 56px;
    border-radius: 50% 50% 50% 45%; background: var(--primary); border: 3px solid var(--text);
    box-shadow: 3px 3px 0 var(--text); cursor: pointer; overflow: hidden;
    transition: transform 0.4s var(--bounce), background 0.4s;
  }
  #mascot:hover { transform: scale(1.15) rotate(-5deg); }
  #mascot .eye { position: absolute; width: 8px; height: 10px; background: var(--text); border-radius: 50%; top: 18px; }
  #mascot .eye.left { left: 14px; } #mascot .eye.right { right: 14px; }
  #mascot .eye::after { content: ''; position: absolute; width: 3px; height: 3px; background: #fff; border-radius: 50%; top: 1px; right: 0; }
  #mascot .mouth {
    position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%); width: 10px; height: 5px;
    border-bottom: 2.5px solid var(--text); border-radius: 0 0 50% 50%;
  }
  #mascot .blush { position: absolute; width: 10px; height: 5px; background: var(--pink); border-radius: 50%; top: 32px; opacity: 0.5; }
  #mascot .blush.left { left: 5px; } #mascot .blush.right { right: 5px; }
  #mascot.bounce { animation: mascotBounce 0.5s var(--bounce); }
  @keyframes mascotBounce {
    0% { transform: scale(1); } 30% { transform: scale(1.3) rotate(10deg); } 60% { transform: scale(0.9) rotate(-5deg); } 100% { transform: scale(1) rotate(0); }
  }

  #mascotTip {
    position: fixed; bottom: 4.5rem; left: 1.5rem; z-index: 9989; background: var(--card);
    border: 2.5px solid var(--card-border); border-radius: var(--radius-sm); padding: 0.5rem 0.9rem;
    font-size: 0.75rem; font-weight: 700; color: var(--text-muted); box-shadow: 3px 3px 0 var(--card-border);
    opacity: 0; transform: translateY(8px); pointer-events: none; transition: all 0.3s var(--bounce);
    white-space: nowrap;
  }
  #mascotTip.show { opacity: 1; transform: translateY(0); }
  #mascotTip::after {
    content: ''; position: absolute; bottom: -6px; left: 1.2rem; width: 10px; height: 10px;
    background: var(--card); border-right: 2.5px solid var(--card-border); border-bottom: 2.5px solid var(--card-border); transform: rotate(45deg);
  }

  /* ===== UTILITIES ===== */
  .section-label {
    display: inline-block; padding: 0.4rem 1rem; border-radius: 999px; font-size: 0.7rem; font-weight: 800;
    letter-spacing: 0.1em; text-transform: uppercase; border: 2px solid; margin-bottom: 1rem;
    transition: background 0.4s, color 0.4s, border-color 0.4s;
  }
  .label-primary { color: var(--primary); background: var(--primary-light); border-color: var(--primary); }
  .label-secondary { color: var(--secondary); background: var(--secondary-light); border-color: var(--secondary); }
  .label-purple { color: var(--purple); background: var(--purple-light); border-color: var(--purple); }
  .label-pink { color: var(--pink); background: var(--pink-light); border-color: var(--pink); }
  .label-accent { color: var(--accent-dark); background: var(--accent-light); border-color: var(--accent); }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 640px) {
    .preview-float { display: none !important; }
    .hero-buttons { flex-direction: column; align-items: center; }
    .btn { width: 100%; max-width: 280px; justify-content: center; }
    #mascot, #mascotTip { display: none; }
  }
  @media (min-width: 641px) and (max-width: 768px) {
    #mascot, #mascotTip { display: none; }
  }

  /* ===== REDUCED MOTION ===== */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important; animation-iteration-count: 1 !important;
      transition-duration: 0.15ms !important;
    }
    .sparkle, .confetti-piece { display: none !important; }
  }

  /* ===== SCROLLBAR ===== */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--card-border); border-radius: 4px; border: 2px solid var(--bg); }
  ::-webkit-scrollbar-thumb:hover { background: var(--primary); }
</style>
