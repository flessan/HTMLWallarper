<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>
  /* ===== CSS VARIABLES ===== */
  :root {
    --bg: #FEF6E8;
    --bg-alt: #FFF0DB;
    --bg-dot: #F5DFC0;
    --card: #FFFFFF;
    --card-border: #F0D9B5;
    --card-border-hover: #E8A85C;
    --text: #3D2C1E;
    --text-muted: #8B7355;
    --text-light: #A89279;
    --primary: #FF7043;
    --primary-hover: #FF5722;
    --primary-light: #FFCCBC;
    --primary-glow: rgba(255, 112, 67, 0.25);
    --secondary: #26A69A;
    --secondary-light: #B2DFDB;
    --accent: #FFD54F;
    --accent-light: #FFF8E1;
    --purple: #CE93D8;
    --purple-light: #F3E5F5;
    --pink: #F48FB1;
    --pink-light: #FCE4EC;
    --sky: #81D4FA;
    --sky-light: #E1F5FE;
    --green: #A5D6A7;
    --green-light: #E8F5E9;
    --shadow-sm: 0 2px 8px rgba(61,44,30,0.06);
    --shadow-md: 0 4px 16px rgba(61,44,30,0.08);
    --shadow-lg: 0 8px 32px rgba(61,44,30,0.10);
    --shadow-card: 0 4px 0 0 #F0D9B5, 0 8px 24px rgba(61,44,30,0.08);
    --shadow-card-hover: 0 4px 0 0 #E8A85C, 0 12px 32px rgba(255,112,67,0.15);
    --radius-sm: 0.75rem;
    --radius-md: 1rem;
    --radius-lg: 1.5rem;
    --radius-xl: 2rem;
    --bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);
    --smooth: cubic-bezier(0.4, 0, 0.2, 1);
    --nav-height: 64px;
  }

  [data-theme="dark"] {
    --bg: #1C1B2E;
    --bg-alt: #242338;
    --bg-dot: #2E2D45;
    --card: #2A2942;
    --card-border: #3D3C5C;
    --card-border-hover: #FF8A65;
    --text: #F0E6D6;
    --text-muted: #9E93A8;
    --text-light: #706888;
    --primary: #FF8A65;
    --primary-hover: #FFAB91;
    --primary-light: rgba(255,138,101,0.15);
    --primary-glow: rgba(255,138,101,0.2);
    --secondary: #4DB6AC;
    --secondary-light: rgba(77,182,172,0.15);
    --accent: #FFE082;
    --accent-light: rgba(255,224,130,0.1);
    --purple: #CE93D8;
    --purple-light: rgba(206,147,216,0.12);
    --pink: #F48FB1;
    --pink-light: rgba(244,143,177,0.12);
    --sky: #81D4FA;
    --sky-light: rgba(129,212,250,0.12);
    --green: #A5D6A7;
    --green-light: rgba(165,214,167,0.12);
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.15);
    --shadow-md: 0 4px 16px rgba(0,0,0,0.2);
    --shadow-lg: 0 8px 32px rgba(0,0,0,0.25);
    --shadow-card: 0 4px 0 0 #3D3C5C, 0 8px 24px rgba(0,0,0,0.2);
    --shadow-card-hover: 0 4px 0 0 #FF8A65, 0 12px 32px rgba(255,138,101,0.12);
  }

  /* ===== BASE ===== */
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Nunito', sans-serif;
    background: var(--bg);
    color: var(--text);
    overflow-x: hidden;
    transition: background 0.4s var(--smooth), color 0.4s var(--smooth);
  }
  /* Dot pattern overlay */
  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background-image: radial-gradient(var(--bg-dot) 1px, transparent 1px);
    background-size: 24px 24px;
    opacity: 0.5;
  }
  h1, h2, h3, h4 { font-family: 'Fredoka', sans-serif; }
  a { text-decoration: none; color: inherit; }
  img { max-width: 100%; display: block; }

  /* ===== SCROLL PROGRESS ===== */
  #scrollProgress {
    position: fixed; top: 0; left: 0; height: 4px; z-index: 10001;
    background: linear-gradient(90deg, var(--primary), var(--accent), var(--secondary), var(--primary));
    background-size: 300% 100%;
    animation: progressSlide 4s linear infinite;
    width: 0%; transition: width 0.08s linear;
    border-radius: 0 4px 4px 0;
  }
  @keyframes progressSlide { 0%{background-position:0% 0} 100%{background-position:300% 0} }

  /* ===== NAVIGATION ===== */
  #mainNav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 10000;
    height: var(--nav-height);
    background: var(--bg);
    border-bottom: 2px solid var(--card-border);
    transition: all 0.35s var(--smooth);
  }
  #mainNav.scrolled {
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    box-shadow: var(--shadow-sm);
  }
  .nav-inner {
    max-width: 1100px; margin: 0 auto; height: 100%;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 1.25rem;
  }
  .nav-logo {
    display: flex; align-items: center; gap: 0.625rem;
    font-family: 'Fredoka', sans-serif; font-weight: 700; font-size: 1.1rem;
    color: var(--text);
  }
  .nav-logo-icon {
    width: 36px; height: 36px; border-radius: var(--radius-sm);
    background: var(--primary);
    border: 2px solid var(--text);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 2px 2px 0 var(--text);
    transition: transform 0.3s var(--bounce);
  }
  .nav-logo:hover .nav-logo-icon { transform: rotate(-8deg) scale(1.1); }
  .nav-links { display: flex; align-items: center; gap: 0.25rem; }
  .nav-links a {
    padding: 0.5rem 0.875rem; border-radius: var(--radius-sm);
    font-size: 0.8125rem; font-weight: 700; color: var(--text-muted);
    transition: all 0.25s var(--smooth); border: 2px solid transparent;
  }
  .nav-links a:hover { color: var(--primary); background: var(--primary-light); }
  .nav-cta {
    padding: 0.5rem 1.125rem !important; border-radius: var(--radius-sm) !important;
    background: var(--primary) !important; color: #fff !important;
    border: 2px solid var(--text) !important;
    box-shadow: 2px 2px 0 var(--text);
    transition: all 0.25s var(--bounce) !important;
  }
  .nav-cta:hover {
    background: var(--primary-hover) !important;
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 var(--text) !important;
  }
  .nav-cta:active { transform: translate(1px, 1px); box-shadow: 1px 1px 0 var(--text) !important; }

  /* Theme toggle */
  .theme-toggle {
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--accent-light); border: 2px solid var(--card-border);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all 0.3s var(--bounce); position: relative; overflow: hidden;
  }
  .theme-toggle:hover { transform: scale(1.15) rotate(15deg); border-color: var(--accent); }
  .theme-toggle .sun, .theme-toggle .moon {
    position: absolute; transition: all 0.4s var(--bounce);
  }
  .theme-toggle .sun { opacity: 1; transform: scale(1) rotate(0deg); }
  .theme-toggle .moon { opacity: 0; transform: scale(0.5) rotate(-90deg); }
  [data-theme="dark"] .theme-toggle .sun { opacity: 0; transform: scale(0.5) rotate(90deg); }
  [data-theme="dark"] .theme-toggle .moon { opacity: 1; transform: scale(1) rotate(0deg); }

  /* Hamburger */
  .hamburger {
    display: none; width: 40px; height: 40px; border-radius: var(--radius-sm);
    background: var(--primary-light); border: 2px solid var(--card-border);
    cursor: pointer; flex-direction: column; align-items: center; justify-content: center; gap: 4px;
  }
  .hamburger span {
    display: block; width: 18px; height: 2.5px; background: var(--text);
    border-radius: 2px; transition: all 0.3s var(--bounce);
  }
  .hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(4px, 4px); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(4px, -4px); }

  /* Mobile menu */
  .mobile-menu {
    display: none; position: fixed; top: var(--nav-height); left: 0; right: 0;
    background: var(--bg); border-bottom: 3px solid var(--card-border);
    padding: 1rem; z-index: 9999;
    transform: translateY(-10px); opacity: 0;
    transition: all 0.35s var(--bounce);
    pointer-events: none;
  }
  .mobile-menu.open { transform: translateY(0); opacity: 1; pointer-events: auto; }
  .mobile-menu a {
    display: block; padding: 0.75rem 1rem; border-radius: var(--radius-sm);
    font-weight: 700; font-size: 0.9375rem; color: var(--text-muted);
    transition: all 0.2s;
  }
  .mobile-menu a:hover { background: var(--primary-light); color: var(--primary); }

  @media (max-width: 768px) {
    .nav-links, .nav-cta-wrap { display: none !important; }
    .hamburger { display: flex; }
    .mobile-menu { display: block; }
  }

  /* ===== FLOATING CARTOON DECORATIONS ===== */
  .cartoon-deco {
    position: absolute; pointer-events: none; z-index: 0;
  }
  /* Cloud */
  .deco-cloud {
    width: 80px; height: 40px; background: var(--card); border-radius: 40px;
    border: 2.5px solid var(--card-border);
    box-shadow: 2px 2px 0 var(--card-border);
    animation: floatCloud 8s ease-in-out infinite;
  }
  .deco-cloud::before {
    content: ''; position: absolute; width: 36px; height: 36px;
    background: var(--card); border-radius: 50%;
    border: 2.5px solid var(--card-border); border-bottom: none;
    top: -22px; left: 14px;
  }
  .deco-cloud::after {
    content: ''; position: absolute; width: 24px; height: 24px;
    background: var(--card); border-radius: 50%;
    border: 2.5px solid var(--card-border); border-bottom: none;
    top: -14px; left: 42px;
  }
  @keyframes floatCloud {
    0%, 100% { transform: translateY(0) translateX(0); }
    50% { transform: translateY(-12px) translateX(8px); }
  }
  /* Star */
  .deco-star {
    width: 24px; height: 24px;
    background: var(--accent);
    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
    border: none; box-shadow: none;
    animation: twinkleStar 3s ease-in-out infinite;
  }
  @keyframes twinkleStar {
    0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.8; }
    50% { transform: scale(1.3) rotate(15deg); opacity: 1; }
  }
  /* Heart */
  .deco-heart {
    width: 20px; height: 18px;
    background: var(--pink);
    transform: rotate(-45deg);
    border-radius: 0 50% 0 50%;
    animation: floatHeart 4s ease-in-out infinite;
  }
  .deco-heart::before {
    content: ''; position: absolute;
    width: 20px; height: 18px;
    background: var(--pink);
    border-radius: 50% 50% 0 0;
    top: -9px; left: 0;
  }
  @keyframes floatHeart {
    0%, 100% { transform: rotate(-45deg) translateY(0) scale(1); }
    50% { transform: rotate(-45deg) translateY(-10px) scale(1.15); }
  }
  /* Circle bubble */
  .deco-bubble {
    border-radius: 50%;
    border: 2.5px solid var(--card-border);
    background: var(--card);
    box-shadow: 2px 2px 0 var(--card-border);
    animation: floatBubble 6s ease-in-out infinite;
  }
  @keyframes floatBubble {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }

  /* ===== SECTION REVEAL ===== */
  .reveal {
    opacity: 0; transform: translateY(30px) scale(0.97);
    transition: opacity 0.7s var(--bounce), transform 0.7s var(--bounce);
  }
  .reveal.visible { opacity: 1; transform: translateY(0) scale(1); }
  .reveal-delay-1 { transition-delay: 0.08s; }
  .reveal-delay-2 { transition-delay: 0.16s; }
  .reveal-delay-3 { transition-delay: 0.24s; }
  .reveal-delay-4 { transition-delay: 0.32s; }
  .reveal-delay-5 { transition-delay: 0.4s; }

  /* ===== SECTION LABEL ===== */
  .section-label {
    display: inline-block; padding: 0.375rem 1rem;
    border-radius: 999px; font-size: 0.6875rem; font-weight: 800;
    letter-spacing: 0.08em; text-transform: uppercase;
    border: 2px solid; margin-bottom: 0.75rem;
  }
  .label-primary { color: var(--primary); background: var(--primary-light); border-color: var(--primary); }
  .label-secondary { color: var(--secondary); background: var(--secondary-light); border-color: var(--secondary); }
  .label-purple { color: var(--purple); background: var(--purple-light); border-color: var(--purple); }
  .label-pink { color: var(--pink); background: var(--pink-light); border-color: var(--pink); }
  .label-accent { color: #F57F17; background: var(--accent-light); border-color: var(--accent); }

  /* ===== HERO ===== */
  .hero-section {
    position: relative; min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    padding: calc(var(--nav-height) + 2rem) 1.25rem 3rem;
    overflow: hidden;
  }
  .hero-bg-blob {
    position: absolute; border-radius: 50%; pointer-events: none;
    filter: blur(60px); opacity: 0.25;
  }
  .hero-content {
    position: relative; z-index: 2; text-align: center;
    max-width: 720px; margin: 0 auto;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 1rem; border-radius: 999px;
    background: var(--card); border: 2px solid var(--card-border);
    box-shadow: 2px 2px 0 var(--card-border);
    font-size: 0.75rem; font-weight: 700; color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .hero-badge .dot-live {
    width: 8px; height: 8px; border-radius: 50%; background: var(--green);
    border: 2px solid var(--text);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.2); } }

  .hero-title {
    font-size: clamp(2.5rem, 7vw, 4.25rem); font-weight: 700;
    line-height: 1.1; color: var(--text); margin-bottom: 1rem;
  }
  .hero-title-accent {
    color: var(--primary);
    text-shadow: 2px 2px 0 var(--card-border);
    position: relative; display: inline-block;
  }
  .hero-title-accent::after {
    content: ''; position: absolute; bottom: 2px; left: -4px; right: -4px;
    height: 8px; background: var(--accent); border-radius: 4px;
    z-index: -1; opacity: 0.6;
  }
  .hero-sub {
    font-size: clamp(1rem, 2.5vw, 1.1875rem); color: var(--text-muted);
    line-height: 1.7; max-width: 560px; margin: 0 auto 2rem;
  }
  .hero-buttons { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.875rem; }

  /* Buttons */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.8125rem 1.75rem; border-radius: var(--radius-md);
    font-family: 'Fredoka', sans-serif; font-weight: 600; font-size: 0.9375rem;
    cursor: pointer; border: 2.5px solid var(--text);
    transition: all 0.25s var(--bounce);
    text-decoration: none;
  }
  .btn:active { transform: translate(1px, 1px); }
  .btn-primary {
    background: var(--primary); color: #fff;
    box-shadow: 3px 3px 0 var(--text);
  }
  .btn-primary:hover {
    background: var(--primary-hover);
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--text);
  }
  .btn-secondary {
    background: var(--card); color: var(--text);
    box-shadow: 3px 3px 0 var(--card-border);
  }
  .btn-secondary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--card-border);
    border-color: var(--text);
  }

  .hero-hint {
    margin-top: 1.25rem; font-size: 0.75rem; color: var(--text-light);
    font-weight: 600;
  }
  .hero-hint kbd {
    display: inline-block; padding: 0.125rem 0.5rem;
    background: var(--card); border: 2px solid var(--card-border);
    border-radius: 0.375rem; font-family: 'Nunito', sans-serif;
    font-size: 0.6875rem; box-shadow: 1px 1px 0 var(--card-border);
    color: var(--text-muted);
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.375rem;
    animation: scrollBounce 2s ease-in-out infinite;
  }
  .scroll-indicator span { font-size: 0.625rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--text-light); }
  .scroll-indicator svg { color: var(--text-light); }
  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ===== PREVIEW WINDOW (cartoon style) ===== */
  .preview-float {
    position: absolute; border-radius: var(--radius-md); overflow: hidden;
    border: 3px solid var(--card-border);
    box-shadow: 4px 4px 0 var(--card-border);
    transition: transform 0.5s var(--bounce);
  }
  .preview-float:hover { transform: rotate(0deg) scale(1.05) !important; }
  .preview-float .pw-bar {
    height: 24px; background: var(--bg-alt); border-bottom: 2px solid var(--card-border);
    display: flex; align-items: center; padding: 0 8px; gap: 4px;
  }
  .preview-float .pw-dot { width: 7px; height: 7px; border-radius: 50%; border: 1.5px solid var(--text); }
  .preview-float .pw-dot.r { background: #EF5350; }
  .preview-float .pw-dot.y { background: #FFC107; }
  .preview-float .pw-dot.g { background: #66BB6A; }

  /* ===== CAROUSEL ===== */
  .carousel-wrap {
    position: relative; border-radius: var(--radius-xl); overflow: hidden;
    border: 3px solid var(--card-border);
    box-shadow: 4px 4px 0 var(--card-border);
    background: var(--card);
  }
  .carousel-area { overflow: hidden; aspect-ratio: 16/9; background: var(--bg-alt); position: relative; }
  .carousel-track { display: flex; transition: transform 0.6s var(--bounce); height: 100%; }
  .carousel-slide { min-width: 100%; height: 100%; position: relative; }
  .carousel-controls {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 0.875rem; display: flex; align-items: center; justify-content: space-between;
    background: linear-gradient(to top, color-mix(in srgb, var(--bg) 90%, transparent), transparent);
  }
  .carousel-btn {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--card); border: 2.5px solid var(--text);
    box-shadow: 2px 2px 0 var(--text);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    color: var(--text); transition: all 0.2s var(--bounce);
  }
  .carousel-btn:hover { transform: translate(-1px, -1px); box-shadow: 3px 3px 0 var(--text); }
  .carousel-btn:active { transform: translate(1px, 1px); box-shadow: 1px 1px 0 var(--text); }
  .carousel-dots { display: flex; gap: 6px; }
  .carousel-dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--card-border); border: 2px solid var(--text);
    cursor: pointer; transition: all 0.3s var(--bounce);
  }
  .carousel-dot.active { background: var(--primary); transform: scale(1.2); }
  .carousel-dot:hover { transform: scale(1.15); }

  /* ===== FEATURE CARDS ===== */
  .feature-card {
    background: var(--card); border: 2.5px solid var(--card-border);
    border-radius: var(--radius-lg); padding: 1.75rem;
    box-shadow: var(--shadow-card);
    transition: all 0.35s var(--bounce);
    position: relative; overflow: hidden;
    cursor: default;
  }
  .feature-card::after {
    content: ''; position: absolute; top: 0; right: 0;
    width: 60px; height: 60px; border-radius: 0 0 0 60px;
    opacity: 0.15; transition: opacity 0.3s;
  }
  .feature-card:hover {
    border-color: var(--card-border-hover);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-4px);
  }
  .feature-card:hover::after { opacity: 0.25; }
  .feature-card.card-primary::after { background: var(--primary); }
  .feature-card.card-secondary::after { background: var(--secondary); }
  .feature-card.card-purple::after { background: var(--purple); }
  .feature-card.card-accent::after { background: var(--accent); }
  .feature-card.card-pink::after { background: var(--pink); }
  .feature-card.card-sky::after { background: var(--sky); }

  .feature-icon {
    width: 52px; height: 52px; border-radius: var(--radius-md);
    display: flex; align-items: center; justify-content: center;
    border: 2.5px solid; margin-bottom: 1rem;
    box-shadow: 2px 2px 0 currentColor;
  }
  .fi-primary { background: var(--primary-light); border-color: var(--primary); color: var(--primary); }
  .fi-secondary { background: var(--secondary-light); border-color: var(--secondary); color: var(--secondary); }
  .fi-purple { background: var(--purple-light); border-color: var(--purple); color: var(--purple); }
  .fi-accent { background: var(--accent-light); border-color: #F57F17; color: #F57F17; }
  .fi-pink { background: var(--pink-light); border-color: var(--pink); color: var(--pink); }
  .fi-sky { background: var(--sky-light); border-color: var(--sky); color: #0288D1; }

  .feature-card h3 { font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text); }
  .feature-card p { font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; }

  /* ===== STATS ===== */
  .stats-section {
    border-top: 3px solid var(--card-border);
    border-bottom: 3px solid var(--card-border);
    background: var(--bg-alt);
    position: relative; overflow: hidden;
  }
  .stat-card {
    text-align: center; padding: 1.5rem;
    background: var(--card); border: 2.5px solid var(--card-border);
    border-radius: var(--radius-lg);
    box-shadow: 3px 3px 0 var(--card-border);
    transition: transform 0.3s var(--bounce);
  }
  .stat-card:hover { transform: translateY(-4px) rotate(-1deg); }
  .stat-value {
    font-family: 'Fredoka', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem); font-weight: 700;
    color: var(--primary);
  }
  .stat-label { font-size: 0.8125rem; font-weight: 700; color: var(--text-muted); margin-top: 0.25rem; }

  /* ===== COMPARISON ===== */
  .comparison-container {
    position: relative; overflow: hidden; border-radius: var(--radius-xl);
    border: 3px solid var(--card-border);
    box-shadow: 4px 4px 0 var(--card-border);
    cursor: col-resize; user-select: none;
    aspect-ratio: 16/9;
  }
  .comparison-container .comp-layer { position: absolute; inset: 0; }
  .comparison-container .comp-slider-line {
    position: absolute; top: 0; bottom: 0; width: 4px;
    background: var(--primary); z-index: 10;
    box-shadow: 0 0 0 2px var(--text);
  }
  .comparison-container .comp-handle {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--primary); border: 3px solid var(--text);
    box-shadow: 2px 2px 0 var(--text);
    display: flex; align-items: center; justify-content: center; color: #fff;
  }
  .comp-label {
    position: absolute; top: 0.75rem; padding: 0.25rem 0.75rem;
    border-radius: 999px; font-size: 0.625rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.1em;
    border: 2px solid var(--text);
    box-shadow: 1px 1px 0 var(--text);
  }
  .comp-label-before { left: 0.75rem; background: var(--bg-alt); color: var(--text-muted); }
  .comp-label-after { right: 0.75rem; background: var(--primary); color: #fff; }

  /* ===== INSTALL STEPS ===== */
  .step-connector {
    width: 3px; height: 2.5rem; margin: 0.25rem auto;
    background: var(--card-border);
    border-radius: 3px;
    position: relative; overflow: hidden;
  }
  .step-connector::after {
    content: ''; position: absolute; top: 0; left: 0; right: 0;
    height: 0%; background: var(--primary);
    border-radius: 3px; transition: height 0.6s var(--smooth);
  }
  .step-item.completed .step-connector::after { height: 100%; }
  .step-number {
    width: 44px; height: 44px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Fredoka', sans-serif; font-weight: 700; font-size: 1.125rem;
    background: var(--card); border: 3px solid var(--card-border);
    color: var(--text-muted); box-shadow: 2px 2px 0 var(--card-border);
    transition: all 0.4s var(--bounce); flex-shrink: 0;
  }
  .step-item.active .step-number {
    background: var(--primary); border-color: var(--text); color: #fff;
    box-shadow: 2px 2px 0 var(--text);
    transform: scale(1.1);
  }
  .step-item.completed .step-number {
    background: var(--green); border-color: var(--text); color: #fff;
    box-shadow: 2px 2px 0 var(--text);
  }
  .code-block {
    background: var(--bg-alt); border: 2.5px solid var(--card-border);
    border-radius: var(--radius-sm); padding: 0.875rem 1rem;
    font-family: 'Courier New', monospace; font-size: 0.8125rem;
    color: var(--text-muted); display: flex; align-items: center;
    justify-content: space-between; gap: 0.75rem;
    box-shadow: 2px 2px 0 var(--card-border);
    transition: border-color 0.3s;
  }
  .code-block:hover { border-color: var(--primary); }
  .code-block .ck { color: var(--primary); font-weight: 700; }
  .code-block .cf { color: var(--secondary); }
  .code-block .cp { color: #F57F17; }
  .copy-btn {
    padding: 0.375rem 0.75rem; border-radius: var(--radius-sm);
    background: var(--card); border: 2px solid var(--card-border);
    color: var(--text-muted); font-size: 0.6875rem; font-weight: 800;
    font-family: 'Nunito', sans-serif;
    cursor: pointer; transition: all 0.2s var(--bounce);
    box-shadow: 1px 1px 0 var(--card-border); white-space: nowrap;
  }
  .copy-btn:hover { border-color: var(--primary); color: var(--primary); transform: translate(-1px, -1px); }
  .copy-btn:active { transform: translate(1px, 1px); }
  .copy-btn.copied { background: var(--green-light); border-color: var(--green); color: #2E7D32; }

  /* ===== FAQ ===== */
  .faq-item {
    border: 2.5px solid var(--card-border); border-radius: var(--radius-lg);
    overflow: hidden; background: var(--card);
    box-shadow: 3px 3px 0 var(--card-border);
    transition: all 0.3s var(--bounce);
  }
  .faq-item.open { border-color: var(--primary); box-shadow: 3px 3px 0 var(--primary); }
  .faq-question {
    padding: 1.125rem 1.25rem; cursor: pointer;
    display: flex; align-items: center; justify-content: space-between;
    font-family: 'Fredoka', sans-serif; font-weight: 600; font-size: 0.9375rem;
    color: var(--text); transition: color 0.3s; gap: 1rem;
  }
  .faq-item.open .faq-question { color: var(--primary); }
  .faq-chevron {
    transition: transform 0.4s var(--bounce); color: var(--text-light);
    flex-shrink: 0;
  }
  .faq-item.open .faq-chevron { transform: rotate(180deg); color: var(--primary); }
  .faq-answer {
    max-height: 0; overflow: hidden;
    transition: max-height 0.5s var(--smooth), padding 0.3s;
    padding: 0 1.25rem;
  }
  .faq-item.open .faq-answer { max-height: 300px; padding: 0 1.25rem 1.125rem; }
  .faq-answer p { font-size: 0.875rem; color: var(--text-muted); line-height: 1.7; }
  .faq-answer code {
    background: var(--primary-light); color: var(--primary);
    padding: 0.125rem 0.5rem; border-radius: 0.25rem; font-size: 0.8125rem;
    font-weight: 700; border: 1.5px solid var(--primary);
  }
  .faq-answer strong { color: var(--text); }

  /* ===== CTA SECTION ===== */
  .cta-section {
    position: relative; overflow: hidden;
    padding: 5rem 1.25rem;
    background: var(--bg-alt);
    border-top: 3px solid var(--card-border);
  }
  .cta-section .cta-inner { position: relative; z-index: 2; text-align: center; max-width: 600px; margin: 0 auto; }
  .cta-section h2 {
    font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; line-height: 1.15;
    color: var(--text); margin-bottom: 1rem;
  }
  .cta-section p { font-size: 1.0625rem; color: var(--text-muted); line-height: 1.7; margin-bottom: 2rem; }

  /* ===== FOOTER ===== */
  .site-footer {
    border-top: 3px solid var(--card-border);
    padding: 2rem 1.25rem;
    background: var(--bg);
  }
  .footer-inner {
    max-width: 1100px; margin: 0 auto;
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
    gap: 1rem;
  }
  .footer-logo { display: flex; align-items: center; gap: 0.5rem; }
  .footer-logo-icon {
    width: 28px; height: 28px; border-radius: 0.5rem;
    background: var(--primary); border: 2px solid var(--text);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 1px 1px 0 var(--text);
  }
  .footer-logo span { font-family: 'Fredoka', sans-serif; font-weight: 600; font-size: 0.8125rem; color: var(--text-muted); }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a { font-size: 0.8125rem; font-weight: 700; color: var(--text-light); transition: color 0.2s; }
  .footer-links a:hover { color: var(--primary); }

  /* ===== BACK TO TOP ===== */
  #backToTop {
    position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9998;
    width: 48px; height: 48px; border-radius: 50%;
    background: var(--primary); border: 3px solid var(--text);
    box-shadow: 3px 3px 0 var(--text);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    color: #fff; transition: all 0.3s var(--bounce);
    opacity: 0; transform: translateY(20px) scale(0.8);
    pointer-events: none;
  }
  #backToTop.visible { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
  #backToTop:hover { transform: translateY(-3px) scale(1.1); box-shadow: 4px 4px 0 var(--text); }
  #backToTop:active { transform: translateY(1px) scale(0.95); box-shadow: 1px 1px 0 var(--text); }

  /* ===== TOAST ===== */
  .toast-container {
    position: fixed; bottom: 5rem; right: 1.5rem; z-index: 99999;
    display: flex; flex-direction: column; gap: 0.5rem; pointer-events: none;
  }
  .toast {
    pointer-events: auto; padding: 0.75rem 1.25rem;
    border-radius: var(--radius-sm); font-size: 0.8125rem; font-weight: 700;
    color: #fff; border: 2.5px solid var(--text);
    box-shadow: 3px 3px 0 var(--text);
    animation: toastIn 0.4s var(--bounce), toastOut 0.3s ease 2.2s forwards;
  }
  .toast.success { background: var(--green); color: #1B5E20; border-color: #1B5E20; box-shadow: 3px 3px 0 #1B5E20; }
  .toast.info { background: var(--sky); color: #01579B; border-color: #01579B; box-shadow: 3px 3px 0 #01579B; }
  .toast.warn { background: var(--accent); color: #E65100; border-color: #E65100; box-shadow: 3px 3px 0 #E65100; }
  @keyframes toastIn { from { opacity:0; transform: translateY(1rem) scale(0.9); } to { opacity:1; transform: translateY(0) scale(1); } }
  @keyframes toastOut { to { opacity:0; transform: translateY(-0.5rem) scale(0.9); } }

  /* ===== SPARKLE CURSOR ===== */
  .sparkle {
    position: fixed; pointer-events: none; z-index: 99997;
    width: 8px; height: 8px;
    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
    animation: sparkleFade 0.6s ease-out forwards;
  }
  @keyframes sparkleFade {
    0% { opacity: 1; transform: scale(1) rotate(0deg); }
    100% { opacity: 0; transform: scale(0) rotate(90deg); }
  }

  /* ===== CONFETTI ===== */
  .confetti-piece {
    position: fixed; pointer-events: none; z-index: 99998;
    width: 8px; height: 8px; border-radius: 2px;
    animation: confettiFall 1.2s ease-out forwards;
  }
  @keyframes confettiFall {
    0% { opacity: 1; transform: translateY(0) rotate(0deg) scale(1); }
    100% { opacity: 0; transform: translateY(200px) rotate(720deg) scale(0.3); }
  }

  /* ===== MASCOT BLOB ===== */
  #mascot {
    position: fixed; bottom: 1.5rem; left: 1.5rem; z-index: 9990;
    width: 56px; height: 56px; border-radius: 50% 50% 50% 45%;
    background: var(--primary); border: 3px solid var(--text);
    box-shadow: 3px 3px 0 var(--text);
    transition: transform 0.4s var(--bounce);
    cursor: pointer; overflow: hidden;
  }
  #mascot:hover { transform: scale(1.15) rotate(-5deg); }
  #mascot .eye {
    position: absolute; width: 8px; height: 10px;
    background: var(--text); border-radius: 50%;
    top: 18px;
  }
  #mascot .eye.left { left: 14px; }
  #mascot .eye.right { right: 14px; }
  #mascot .eye::after {
    content: ''; position: absolute; width: 3px; height: 3px;
    background: #fff; border-radius: 50%; top: 1px; right: 1px;
  }
  #mascot .mouth {
    position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%);
    width: 12px; height: 6px; border-bottom: 3px solid var(--text);
    border-radius: 0 0 50% 50%;
  }
  #mascot.bounce { animation: mascotBounce 0.5s var(--bounce); }
  @keyframes mascotBounce {
    0% { transform: scale(1); }
    30% { transform: scale(1.3) rotate(10deg); }
    60% { transform: scale(0.9) rotate(-5deg); }
    100% { transform: scale(1) rotate(0deg); }
  }
  #mascot .blush {
    position: absolute; width: 10px; height: 6px;
    background: var(--pink); border-radius: 50%;
    top: 30px; opacity: 0.5;
  }
  #mascot .blush.left { left: 5px; }
  #mascot .blush.right { right: 5px; }

  /* Tooltip for mascot */
  #mascotTip {
    position: fixed; bottom: 4.5rem; left: 1.5rem; z-index: 9990;
    background: var(--card); border: 2.5px solid var(--card-border);
    border-radius: var(--radius-sm); padding: 0.5rem 0.875rem;
    font-size: 0.75rem; font-weight: 700; color: var(--text-muted);
    box-shadow: 2px 2px 0 var(--card-border);
    opacity: 0; transform: translateY(8px);
    transition: all 0.3s var(--bounce); pointer-events: none;
    white-space: nowrap;
  }
  #mascotTip.show { opacity: 1; transform: translateY(0); }
  #mascotTip::after {
    content: ''; position: absolute; bottom: -6px; left: 1.25rem;
    width: 10px; height: 10px; background: var(--card);
    border-right: 2.5px solid var(--card-border);
    border-bottom: 2.5px solid var(--card-border);
    transform: rotate(45deg);
  }

  @media (max-width: 768px) {
    #mascot { display: none; }
    #mascotTip { display: none; }
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 640px) {
    .preview-float { display: none !important; }
    .hero-buttons { flex-direction: column; align-items: center; }
    .btn { width: 100%; max-width: 280px; justify-content: center; }
    .carousel-controls { padding: 0.5rem; }
  }

  /* ===== REDUCED MOTION ===== */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* ===== SCROLLBAR ===== */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--card-border); border-radius: 4px; border: 2px solid var(--bg); }
  ::-webkit-scrollbar-thumb:hover { background: var(--primary); }
</style>

