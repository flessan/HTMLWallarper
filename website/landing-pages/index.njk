<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">

<style>
  /* ===== THEME VARIABLES ===== */
  :root {
    --bg-body: #FFF5EE;
    --bg-card: #FFFFFF;
    --bg-card-hover: #FFFAF7;
    --bg-nav: rgba(255,245,238,0.85);
    --bg-input: #FFF0E8;
    --bg-badge: #FFF0F5;
    --text-primary: #4A3456;
    --text-secondary: #7B6888;
    --text-muted: #B0A0BC;
    --border: #F0E0D8;
    --border-strong: #E8D0C4;
    --accent-pink: #FF7EB3;
    --accent-pink-soft: #FFD6E8;
    --accent-mint: #6EC6B8;
    --accent-mint-soft: #D0F0EA;
    --accent-yellow: #FFB830;
    --accent-yellow-soft: #FFF0D0;
    --accent-lavender: #A78BDB;
    --accent-lavender-soft: #E8DFF8;
    --accent-peach: #FFAB91;
    --accent-peach-soft: #FFE0D4;
    --shadow-sm: 0 2px 8px rgba(74,52,86,0.06);
    --shadow-md: 0 4px 20px rgba(74,52,86,0.08);
    --shadow-lg: 0 8px 40px rgba(74,52,86,0.10);
    --shadow-pink: 0 6px 24px rgba(255,126,179,0.18);
    --shadow-mint: 0 6px 24px rgba(110,198,184,0.18);
    --radius: 1.25rem;
    --radius-lg: 1.75rem;
    --radius-pill: 9999px;
    --radius-sm: 0.75rem;
    --spring: cubic-bezier(0.34, 1.56, 0.64, 1);
    --smooth: cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-theme="dark"] {
    --bg-body: #2A2640;
    --bg-card: #353150;
    --bg-card-hover: #3D3960;
    --bg-nav: rgba(42,38,64,0.88);
    --bg-input: #3D3960;
    --bg-badge: #3D2848;
    --text-primary: #F2ECFF;
    --text-secondary: #C0B4D4;
    --text-muted: #7E72A0;
    --border: #4A4468;
    --border-strong: #5A5478;
    --accent-pink: #FF8FAB;
    --accent-pink-soft: #3D2035;
    --accent-mint: #80D8CC;
    --accent-mint-soft: #203835;
    --accent-yellow: #FFCC55;
    --accent-yellow-soft: #383018;
    --accent-lavender: #BBA0E8;
    --accent-lavender-soft: #2E2848;
    --accent-peach: #FFBFA8;
    --accent-peach-soft: #3D2820;
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.15);
    --shadow-md: 0 4px 20px rgba(0,0,0,0.2);
    --shadow-lg: 0 8px 40px rgba(0,0,0,0.25);
    --shadow-pink: 0 6px 24px rgba(255,143,171,0.12);
    --shadow-mint: 0 6px 24px rgba(128,216,204,0.12);
  }

  /* ===== BASE ===== */
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Nunito', sans-serif;
    background: var(--bg-body);
    color: var(--text-primary);
    overflow-x: hidden;
    transition: background 0.4s, color 0.4s;
  }
  a { text-decoration: none; color: inherit; }
  button { font-family: inherit; cursor: pointer; border: none; background: none; }
  ::selection { background: var(--accent-pink-soft); color: var(--accent-pink); }

  /* ===== SCROLLBAR ===== */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: var(--bg-body); }
  ::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

  /* ===== SCROLL PROGRESS ===== */
  #scrollProgress {
    position: fixed; top: 0; left: 0; height: 4px; z-index: 10001;
    background: linear-gradient(90deg, var(--accent-pink), var(--accent-yellow), var(--accent-mint), var(--accent-lavender));
    background-size: 300% 100%;
    animation: progressRainbow 4s linear infinite;
    width: 0%; transition: width 0.08s linear;
    border-radius: 0 2px 2px 0;
  }
  @keyframes progressRainbow { 0%{background-position:0% 0} 100%{background-position:300% 0} }

  /* ===== CUTE FLOATING DECORATIONS ===== */
  .cute-deco {
    position: absolute; pointer-events: none; z-index: 0;
  }
  .cute-star {
    width: 18px; height: 18px;
    animation: floatStar 6s ease-in-out infinite;
  }
  .cute-star svg { width: 100%; height: 100%; }
  .cute-heart {
    width: 14px; height: 14px;
    animation: floatHeart 5s ease-in-out infinite;
  }
  .cute-heart svg { width: 100%; height: 100%; }
  .cute-cloud {
    width: 60px; height: 30px; opacity: 0.3;
    animation: driftCloud 20s linear infinite;
  }
  .cute-cloud svg { width: 100%; height: 100%; }
  .cute-sparkle {
    width: 8px; height: 8px; border-radius: 50%;
    animation: twinkle 2s ease-in-out infinite;
  }
  @keyframes floatStar {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(20deg); }
  }
  @keyframes floatHeart {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-20px) scale(1.15); }
  }
  @keyframes driftCloud {
    0% { transform: translateX(-100px); }
    100% { transform: translateX(calc(100vw + 100px)); }
  }
  @keyframes twinkle {
    0%, 100% { opacity: 0.3; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  /* ===== MOBILE MENU ===== */
  #mobileMenu {
    position: fixed; inset: 0; z-index: 10002;
    background: var(--bg-body);
    transform: translateX(100%);
    transition: transform 0.45s var(--spring);
    display: flex; flex-direction: column;
  }
  #mobileMenu.open { transform: translateX(0); }
  #mobileMenu .menu-header {
    padding: 1.25rem 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 2px solid var(--border);
  }
  #mobileMenu .menu-links {
    flex: 1; display: flex; flex-direction: column;
    padding: 2rem 1.5rem; gap: 0.5rem;
  }
  #mobileMenu .menu-links a {
    font-size: 1.25rem; font-weight: 700; padding: 0.875rem 1rem;
    border-radius: var(--radius-sm);
    transition: background 0.2s, color 0.2s;
    color: var(--text-primary);
  }
  #mobileMenu .menu-links a:hover {
    background: var(--accent-pink-soft);
    color: var(--accent-pink);
  }
  #menuOverlay {
    position: fixed; inset: 0; z-index: 10001;
    background: rgba(74,52,86,0.3); backdrop-filter: blur(4px);
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s;
  }
  #menuOverlay.visible { opacity: 1; pointer-events: auto; }

  /* ===== STICKY NAV ===== */
  #stickyNav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 10000;
    padding: 0.625rem 1.25rem;
    background: var(--bg-nav);
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    border-bottom: 2px solid var(--border);
    transform: translateY(-100%);
    transition: transform 0.4s var(--spring), background 0.3s, border-color 0.3s;
  }
  #stickyNav.visible { transform: translateY(0); }
  .nav-inner {
    max-width: 72rem; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-logo {
    display: flex; align-items: center; gap: 0.625rem;
  }
  .nav-logo-icon {
    width: 2.25rem; height: 2.25rem; border-radius: 0.75rem;
    background: var(--accent-pink);
    display: flex; align-items: center; justify-content: center;
    box-shadow: var(--shadow-pink);
    transition: transform 0.3s var(--spring);
  }
  .nav-logo:hover .nav-logo-icon { transform: rotate(-8deg) scale(1.08); }
  .nav-logo-icon svg { width: 1.125rem; height: 1.125rem; color: #fff; }
  .nav-logo-text { font-weight: 900; font-size: 1rem; color: var(--text-primary); }
  .nav-links { display: none; align-items: center; gap: 0.25rem; }
  @media(min-width:640px) { .nav-links { display: flex; } }
  .nav-links a {
    padding: 0.5rem 0.875rem; border-radius: var(--radius-pill);
    font-size: 0.8125rem; font-weight: 700; color: var(--text-secondary);
    transition: all 0.25s;
  }
  .nav-links a:hover { background: var(--accent-pink-soft); color: var(--accent-pink); }
  .nav-actions { display: flex; align-items: center; gap: 0.5rem; }
  .nav-btn {
    width: 2.25rem; height: 2.25rem; border-radius: 0.75rem;
    display: flex; align-items: center; justify-content: center;
    color: var(--text-secondary); transition: all 0.25s;
    border: 2px solid transparent;
  }
  .nav-btn:hover { background: var(--accent-lavender-soft); color: var(--accent-lavender); border-color: var(--accent-lavender-soft); }
  .nav-btn svg { width: 1.125rem; height: 1.125rem; }
  .nav-cta {
    padding: 0.5rem 1rem; border-radius: var(--radius-pill);
    background: var(--accent-pink); color: #fff;
    font-size: 0.8125rem; font-weight: 800;
    box-shadow: var(--shadow-pink);
    transition: all 0.3s var(--spring);
    display: none;
  }
  @media(min-width:640px) { .nav-cta { display: inline-flex; align-items: center; gap: 0.375rem; } }
  .nav-cta:hover { transform: translateY(-2px) scale(1.03); box-shadow: 0 8px 28px rgba(255,126,179,0.3); }
  .nav-cta svg { width: 0.875rem; height: 0.875rem; }
  .hamburger { display: flex; }
  @media(min-width:640px) { .hamburger { display: none; } }

  /* ===== HERO ===== */
  .hero {
    position: relative; min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; padding: 6rem 1.25rem 4rem;
  }
  .hero-bg-pattern {
    position: absolute; inset: 0; z-index: 0; opacity: 0.4;
    background-image:
      radial-gradient(circle at 20% 30%, var(--accent-pink-soft) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, var(--accent-mint-soft) 0%, transparent 50%),
      radial-gradient(circle at 50% 50%, var(--accent-yellow-soft) 0%, transparent 60%);
  }
  .hero-content {
    position: relative; z-index: 1;
    text-align: center; max-width: 52rem;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 1rem; border-radius: var(--radius-pill);
    background: var(--bg-card); border: 2px solid var(--border);
    font-size: 0.75rem; font-weight: 700; color: var(--text-secondary);
    box-shadow: var(--shadow-sm);
    margin-bottom: 2rem;
  }
  .hero-badge .pulse-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent-mint); position: relative;
  }
  .hero-badge .pulse-dot::after {
    content: ''; position: absolute; inset: -3px;
    border-radius: 50%; background: var(--accent-mint);
    animation: pulse-ring 2s ease-out infinite; opacity: 0;
  }
  @keyframes pulse-ring { 0%{transform:scale(0.8);opacity:0.6} 100%{transform:scale(2);opacity:0} }

  .hero h1 {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 900; line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }
  .hero h1 .highlight {
    background: linear-gradient(135deg, var(--accent-pink), var(--accent-lavender), var(--accent-mint));
    background-size: 200% 200%;
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientMove 5s ease infinite;
  }
  @keyframes gradientMove { 0%,100%{background-position:0% 50%} 50%{background-position:100% 50%} }

  .hero-sub {
    margin-top: 1.5rem; font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--text-secondary); line-height: 1.7;
    max-width: 40rem; margin-left: auto; margin-right: auto;
  }
  .hero-buttons {
    margin-top: 2.5rem;
    display: flex; flex-wrap: wrap; justify-content: center; gap: 0.875rem;
  }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.875rem 2rem; border-radius: var(--radius-pill);
    background: var(--accent-pink); color: #fff;
    font-weight: 800; font-size: 0.9375rem;
    box-shadow: var(--shadow-pink);
    transition: all 0.3s var(--spring);
    border: 2px solid transparent;
  }
  .btn-primary:hover { transform: translateY(-3px) scale(1.04); box-shadow: 0 10px 32px rgba(255,126,179,0.35); }
  .btn-primary:active { transform: translateY(0) scale(0.97); }
  .btn-primary svg { width: 1.125rem; height: 1.125rem; }

  .btn-secondary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.875rem 2rem; border-radius: var(--radius-pill);
    background: var(--bg-card); color: var(--text-primary);
    font-weight: 800; font-size: 0.9375rem;
    border: 2px solid var(--border);
    box-shadow: var(--shadow-sm);
    transition: all 0.3s var(--spring);
  }
  .btn-secondary:hover { border-color: var(--accent-lavender); color: var(--accent-lavender); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .btn-secondary svg { width: 1.125rem; height: 1.125rem; }

  .hero-hint {
    margin-top: 1.5rem; font-size: 0.6875rem;
    color: var(--text-muted); font-family: 'Nunito', monospace;
  }
  .hero-hint kbd {
    padding: 0.125rem 0.5rem; border-radius: 0.375rem;
    background: var(--bg-card); border: 1.5px solid var(--border);
    font-weight: 700; color: var(--text-secondary);
  }

  .hero-scroll {
    position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
    z-index: 1; display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    animation: gentleBounce 2.5s ease-in-out infinite;
  }
  .hero-scroll span { font-size: 0.625rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--text-muted); }
  .hero-scroll svg { width: 1rem; height: 1rem; color: var(--text-muted); }
  @keyframes gentleBounce { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(-8px)} }

  /* ===== SECTION COMMON ===== */
  .section { padding: 5rem 1.25rem; position: relative; }
  .section-inner { max-width: 72rem; margin: 0 auto; }
  .section-label {
    display: inline-block; font-size: 0.6875rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.15em;
    padding: 0.375rem 0.875rem; border-radius: var(--radius-pill);
    margin-bottom: 0.875rem;
  }
  .label-pink { background: var(--accent-pink-soft); color: var(--accent-pink); }
  .label-mint { background: var(--accent-mint-soft); color: var(--accent-mint); }
  .label-yellow { background: var(--accent-yellow-soft); color: var(--accent-yellow); }
  .label-lavender { background: var(--accent-lavender-soft); color: var(--accent-lavender); }
  .label-peach { background: var(--accent-peach-soft); color: var(--accent-peach); }
  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 900; letter-spacing: -0.02em;
    color: var(--text-primary); line-height: 1.15;
  }
  .section-desc {
    margin-top: 0.75rem; font-size: 1rem;
    color: var(--text-secondary); line-height: 1.7;
    max-width: 36rem;
  }
  .section-header { text-align: center; margin-bottom: 3rem; }
  .section-header .section-desc { margin-left: auto; margin-right: auto; }

  /* ===== REVEAL ===== */
  .reveal {
    opacity: 0; transform: translateY(30px);
    transition: opacity 0.7s var(--smooth), transform 0.7s var(--spring);
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-d1 { transition-delay: 0.08s; }
  .reveal-d2 { transition-delay: 0.16s; }
  .reveal-d3 { transition-delay: 0.24s; }
  .reveal-d4 { transition-delay: 0.32s; }
  .reveal-d5 { transition-delay: 0.4s; }
  .reveal-d6 { transition-delay: 0.48s; }

  /* ===== GALLERY SECTION ===== */
  .gallery-toolbar {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .gallery-search {
    flex: 1; min-width: 200px; position: relative;
  }
  .gallery-search input {
    width: 100%; padding: 0.75rem 1rem 0.75rem 2.75rem;
    border-radius: var(--radius-pill); border: 2px solid var(--border);
    background: var(--bg-input); color: var(--text-primary);
    font-family: inherit; font-size: 0.875rem; font-weight: 600;
    outline: none; transition: all 0.25s;
  }
  .gallery-search input::placeholder { color: var(--text-muted); }
  .gallery-search input:focus { border-color: var(--accent-pink); box-shadow: 0 0 0 4px var(--accent-pink-soft); }
  .gallery-search svg {
    position: absolute; left: 1rem; top: 50%; transform: translateY(-50%);
    width: 1rem; height: 1rem; color: var(--text-muted); pointer-events: none;
  }
  .gallery-filters {
    display: flex; gap: 0.375rem; flex-wrap: wrap;
  }
  .filter-pill {
    padding: 0.5rem 1rem; border-radius: var(--radius-pill);
    font-size: 0.75rem; font-weight: 700;
    border: 2px solid var(--border); background: var(--bg-card);
    color: var(--text-secondary); transition: all 0.25s var(--spring);
    white-space: nowrap;
  }
  .filter-pill:hover { border-color: var(--accent-pink); color: var(--accent-pink); }
  .filter-pill.active { background: var(--accent-pink); border-color: var(--accent-pink); color: #fff; box-shadow: var(--shadow-pink); }
  .gallery-actions { display: flex; gap: 0.375rem; }
  .view-btn {
    width: 2.25rem; height: 2.25rem; border-radius: 0.625rem;
    display: flex; align-items: center; justify-content: center;
    border: 2px solid var(--border); background: var(--bg-card);
    color: var(--text-muted); transition: all 0.2s;
  }
  .view-btn:hover, .view-btn.active { border-color: var(--accent-lavender); color: var(--accent-lavender); background: var(--accent-lavender-soft); }
  .view-btn svg { width: 1rem; height: 1rem; }

  /* ===== WALLPAPER CARDS ===== */
  .gallery-grid {
    display: grid; gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .gallery-grid.view-list { grid-template-columns: 1fr; }
  .gallery-grid.view-list .wp-card { flex-direction: row; }
  .gallery-grid.view-list .wp-card-preview { width: 200px; min-height: 120px; flex-shrink: 0; }
  .gallery-grid.view-list .wp-card-info { flex: 1; }

  .wp-card {
    background: var(--bg-card); border: 2px solid var(--border);
    border-radius: var(--radius-lg); overflow: hidden;
    display: flex; flex-direction: column;
    transition: all 0.35s var(--spring);
    position: relative;
  }
  .wp-card:hover {
    border-color: var(--accent-pink);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg), var(--shadow-pink);
  }
  .wp-card-preview {
    position: relative; width: 100%; aspect-ratio: 16/9;
    background: var(--bg-input); overflow: hidden; cursor: pointer;
  }
  .wp-card-preview iframe {
    position: absolute; width: 1280px; height: 720px;
    origin: center; pointer-events: none;
    transform: scale(calc(min(100%, 280px) / 1280));
  }
  .wp-card-preview .preview-overlay {
    position: absolute; inset: 0; z-index: 2;
    background: rgba(74,52,86,0.0);
    display: flex; align-items: center; justify-content: center;
    transition: background 0.3s;
  }
  .wp-card-preview:hover .preview-overlay { background: rgba(74,52,86,0.25); }
  .preview-overlay .play-circle {
    width: 3rem; height: 3rem; border-radius: 50%;
    background: var(--bg-card); border: 2px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transform: scale(0.7);
    transition: all 0.3s var(--spring);
    box-shadow: var(--shadow-md);
  }
  .wp-card-preview:hover .play-circle { opacity: 1; transform: scale(1); }
  .play-circle svg { width: 1.125rem; height: 1.125rem; color: var(--accent-pink); margin-left: 2px; }

  .wp-card-badges {
    position: absolute; top: 0.625rem; left: 0.625rem; z-index: 3;
    display: flex; gap: 0.375rem;
  }
  .wp-badge {
    padding: 0.25rem 0.625rem; border-radius: var(--radius-pill);
    font-size: 0.625rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .badge-new { background: var(--accent-mint); color: #fff; }
  .badge-popular { background: var(--accent-yellow); color: #4A3456; }
  .badge-staff { background: var(--accent-lavender); color: #fff; }

  .wp-card-info { padding: 1rem 1.125rem; }
  .wp-card-name {
    font-weight: 800; font-size: 0.9375rem;
    color: var(--text-primary); margin-bottom: 0.375rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .wp-card-meta {
    display: flex; align-items: center; gap: 0.875rem;
    font-size: 0.75rem; color: var(--text-muted); font-weight: 600;
  }
  .wp-card-meta span { display: flex; align-items: center; gap: 0.25rem; }
  .wp-card-meta svg { width: 0.875rem; height: 0.875rem; }
  .wp-card-actions {
    display: flex; align-items: center; gap: 0.375rem;
    margin-top: 0.75rem; padding-top: 0.75rem;
    border-top: 2px solid var(--border);
  }
  .wp-action-btn {
    flex: 1; display: flex; align-items: center; justify-content: center; gap: 0.375rem;
    padding: 0.5rem; border-radius: var(--radius-sm);
    font-size: 0.75rem; font-weight: 700;
    transition: all 0.25s var(--spring);
    color: var(--text-secondary);
  }
