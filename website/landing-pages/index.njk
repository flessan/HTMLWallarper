<style>
  /* ===== CSS VARIABLES ===== */
  :root {
    --bg: #FEF6E8;
    --bg-alt: #FFF0DB;
    --bg-dot: #F0D9B5;
    --card: #FFFFFF;
    --card-border: #E8CFA8;
    --card-border-hover: #E8A85C;
    --text: #3D2C1E;
    --text-muted: #8B7355;
    --text-light: #A89279;
    --primary: #FF7043;
    --primary-hover: #FF5722;
    --primary-light: #FFCCBC;
    --secondary: #26A69A;
    --secondary-light: #B2DFDB;
    --accent: #FFD54F;
    --accent-light: #FFF8E1;
    --accent-dark: #F57F17;
    --purple: #CE93D8;
    --purple-light: #F3E5F5;
    --pink: #F48FB1;
    --pink-light: #FCE4EC;
    --sky: #81D4FA;
    --sky-light: #E1F5FE;
    --sky-dark: #0288D1;
    --green: #81C784;
    --green-light: #E8F5E9;
    --green-dark: #2E7D32;
    --shadow-sm: 0 2px 8px rgba(61,44,30,0.06);
    --shadow-card: 0 4px 0 0 var(--card-border), 0 6px 20px rgba(61,44,30,0.07);
    --shadow-card-hover: 0 4px 0 0 var(--card-border-hover), 0 10px 30px rgba(255,112,67,0.12);
    --radius-sm: 0.75rem;
    --radius-md: 1rem;
    --radius-lg: 1.25rem;
    --radius-xl: 1.75rem;
    --bounce: cubic-bezier(0.68, -0.4, 0.265, 1.4);
    --smooth: cubic-bezier(0.4, 0, 0.2, 1);
    --nav-h: 64px;
  }

  [data-theme="dark"] {
    --bg: #1A192B;
    --bg-alt: #22213A;
    --bg-dot: #2D2C4A;
    --card: #272643;
    --card-border: #3A3960;
    --card-border-hover: #FF8A65;
    --text: #F0E6D6;
    --text-muted: #9E93A8;
    --text-light: #6E6585;
    --primary: #FF8A65;
    --primary-hover: #FFAB91;
    --primary-light: rgba(255,138,101,0.14);
    --secondary: #4DB6AC;
    --secondary-light: rgba(77,182,172,0.14);
    --accent: #FFE082;
    --accent-light: rgba(255,224,130,0.1);
    --accent-dark: #FFB300;
    --purple: #CE93D8;
    --purple-light: rgba(206,147,216,0.12);
    --pink: #F48FB1;
    --pink-light: rgba(244,143,177,0.12);
    --sky: #81D4FA;
    --sky-light: rgba(129,212,250,0.12);
    --sky-dark: #4FC3F7;
    --green: #81C784;
    --green-light: rgba(129,199,132,0.12);
    --green-dark: #66BB6A;
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.18);
    --shadow-card: 0 4px 0 0 var(--card-border), 0 6px 20px rgba(0,0,0,0.2);
    --shadow-card-hover: 0 4px 0 0 var(--card-border-hover), 0 10px 30px rgba(255,138,101,0.1);
  }

  /* ===== BASE ===== */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--bg);
    color: var(--text);
    overflow-x: hidden;
    transition: background 0.5s var(--smooth), color 0.5s var(--smooth);
    line-height: 1.6;
  }

  /* Dot pattern */
  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background-image: radial-gradient(var(--bg-dot) 1px, transparent 1px);
    background-size: 22px 22px;
    opacity: 0.45;
    transition: opacity 0.5s;
  }

  h1, h2, h3, h4 { font-family: 'Fredoka', sans-serif; line-height: 1.2; }
  a { text-decoration: none; color: inherit; }
  img { max-width: 100%; display: block; }
  code, .code-block code { font-family: 'Courier New', Courier, monospace; }

  /* Focus visible */
  :focus-visible {
    outline: 3px solid var(--primary);
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* ===== SCROLL PROGRESS ===== */
  #scrollProgress {
    position: fixed; top: 0; left: 0; height: 4px; z-index: 10001;
    background: linear-gradient(90deg, var(--primary), var(--accent), var(--secondary), var(--primary));
    background-size: 300% 100%;
    animation: progressSlide 4s linear infinite;
    width: 0%;
    border-radius: 0 4px 4px 0;
    transition: width 0.06s linear;
  }
  @keyframes progressSlide { to { background-position: 300% 0; } }

  /* ===== NAVIGATION ===== */
  #mainNav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 10000;
    height: var(--nav-h);
    background: var(--bg);
    border-bottom: 2.5px solid var(--card-border);
    transition: background 0.4s var(--smooth), border-color 0.4s, box-shadow 0.3s;
  }
  #mainNav.scrolled {
    background: var(--bg);
    box-shadow: var(--shadow-sm);
  }
  .nav-inner {
    max-width: 1080px; margin: 0 auto; height: 100%;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 1.25rem;
  }
  .nav-logo {
    display: flex; align-items: center; gap: 0.6rem;
    font-family: 'Fredoka', sans-serif; font-weight: 700; font-size: 1.05rem;
    color: var(--text); transition: color 0.4s;
  }
  .nav-logo-icon {
    width: 34px; height: 34px; border-radius: var(--radius-sm);
    background: var(--primary); border: 2.5px solid var(--text);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 2px 2px 0 var(--text);
    transition: transform 0.3s var(--bounce), box-shadow 0.3s, background 0.4s;
  }
  .nav-logo:hover .nav-logo-icon { transform: rotate(-8deg) scale(1.08); }

  .nav-links { display: flex; align-items: center; gap: 0.2rem; }
  .nav-links a {
    padding: 0.45rem 0.75rem; border-radius: var(--radius-sm);
    font-size: 0.8rem; font-weight: 700; color: var(--text-muted);
    transition: all 0.2s var(--smooth); border: 2px solid transparent;
  }
  .nav-links a:hover { color: var(--primary); background: var(--primary-light); }

  .nav-cta {
    padding: 0.45rem 1rem !important;
    background: var(--primary) !important; color: #fff !important;
    border: 2.5px solid var(--text) !important;
    border-radius: var(--radius-sm) !important;
    box-shadow: 2px 2px 0 var(--text);
    transition: all 0.25s var(--bounce) !important;
  }
  .nav-cta:hover {
    background: var(--primary-hover) !important;
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 var(--text) !important;
  }
  .nav-cta:active { transform: translate(1px, 1px); box-shadow: 1px 1px 0 var(--text) !important; }

  /* Theme toggle */
  .theme-toggle {
    width: 38px; height: 38px; border-radius: 50%;
    background: var(--accent-light); border: 2.5px solid var(--card-border);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all 0.3s var(--bounce); position: relative; overflow: hidden;
    flex-shrink: 0;
  }
  .theme-toggle:hover { transform: scale(1.12) rotate(15deg); border-color: var(--accent-dark); }
  .theme-toggle .sun, .theme-toggle .moon {
    position: absolute; transition: all 0.45s var(--bounce);
  }
  .theme-toggle .sun { opacity: 1; transform: scale(1) rotate(0deg); }
  .theme-toggle .moon { opacity: 0; transform: scale(0.4) rotate(-90deg); }
  [data-theme="dark"] .theme-toggle .sun { opacity: 0; transform: scale(0.4) rotate(90deg); }
  [data-theme="dark"] .theme-toggle .moon { opacity: 1; transform: scale(1) rotate(0deg); }

  /* Hamburger */
  .hamburger {
    display: none; width: 38px; height: 38px; border-radius: var(--radius-sm);
    background: var(--primary-light); border: 2.5px solid var(--card-border);
    cursor: pointer; flex-direction: column; align-items: center; justify-content: center; gap: 4px;
    flex-shrink: 0;
  }
  .hamburger span {
    display: block; width: 17px; height: 2.5px; background: var(--text);
    border-radius: 2px; transition: all 0.3s var(--bounce); transform-origin: center;
  }
  .hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(4.5px, 4.5px); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(4.5px, -4.5px); }

  /* Mobile menu */
  .mobile-menu {
    display: none; position: fixed; top: var(--nav-h); left: 0; right: 0;
    background: var(--bg); border-bottom: 3px solid var(--card-border);
    padding: 0.75rem; z-index: 9999;
    transform: translateY(-8px); opacity: 0; pointer-events: none;
    transition: all 0.35s var(--bounce);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .mobile-menu.open { transform: translateY(0); opacity: 1; pointer-events: auto; }
  .mobile-menu a {
    display: block; padding: 0.7rem 1rem; border-radius: var(--radius-sm);
    font-weight: 700; font-size: 0.9rem; color: var(--text-muted);
    transition: all 0.2s;
  }
  .mobile-menu a:hover { background: var(--primary-light); color: var(--primary); }

  @media (max-width: 768px) {
    .nav-links { display: none !important; }
    .hamburger { display: flex; }
    .mobile-menu { display: block; }
  }

  /* ===== CARTOON DECORATIONS ===== */
  .cartoon-deco { position: absolute; pointer-events: none; z-index: 0; }

  .deco-cloud {
    width: 72px; height: 36px; background: var(--card);
    border-radius: 36px; border: 2.5px solid var(--card-border);
    box-shadow: 2px 2px 0 var(--card-border);
    animation: floatCloud 8s ease-in-out infinite;
    transition: background 0.4s, border-color 0.4s;
  }
  .deco-cloud::before {
    content: ''; position: absolute; width: 32px; height: 32px;
    background: var(--card); border-radius: 50%;
    border: 2.5px solid var(--card-border); border-bottom-color: transparent;
    top: -18px; left: 12px;
  }
  .deco-cloud::after {
    content: ''; position: absolute; width: 22px; height: 22px;
    background: var(--card); border-radius: 50%;
    border: 2.5px solid var(--card-border); border-bottom-color: transparent;
    top: -10px; left: 38px;
  }
  @keyframes floatCloud {
    0%, 100% { transform: translateY(0) translateX(0); }
    50% { transform: translateY(-10px) translateX(6px); }
  }

  .deco-star {
    width: 20px; height: 20px; background: var(--accent);
    clip-path: polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%);
    animation: twinkle 3s ease-in-out infinite;
  }
  @keyframes twinkle {
    0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.75; }
    50% { transform: scale(1.25) rotate(12deg); opacity: 1; }
  }

  .deco-heart {
    width: 18px; height: 16px; background: var(--pink);
    transform: rotate(-45deg); border-radius: 0 50% 0 50%;
    animation: floatHeart 4s ease-in-out infinite;
  }
  .deco-heart::before {
    content: ''; position: absolute; width: 18px; height: 16px;
    background: var(--pink); border-radius: 50% 50% 0 0; top: -8px; left: 0;
  }
  @keyframes floatHeart {
    0%, 100% { transform: rotate(-45deg) translateY(0) scale(1); }
    50% { transform: rotate(-45deg) translateY(-8px) scale(1.12); }
  }

  .deco-bubble {
    border-radius: 50%; border: 2.5px solid var(--card-border);
    background: var(--card); box-shadow: 2px 2px 0 var(--card-border);
    animation: floatBubble 6s ease-in-out infinite;
    transition: background 0.4s, border-color 0.4s;
  }
  @keyframes floatBubble {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  /* ===== REVEAL ===== */
  .reveal {
    opacity: 0; transform: translateY(28px) scale(0.97);
    transition: opacity 0.65s var(--bounce), transform 0.65s var(--bounce);
  }
  .reveal.visible { opacity: 1; transform: translateY(0) scale(1); }
  .reveal-delay-1 { transition-delay: 0.07s; }
  .reveal-delay-2 { transition-delay: 0.14s; }
  .reveal-delay-3 { transition-delay: 0.21s; }
  .reveal-delay-4 { transition-delay: 0.28s; }
  .reveal-delay-5 { transition-delay: 0.35s; }

  /* ===== SECTION LABEL ===== */
  .section-label {
    display: inline-block; padding: 0.3rem 0.875rem;
    border-radius: 999px; font-size: 0.65rem; font-weight: 800;
    letter-spacing: 0.08em; text-transform: uppercase;
    border: 2px solid; margin-bottom: 0.625rem;
    transition: background 0.4s, color 0.4s, border-color 0.4s;
  }
  .label-primary { color: var(--primary); background: var(--primary-light); border-color: var(--primary); }
  .label-secondary { color: var(--secondary); background: var(--secondary-light); border-color: var(--secondary); }
  .label-purple { color: var(--purple); background: var(--purple-light); border-color: var(--purple); }
  .label-pink { color: var(--pink); background: var(--pink-light); border-color: var(--pink); }
  .label-accent { color: var(--accent-dark); background: var(--accent-light); border-color: var(--accent); }

  /* ===== HERO ===== */
  .hero-section {
    position: relative; min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    padding: calc(var(--nav-h) + 2rem) 1.25rem 4rem;
    overflow: hidden;
  }
  .hero-bg-blob {
    position: absolute; border-radius: 50%; pointer-events: none;
    filter: blur(70px); opacity: 0.2; transition: background 0.6s;
  }
  .hero-content {
    position: relative; z-index: 2; text-align: center;
    max-width: 680px; margin: 0 auto;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.45rem 0.9rem; border-radius: 999px;
    background: var(--card); border: 2.5px solid var(--card-border);
    box-shadow: 2px 2px 0 var(--card-border);
    font-size: 0.72rem; font-weight: 700; color: var(--text-muted);
    margin-bottom: 1.5rem; transition: all 0.4s;
  }
  .dot-live {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--green); border: 2px solid var(--text);
    animation: pulse 2s ease-in-out infinite; flex-shrink: 0;
  }
  @keyframes pulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.2); } }

  .hero-title {
    font-size: clamp(2.4rem, 6.5vw, 4rem); font-weight: 700;
    color: var(--text); margin-bottom: 0.875rem;
    transition: color 0.4s;
  }
  .hero-title-accent {
    color: var(--primary); position: relative; display: inline-block;
    transition: color 0.4s;
  }
  .hero-title-accent::after {
    content: ''; position: absolute; bottom: 2px; left: -3px; right: -3px;
    height: 7px; background: var(--accent); border-radius: 4px;
    z-index: -1; opacity: 0.55; transition: background 0.4s;
  }
  .hero-sub {
    font-size: clamp(0.95rem, 2.2vw, 1.125rem); color: var(--text-muted);
    line-height: 1.75; max-width: 520px; margin: 0 auto 2rem;
    transition: color 0.4s;
  }
  .hero-buttons { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; }

  /* Buttons */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1.5rem; border-radius: var(--radius-md);
    font-family: 'Fredoka', sans-serif; font-weight: 600; font-size: 0.9rem;
    cursor: pointer; border: 2.5px solid var(--text);
    transition: all 0.25s var(--bounce);
    text-decoration: none; position: relative; overflow: hidden;
  }
  .btn:active { transform: translate(1px, 1px) !important; }
  .btn-primary {
    background: var(--primary); color: #fff;
    box-shadow: 3px 3px 0 var(--text);
  }
  .btn-primary:hover {
    background: var(--primary-hover);
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--text);
  }
  .btn-secondary {
    background: var(--card); color: var(--text);
    box-shadow: 3px 3px 0 var(--card-border);
    transition: all 0.25s var(--bounce), background 0.4s, color 0.4s, border-color 0.4s;
  }
  .btn-secondary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--card-border-hover);
    border-color: var(--text);
  }

  .hero-hint {
    margin-top: 1.125rem; font-size: 0.72rem; color: var(--text-light);
    font-weight: 600; transition: color 0.4s;
  }
  .hero-hint kbd {
    display: inline-block; padding: 0.1rem 0.45rem;
    background: var(--card); border: 2px solid var(--card-border);
    border-radius: 0.3rem; font-family: 'Nunito', sans-serif;
    font-size: 0.65rem; box-shadow: 1px 1px 0 var(--card-border);
    color: var(--text-muted); transition: all 0.4s;
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
    animation: scrollBounce 2.2s ease-in-out infinite;
  }
  .scroll-indicator span {
    font-size: 0.6rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.15em; color: var(--text-light);
  }
  .scroll-indicator svg { color: var(--text-light); }
  @keyframes scrollBounce {
    0%,100% { transform: translateX(-50%) translateY(0); opacity: 1; }
    50% { transform: translateX(-50%) translateY(8px); opacity: 0.5; }
  }

  /* ===== PREVIEW FLOAT WINDOWS ===== */
  .preview-float {
    position: absolute; border-radius: var(--radius-md); overflow: hidden;
    border: 3px solid var(--card-border);
    box-shadow: 4px 4px 0 var(--card-border);
    transition: transform 0.5s var(--bounce), border-color 0.4s, box-shadow 0.4s;
  }
  .preview-float:hover { transform: rotate(0deg) scale(1.06) !important; }
  .pw-bar {
    height: 22px; background: var(--bg-alt); border-bottom: 2px solid var(--card-border);
    display: flex; align-items: center; padding: 0 7px; gap: 4px;
    transition: background 0.4s, border-color 0.4s;
  }
  .pw-dot { width: 6px; height: 6px; border-radius: 50%; border: 1.5px solid var(--text); flex-shrink: 0; }
  .pw-dot.r { background: #EF5350; }
  .pw-dot.y { background: #FFC107; }
  .pw-dot.g { background: #66BB6A; }
  .pw-body { transition: background 0.4s; }

  /* ===== CAROUSEL ===== */
  .carousel-wrap {
    position: relative; border-radius: var(--radius-xl); overflow: hidden;
    border: 3px solid var(--card-border);
    box-shadow: 4px 4px 0 var(--card-border);
    background: var(--card); transition: all 0.4s;
  }
  .carousel-area {
    overflow: hidden; position: relative;
    aspect-ratio: 16/9; background: var(--bg-alt);
    transition: background 0.4s;
  }
  .carousel-track {
    display: flex; height: 100%;
    transition: transform 0.6s var(--bounce);
  }
  .carousel-slide { min-width: 100%; height: 100%; position: relative; }
  .carousel-slide iframe {
    position: absolute;
    left: 50%; top: 50%;
    width: 1280px; height: 720px;
    margin-left: -640px; margin-top: -360px;
    transform: scale(0.3125);
    transform-origin: center center;
    border: none;
    pointer-events: none;
  }
  .carousel-controls {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 0.75rem; display: flex; align-items: center; justify-content: space-between;
    z-index: 5;
  }
  .carousel-controls::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.25), transparent);
    pointer-events: none; z-index: -1;
  }
  .carousel-btn {
    width: 34px; height: 34px; border-radius: 50%;
    background: var(--card); border: 2.5px solid var(--text);
    box-shadow: 2px 2px 0 var(--text);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    color: var(--text); transition: all 0.2s var(--bounce); flex-shrink: 0;
  }
  .carousel-btn:hover { transform: translate(-1px, -1px); box-shadow: 3px 3px 0 var(--text); }
  .carousel-btn:active { transform: translate(1px, 1px); box-shadow: 1px 1px 0 var(--text); }
  .carousel-dots { display: flex; gap: 5px; }
  .carousel-dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: rgba(255,255,255,0.3); border: 2px solid rgba(255,255,255,0.8);
    cursor: pointer; transition: all 0.3s var(--bounce);
  }
  .carousel-dot.active { background: var(--primary); border-color: #fff; transform: scale(1.25); }
  .carousel-dot:hover { transform: scale(1.15); }

  /* ===== FEATURE CARDS ===== */
  .feature-card {
    background: var(--card); border: 2.5px solid var(--card-border);
    border-radius: var(--radius-lg); padding: 1.625rem;
    box-shadow: var(--shadow-card);
    transition: border-color 0.35s var(--smooth), box-shadow 0.35s var(--smooth), background 0.4s;
    position: relative; overflow: hidden; cursor: default;
    will-change: transform;
  }
  .feature-card::after {
    content: ''; position: absolute; top: -10px; right: -10px;
    width: 60px; height: 60px; border-radius: 50%; opacity: 0.1;
    transition: opacity 0.3s, background 0.4s;
  }
  .feature-card:hover { border-color: var(--card-border-hover); box-shadow: var(--shadow-card-hover); }
  .feature-card:hover::after { opacity: 0.2; }
  .feature-card.card-primary::after { background: var(--primary); }
  .feature-card.card-secondary::after { background: var(--secondary); }
  .feature-card.card-purple::after { background: var(--purple); }
  .feature-card.card-accent::after { background: var(--accent); }
  .feature-card.card-pink::after { background: var(--pink); }
  .feature-card.card-sky::after { background: var(--sky); }

  .feature-icon {
    width: 48px; height: 48px; border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    border: 2.5px solid; margin-bottom: 0.875rem;
    box-shadow: 2px 2px 0 currentColor;
    transition: background 0.4s, border-color 0.4s;
    flex-shrink: 0;
  }
  .fi-primary { background: var(--primary-light); border-color: var(--primary); color: var(--primary); }
  .fi-secondary { background: var(--secondary-light); border-color: var(--secondary); color: var(--secondary); }
  .fi-purple { background: var(--purple-light); border-color: var(--purple); color: var(--purple); }
  .fi-accent { background: var(--accent-light); border-color: var(--accent-dark); color: var(--accent-dark); }
  .fi-pink { background: var(--pink-light); border-color: var(--pink); color: var(--pink); }
  .fi-sky { background: var(--sky-light); border-color: var(--sky-dark); color: var(--sky-dark); }

  .feature-card h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--text); transition: color 0.4s; }
  .feature-card p { font-size: 0.85rem; color: var(--text-muted); line-height: 1.65; transition: color 0.4s; }

  /* ===== STATS ===== */
  .stats-section {
    border-top: 3px solid var(--card-border);
    border-bottom: 3px solid var(--card-border);
    background: var(--bg-alt); position: relative; overflow: hidden;
    transition: background 0.4s, border-color 0.4s;
  }
  .stat-card {
    text-align: center; padding: 1.25rem 0.75rem;
    background: var(--card); border: 2.5px solid var(--card-border);
    border-radius: var(--radius-lg);
    box-shadow: 3px 3px 0 var(--card-border);
    transition: transform 0.3s var(--bounce), background 0.4s, border-color 0.4s;
  }
  .stat-card:hover { transform: translateY(-3px) rotate(-1deg); }
  .stat-value {
    font-family: 'Fredoka', sans-serif;
    font-size: clamp(1.75rem, 4.5vw, 2.75rem); font-weight: 700;
    color: var(--primary); transition: color 0.4s;
    font-variant-numeric: tabular-nums;
  }
  .stat-label { font-size: 0.78rem; font-weight: 700; color: var(--text-muted); margin-top: 0.2rem; transition: color 0.4s; }

  /* ===== COMPARISON ===== */
  .comparison-container {
    position: relative; overflow: hidden; border-radius: var(--radius-xl);
    border: 3px solid var(--card-border);
    box-shadow: 4px 4px 0 var(--card-border);
    cursor: col-resize; user-select: none;
    aspect-ratio: 16/9; transition: border-color 0.4s;
  }
  .comp-layer { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
  .comp-slider-line {
    position: absolute; top: 0; bottom: 0; width: 4px;
    background: var(--primary); z-index: 10;
    box-shadow: 0 0 0 2px var(--text);
    transition: background 0.4s;
  }
  .comp-handle {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 38px; height: 38px; border-radius: 50%;
    background: var(--primary); border: 3px solid var(--text);
    box-shadow: 2px 2px 0 var(--text);
    display: flex; align-items: center; justify-content: center; color: #fff;
    transition: background 0.4s;
  }
  .comp-label {
    position: absolute; top: 0.625rem; padding: 0.2rem 0.625rem;
    border-radius: 999px; font-size: 0.6rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.08em;
    border: 2px solid var(--text); box-shadow: 1px 1px 0 var(--text);
    z-index: 5; transition: background 0.4s;
  }
  .comp-label-before { left: 0.625rem; background: var(--bg-alt); color: var(--text-muted); }
  .comp-label-after { right: 0.625rem; background: var(--primary); color: #fff; }

  /* ===== INSTALL ===== */
  .step-connector {
    width: 3px; height: 2rem; margin: 0.2rem auto;
    background: var(--card-border); border-radius: 3px;
    position: relative; overflow: hidden;
    transition: background 0.4s;
  }
  .step-connector-fill {
    position: absolute; inset: 0; background: var(--primary);
    border-radius: 3px; transform: scaleY(0); transform-origin: top;
    transition: transform 0.6s var(--smooth);
  }
  .step-item.completed .step-connector-fill { transform: scaleY(1); }

  .step-number {
    width: 42px; height: 42px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Fredoka', sans-serif; font-weight: 700; font-size: 1.05rem;
    background: var(--card); border: 3px solid var(--card-border);
    color: var(--text-muted); box-shadow: 2px 2px 0 var(--card-border);
    transition: all 0.4s var(--bounce); flex-shrink: 0;
  }
  .step-item.active .step-number {
    background: var(--primary); border-color: var(--text); color: #fff;
    box-shadow: 2px 2px 0 var(--text); transform: scale(1.1);
  }
  .step-item.completed .step-number {
    background: var(--green); border-color: var(--text); color: #fff;
    box-shadow: 2px 2px 0 var(--text);
  }

  .code-block {
    background: var(--bg-alt); border: 2.5px solid var(--card-border);
    border-radius: var(--radius-sm); padding: 0.75rem 0.875rem;
    font-size: 0.78rem; color: var(--text-muted);
    display: flex; align-items: center; justify-content: space-between; gap: 0.625rem;
    box-shadow: 2px 2px 0 var(--card-border);
    transition: border-color 0.3s, background 0.4s;
    overflow-x: auto;
  }
  .code-block:hover { border-color: var(--primary); }
  .code-block .ck { color: var(--primary); font-weight: 700; }
  .code-block .cf { color: var(--secondary); }
  .code-block .cp { color: var(--accent-dark); }

  .copy-btn {
    padding: 0.3rem 0.6rem; border-radius: var(--radius-sm);
    background: var(--card); border: 2px solid var(--card-border);
    color: var(--text-muted); font-size: 0.65rem; font-weight: 800;
    font-family: 'Nunito', sans-serif; cursor: pointer;
    transition: all 0.2s var(--bounce);
    box-shadow: 1px 1px 0 var(--card-border); white-space: nowrap; flex-shrink: 0;
  }
  .copy-btn:hover { border-color: var(--primary); color: var(--primary); transform: translate(-1px, -1px); }
  .copy-btn:active { transform: translate(1px, 1px); }
  .copy-btn.copied { background: var(--green-light); border-color: var(--green); color: var(--green-dark); }

  /* ===== FAQ ===== */
  .faq-item {
    border: 2.5px solid var(--card-border); border-radius: var(--radius-lg);
    overflow: hidden; background: var(--card);
    box-shadow: 3px 3px 0 var(--card-border);
    transition: all 0.3s var(--bounce); cursor: pointer;
  }
  .faq-item.open { border-color: var(--primary); box-shadow: 3px 3px 0 var(--primary); }
  .faq-question {
    padding: 1rem 1.125rem; cursor: pointer;
    display: flex; align-items: center; justify-content: space-between;
    font-family: 'Fredoka', sans-serif; font-weight: 600; font-size: 0.9rem;
    color: var(--text); transition: color 0.3s; gap: 0.75rem;
  }
  .faq-item.open .faq-question { color: var(--primary); }
  .faq-chevron { transition: transform 0.4s var(--bounce); color: var(--text-light); flex-shrink: 0; }
  .faq-item.open .faq-chevron { transform: rotate(180deg); color: var(--primary); }
  .faq-answer {
    max-height: 0; overflow: hidden;
    transition: max-height 0.45s var(--smooth), padding 0.3s;
    padding: 0 1.125rem; cursor: default;
  }
  .faq-item.open .faq-answer { max-height: 280px; padding: 0 1.125rem 1rem; }
  .faq-answer p { font-size: 0.85rem; color: var(--text-muted); line-height: 1.7; }
  .faq-answer code {
    background: var(--primary-light); color: var(--primary);
    padding: 0.1rem 0.4rem; border-radius: 0.25rem; font-size: 0.78rem;
    font-weight: 700; border: 1.5px solid var(--primary);
  }
  .faq-answer strong { color: var(--text); }

  /* ===== CTA SECTION ===== */
  .cta-section {
    position: relative; overflow: hidden;
    padding: 4.5rem 1.25rem; background: var(--bg-alt);
    border-top: 3px solid var(--card-border);
    transition: background 0.4s, border-color 0.4s;
  }
  .cta-inner { position: relative; z-index: 2; text-align: center; max-width: 560px; margin: 0 auto; }
  .cta-section h2 { font-size: clamp(1.85rem, 4.5vw, 2.75rem); font-weight: 700; color: var(--text); margin-bottom: 0.75rem; transition: color 0.4s; }
  .cta-section p { font-size: 1rem; color: var(--text-muted); line-height: 1.7; margin-bottom: 1.75rem; transition: color 0.4s; }

  /* ===== FOOTER ===== */
  .site-footer {
    border-top: 3px solid var(--card-border); padding: 1.75rem 1.25rem;
    background: var(--bg); transition: background 0.4s, border-color 0.4s;
  }
  .footer-inner {
    max-width: 1080px; margin: 0 auto;
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 0.75rem;
  }
  .footer-logo { display: flex; align-items: center; gap: 0.5rem; }
  .footer-logo-icon {
    width: 26px; height: 26px; border-radius: 0.4rem;
    background: var(--primary); border: 2px solid var(--text);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 1px 1px 0 var(--text);
  }
  .footer-logo span { font-family: 'Fredoka', sans-serif; font-weight: 600; font-size: 0.78rem; color: var(--text-muted); transition: color 0.4s; }
  .footer-links { display: flex; gap: 1.25rem; }
  .footer-links a { font-size: 0.78rem; font-weight: 700; color: var(--text-light); transition: color 0.2s; }
  .footer-links a:hover { color: var(--primary); }
  .footer-copy { font-size: 0.75rem; font-weight: 700; color: var(--text-light); transition: color 0.4s; }

  /* ===== BACK TO TOP ===== */
  #backToTop {
    position: fixed; bottom: 1.25rem; right: 1.25rem; z-index: 9990;
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--primary); border: 2.5px solid var(--text);
    box-shadow: 2px 2px 0 var(--text); cursor: pointer;
    display: flex; align-items: center; justify-content: center; color: #fff;
    transition: all 0.3s var(--bounce), background 0.4s;
    opacity: 0; transform: translateY(16px) scale(0.8); pointer-events: none;
  }
  #backToTop.visible { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
  #backToTop:hover { transform: translateY(-2px) scale(1.08); box-shadow: 3px 3px 0 var(--text); }
  #backToTop:active { transform: translateY(1px) scale(0.95); box-shadow: 1px 1px 0 var(--text); }

  /* ===== TOAST ===== */
  .toast-container {
    position: fixed; bottom: 4.5rem; right: 1.25rem; z-index: 99999;
    display: flex; flex-direction: column; gap: 0.5rem; pointer-events: none;
  }
  .toast {
    pointer-events: auto; padding: 0.6rem 1rem;
    border-radius: var(--radius-sm); font-size: 0.78rem; font-weight: 700;
    border: 2.5px solid var(--text); box-shadow: 2px 2px 0 var(--text);
    animation: toastIn 0.4s var(--bounce), toastOut 0.3s ease 2.2s forwards;
  }
  .toast.success { background: var(--green); color: var(--green-dark); border-color: var(--green-dark); box-shadow: 2px 2px 0 var(--green-dark); }
  .toast.info { background: var(--sky); color: var(--sky-dark); border-color: var(--sky-dark); box-shadow: 2px 2px 0 var(--sky-dark); }
  .toast.warn { background: var(--accent); color: var(--accent-dark); border-color: var(--accent-dark); box-shadow: 2px 2px 0 var(--accent-dark); }
  @keyframes toastIn { from { opacity:0; transform: translateY(0.75rem) scale(0.9); } to { opacity:1; transform: translateY(0) scale(1); } }
  @keyframes toastOut { to { opacity:0; transform: translateY(-0.5rem) scale(0.9); } }

  /* ===== SPARKLE CURSOR ===== */
  .sparkle {
    position: fixed; pointer-events: none; z-index: 99997;
    width: 7px; height: 7px;
    clip-path: polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%);
    animation: sparkleFade 0.55s ease-out forwards;
  }
  @keyframes sparkleFade {
    0% { opacity: 1; transform: scale(1) rotate(0deg); }
    100% { opacity: 0; transform: scale(0) rotate(80deg); }
  }

  /* ===== CONFETTI ===== */
  @keyframes confettiBurst {
    0% { opacity: 1; transform: translate(0, 0) rotate(0deg) scale(1); }
    100% { opacity: 0; transform: translate(var(--cx), var(--cy)) rotate(var(--cr)) scale(0.15); }
  }
  .confetti-piece {
    position: fixed; pointer-events: none; z-index: 99998;
    animation: confettiBurst 1s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  /* ===== MASCOT ===== */
  #mascot {
    position: fixed; bottom: 1.25rem; left: 1.25rem; z-index: 9989;
    width: 52px; height: 52px; border-radius: 50% 50% 50% 45%;
    background: var(--primary); border: 3px solid var(--text);
    box-shadow: 2px 2px 0 var(--text); cursor: pointer; overflow: hidden;
    transition: transform 0.4s var(--bounce), background 0.4s;
  }
  #mascot:hover { transform: scale(1.12) rotate(-5deg); }
  #mascot .eye {
    position: absolute; width: 7px; height: 9px;
    background: var(--text); border-radius: 50%; top: 17px;
    transition: background 0.4s;
  }
  #mascot .eye.left { left: 13px; }
  #mascot .eye.right { right: 13px; }
  #mascot .eye::after {
    content: ''; position: absolute; width: 3px; height: 3px;
    background: #fff; border-radius: 50%; top: 1px; right: 0;
  }
  #mascot .mouth {
    position: absolute; bottom: 13px; left: 50%; transform: translateX(-50%);
    width: 10px; height: 5px; border-bottom: 2.5px solid var(--text);
    border-radius: 0 0 50% 50%; transition: border-color 0.4s;
  }
  #mascot .blush {
    position: absolute; width: 9px; height: 5px;
    background: var(--pink); border-radius: 50%; top: 29px; opacity: 0.45;
    transition: background 0.4s;
  }
  #mascot .blush.left { left: 4px; }
  #mascot .blush.right { right: 4px; }
  #mascot.bounce { animation: mascotBounce 0.45s var(--bounce); }
  @keyframes mascotBounce {
    0% { transform: scale(1); }
    30% { transform: scale(1.25) rotate(8deg); }
    60% { transform: scale(0.92) rotate(-4deg); }
    100% { transform: scale(1) rotate(0deg); }
  }

  #mascotTip {
    position: fixed; bottom: 4.25rem; left: 1.25rem; z-index: 9989;
    background: var(--card); border: 2.5px solid var(--card-border);
    border-radius: var(--radius-sm); padding: 0.4rem 0.75rem;
    font-size: 0.72rem; font-weight: 700; color: var(--text-muted);
    box-shadow: 2px 2px 0 var(--card-border);
    opacity: 0; transform: translateY(6px); pointer-events: none;
    transition: all 0.3s var(--bounce); white-space: nowrap;
  }
  #mascotTip.show { opacity: 1; transform: translateY(0); }
  #mascotTip::after {
    content: ''; position: absolute; bottom: -5px; left: 1rem;
    width: 9px; height: 9px; background: var(--card);
    border-right: 2.5px solid var(--card-border);
    border-bottom: 2.5px solid var(--card-border);
    transform: rotate(45deg);
  }

  /* ===== UTILITY ANIMATIONS ===== */
  @keyframes ping { 75%,100% { transform: scale(2); opacity: 0; } }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 640px) {
    .preview-float { display: none !important; }
    .hero-buttons { flex-direction: column; align-items: center; }
    .btn { width: 100%; max-width: 260px; justify-content: center; }
    .cta-section .hero-buttons { flex-direction: row; flex-wrap: wrap; }
    .cta-section .btn { width: auto; max-width: none; }
    #mascot, #mascotTip { display: none; }
  }
  @media (min-width: 641px) and (max-width: 768px) {
    #mascot, #mascotTip { display: none; }
  }

  /* ===== REDUCED MOTION ===== */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.15ms !important;
    }
    .sparkle, .confetti-piece { display: none !important; }
  }

  /* ===== SCROLLBAR ===== */
  ::-webkit-scrollbar { width: 7px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--card-border); border-radius: 4px; border: 2px solid var(--bg); }
  ::-webkit-scrollbar-thumb:hover { background: var(--primary); }
</style>

