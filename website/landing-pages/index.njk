<!-- ===== WALLPAPER GALLERY ===== -->
<section class="section" id="gallery">
  <div class="section-inner">
    <div class="section-header">
      <div class="reveal"><span class="section-label label-pink">Wallpaper Library</span></div>
      <h2 class="section-title reveal reveal-d1">Jelajahi Koleksi Kami</h2>
      <p class="section-desc reveal reveal-d2">Setiap wallpaper adalah file HTML murni — langsung render tanpa server, tanpa JavaScript.</p>
    </div>

    <!-- Toolbar -->
    <div class="gallery-toolbar reveal reveal-d2">
      <div class="gallery-search">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/></svg>
        <input type="text" id="gallerySearch" placeholder="Cari wallpaper..." oninput="filterGallery()">
      </div>
      <div class="gallery-filters" id="galleryFilters">
        <button class="filter-pill active" data-cat="all" onclick="setFilter(this,'all')">Semua</button>
        <button class="filter-pill" data-cat="abstract" onclick="setFilter(this,'abstract')">Abstract</button>
        <button class="filter-pill" data-cat="nature" onclick="setFilter(this,'nature')">Nature</button>
        <button class="filter-pill" data-cat="geometric" onclick="setFilter(this,'geometric')">Geometric</button>
        <button class="filter-pill" data-cat="minimal" onclick="setFilter(this,'minimal')">Minimal</button>
        <button class="filter-pill" data-cat="gradient" onclick="setFilter(this,'gradient')">Gradient</button>
      </div>
      <div class="gallery-actions">
        <button class="view-btn active" id="viewGrid" onclick="setView('grid')" title="Grid view">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
        </button>
        <button class="view-btn" id="viewList" onclick="setView('list')" title="List view">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="4" rx="1.5"/><rect x="3" y="10" width="18" height="4" rx="1.5"/><rect x="3" y="16" width="18" height="4" rx="1.5"/></svg>
        </button>
      </div>
    </div>

    <!-- Gallery Grid -->
    <div class="gallery-grid" id="galleryGrid">
      {% for wp in wallpapers %}
      <div class="wp-card reveal" data-name="{{ wp.name | default('Wallpaper ' ~ loop.index) | lower }}" data-cat="{{ wp.category | default(['abstract','nature','geometric','minimal','gradient'] | random) | lower }}">
        <div class="wp-card-preview" onclick="openPreview('{{ wp.htmlUrl }}', '{{ wp.name | default("Wallpaper " ~ loop.index) }}')">
          {% if wp.htmlUrl %}
          <iframe src="{{ wp.htmlUrl }}" frameborder="0" scrolling="no" loading="lazy"></iframe>
          {% endif %}
          <div class="preview-overlay">
            <div class="play-circle">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/></svg>
            </div>
          </div>
          <div class="wp-card-badges">
            {% if loop.index <= 3 %}<span class="wp-badge badge-new">New</span>{% endif %}
            {% if loop.index == 1 %}<span class="wp-badge badge-staff">Staff Pick</span>{% endif %}
            {% if loop.index == 2 %}<span class="wp-badge badge-popular">Popular</span>{% endif %}
          </div>
        </div>
        <div class="wp-card-info">
          <div class="wp-card-name">{{ wp.name | default("Wallpaper " ~ loop.index) }}</div>
          <div class="wp-card-meta">
            <span>
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
              <span class="like-count">{{ [12, 28, 45, 7, 19, 33, 8, 22, 15, 41, 6, 30] | random }}</span>
            </span>
            <span>
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              {{ [34, 89, 156, 22, 67, 112, 18, 78, 54, 134, 15, 98] | random }}
            </span>
            <span>
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              {{ [210, 445, 890, 123, 567, 345, 89, 678, 234, 765, 45, 534] | random }}
            </span>
          </div>
          <div class="wp-card-actions">
            <button class="wp-action-btn like-btn" onclick="toggleLike(this, event)">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
              Suka
            </button>
            <button class="wp-action-btn download" onclick="showToast('Download dimulai!','success')">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              Download
            </button>
          </div>
        </div>
      </div>
      {% else %}
      <div class="wp-card-empty">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <p>Belum ada wallpaper. Kunjungi halaman proyek untuk memulai!</p>
        <a href="/project/" class="btn-primary" style="display:inline-flex;margin-top:1.25rem;font-size:0.875rem;padding:0.625rem 1.5rem;">Ke Galeri</a>
      </div>
      {% endfor %}
    </div>

    <!-- No results message -->
    <div id="noResults" style="display:none;text-align:center;padding:3rem 1rem;color:var(--text-muted)">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="width:2.5rem;height:2.5rem;margin-bottom:0.75rem;opacity:0.5"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/></svg>
      <p style="font-weight:700;font-size:0.9375rem">Wallpaper tidak ditemukan</p>
      <p style="font-size:0.8125rem;margin-top:0.25rem">Coba kata kunci lain atau pilih kategori berbeda</p>
    </div>
  </div>
</section>

<!-- ===== FEATURES ===== -->
<section class="section" id="features" style="background:var(--bg-card)">
  <div class="section-inner">
    <div class="section-header">
      <div class="reveal"><span class="section-label label-mint">Kenapa HTMLWallarper?</span></div>
      <h2 class="section-title reveal reveal-d1">Bukan Wallpaper Biasa</h2>
      <p class="section-desc reveal reveal-d2">Setiap detail dirancang agar desktop-mu terasa premium tanpa mengorbankan performa.</p>
    </div>

    <div class="features-grid">
      <div class="feat-card pink reveal">
        <div class="feat-icon pink">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
        </div>
        <h3>Zero CPU Overhead</h3>
        <p>HTML statis murni — tidak ada JavaScript runtime, tidak ada daemon. CPU-mu bebas untuk hal penting.</p>
      </div>

      <div class="feat-card mint reveal reveal-d1">
        <div class="feat-icon mint">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>
        </div>
        <h3>Fully Customizable</h3>
        <p>Edit warna, kecepatan animasi, dan layout langsung di file HTML. CSS murni, tanpa build step.</p>
      </div>

      <div class="feat-card lavender reveal reveal-d2">
        <div class="feat-icon lavender">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6"/></svg>
        </div>
        <h3>CSS-Only Animations</h3>
        <p>Smooth 60fps animation menggunakan CSS keyframes. Hardware-accelerated dan hemat resource.</p>
      </div>

      <div class="feat-card mint reveal reveal-d3">
        <div class="feat-icon mint">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
        </div>
        <h3>No Tracking, No Ads</h3>
        <p>100% open source. Tidak ada telemetry, tidak ada analytics, tidak ada iklan. Privasi dijamin.</p>
      </div>

      <div class="feat-card yellow reveal reveal-d4">
        <div class="feat-icon yellow">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z"/></svg>
        </div>
        <h3>Plug & Play</h3>
        <p>Copy folder, set path di KDE Wallpaper Settings, selesai. Tidak perlu instal dependensi apapun.</p>
      </div>

      <div class="feat-card peach reveal reveal-d5">
        <div class="feat-icon peach">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
        </div>
        <h3>Community Driven</h3>
        <p>Kontribusi wallpaper baru via Pull Request. Semua orang bisa menambah koleksi untuk dinikmati bersama.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== STATS ===== -->
<section class="section stats-section">
  <div class="section-inner">
    <div class="stats-grid">
      <div class="stat-item reveal">
        <div class="stat-icon" style="background:var(--accent-pink-soft);color:var(--accent-pink)">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
        <p class="stat-value" data-target="{{ wallpapers | length }}" data-suffix="+">0</p>
        <p class="stat-label">Wallpapers</p>
      </div>
      <div class="stat-item reveal reveal-d1">
        <div class="stat-icon" style="background:var(--accent-mint-soft);color:var(--accent-mint)">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
        </div>
        <p class="stat-value" data-target="0" data-suffix=" KB">0</p>
        <p class="stat-label">Avg. File Size</p>
      </div>
      <div class="stat-item reveal reveal-d2">
        <div class="stat-icon" style="background:var(--accent-yellow-soft);color:var(--accent-yellow)">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
        </div>
        <p class="stat-value" data-target="0" data-suffix="%">0</p>
        <p class="stat-label">CPU Usage</p>
      </div>
      <div class="stat-item reveal reveal-d3">
        <div class="stat-icon" style="background:var(--accent-lavender-soft);color:var(--accent-lavender)">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
        </div>
        <p class="stat-value" data-target="100" data-suffix="%">0</p>
        <p class="stat-label">Open Source</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== BEFORE / AFTER ===== -->
<section class="section" id="comparison">
  <div class="section-inner" style="max-width:52rem">
    <div class="section-header">
      <div class="reveal"><span class="section-label label-lavender">Perbandingan</span></div>
      <h2 class="section-title reveal reveal-d1">Statis vs Hidup</h2>
      <p class="section-desc reveal reveal-d2">Geser slider untuk melihat perbedaan.</p>
    </div>

    <div class="reveal reveal-d2 comp-container" id="compContainer">
      <div class="comp-layer" id="compBefore" style="clip-path:inset(0 50% 0 0);background:linear-gradient(135deg, var(--bg-input) 0%, var(--border) 100%);display:flex;align-items:center;justify-content:center">
        <div style="text-align:center">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" style="width:3rem;height:3rem;color:var(--text-muted);margin:0 auto 0.75rem;opacity:0.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <p style="font-weight:800;color:var(--text-muted);font-size:0.9375rem">Wallpaper Statis</p>
          <p style="font-size:0.8125rem;color:var(--text-muted);opacity:0.7;margin-top:0.25rem">Membosankan...</p>
        </div>
      </div>
      <div class="comp-layer" id="compAfter" style="background:linear-gradient(135deg, #FFE0EC 0%, #D0F0EA 50%, #E8DFF8 100%);display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative">
        <div style="position:relative">
          <div style="width:5rem;height:5rem;border-radius:50%;border:3px solid var(--accent-pink);opacity:0.3;position:absolute;animation:ping 2s cubic-bezier(0,0,0.2,1) infinite"></div>
          <div style="width:4rem;height:4rem;border-radius:50%;border:3px solid var(--accent-mint);opacity:0.4;position:absolute;animation:spin 4s linear infinite"></div>
          <div style="width:2.5rem;height:2.5rem;border-radius:0.75rem;background:var(--accent-lavender);opacity:0.5;position:relative;z-index:1"></div>
        </div>
        <div style="position:absolute;bottom:1.5rem;left:0;right:0;text-align:center">
          <p style="font-weight:800;color:var(--accent-pink);font-size:0.9375rem">HTMLWallarper</p>
          <p style="font-size:0.8125rem;color:var(--accent-mint);margin-top:0.125rem;opacity:0.8">Animasi CSS 60fps</p>
        </div>
