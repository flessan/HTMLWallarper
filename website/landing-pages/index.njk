---
layout: layout.njk
title: Project Gallery
permalink: /project/index.html
---

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">

{% raw %}
<style>
  /* ===== CSS VARIABLES ===== */
  :root {
    --bg: #FEF6E8; --bg-alt: #FFF0DB; --bg-dot: #F0D9B5;
    --card: #FFFFFF; --card-border: #E8CFA8; --card-border-hover: #E8A85C;
    --text: #3D2C1E; --text-muted: #8B7355; --text-light: #A89279;
    --primary: #FF7043; --primary-hover: #FF5722; --primary-light: #FFCCBC;
    --secondary: #26A69A; --secondary-light: #B2DFDB;
    --accent: #FFD54F; --accent-light: #FFF8E1; --accent-dark: #F57F17;
    --purple: #CE93D8; --purple-light: #F3E5F5;
    --pink: #F48FB1; --pink-light: #FCE4EC;
    --sky: #81D4FA; --sky-light: #E1F5FE; --sky-dark: #0288D1;
    --green: #81C784; --green-light: #E8F5E9; --green-dark: #2E7D32;
    --shadow-card: 0 4px 0 0 var(--card-border), 0 6px 20px rgba(61,44,30,0.07);
    --shadow-card-hover: 0 4px 0 0 var(--card-border-hover), 0 10px 30px rgba(255,112,67,0.12);
    --radius-sm: 0.75rem; --radius-md: 1rem; --radius-lg: 1.25rem; --radius-xl: 1.75rem;
    --bounce: cubic-bezier(0.68, -0.4, 0.265, 1.4); --smooth: cubic-bezier(0.4, 0, 0.2, 1);
    --nav-h: 64px;
  }

  [data-theme="dark"] {
    --bg: #1A192B; --bg-alt: #22213A; --bg-dot: #2D2C4A;
    --card: #272643; --card-border: #3A3960; --card-border-hover: #FF8A65;
    --text: #F0E6D6; --text-muted: #9E93A8; --text-light: #6E6585;
    --primary: #FF8A65; --primary-hover: #FFAB91; --primary-light: rgba(255,138,101,0.14);
    --secondary: #4DB6AC; --secondary-light: rgba(77,182,172,0.14);
    --accent: #FFE082; --accent-light: rgba(255,224,130,0.1); --accent-dark: #FFB300;
    --purple: #CE93D8; --purple-light: rgba(206,147,216,0.12);
    --pink: #F48FB1; --pink-light: rgba(244,143,177,0.12);
    --sky: #81D4FA; --sky-light: rgba(129,212,250,0.12); --sky-dark: #4FC3F7;
    --green: #81C784; --green-light: rgba(129,199,132,0.12); --green-dark: #66BB6A;
    --shadow-card: 0 4px 0 0 var(--card-border), 0 6px 20px rgba(0,0,0,0.2);
    --shadow-card-hover: 0 4px 0 0 var(--card-border-hover), 0 10px 30px rgba(255,138,101,0.1);
  }

  /* ===== BASE ===== */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Nunito', sans-serif; background: var(--bg); color: var(--text);
    overflow-x: hidden; transition: background 0.5s var(--smooth), color 0.5s var(--smooth); line-height: 1.6;
  }
  body::before {
    content: ''; position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background-image: radial-gradient(var(--bg-dot) 1px, transparent 1px);
    background-size: 22px 22px; opacity: 0.45; transition: opacity 0.5s;
  }
  h1, h2, h3, h4 { font-family: 'Fredoka', sans-serif; line-height: 1.2; }
  a { text-decoration: none; color: inherit; }
  :focus-visible { outline: 3px solid var(--primary); outline-offset: 2px; border-radius: 4px; }

  /* ===== SCROLL PROGRESS ===== */
  #scrollProgress {
    position: fixed; top: 0; left: 0; height: 4px; z-index: 10001;
    background: linear-gradient(90deg, var(--primary), var(--accent), var(--secondary), var(--primary));
    background-size: 300% 100%; animation: progressSlide 4s linear infinite;
    width: 0%; border-radius: 0 4px 4px 0; transition: width 0.06s linear;
  }
  @keyframes progressSlide { to { background-position: 300% 0; } }

  /* ===== NAVIGATION ===== */
  #mainNav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 10000; height: var(--nav-h);
    background: var(--bg); border-bottom: 2.5px solid var(--card-border);
    transition: background 0.4s var(--smooth), border-color 0.4s, box-shadow 0.3s;
  }
  #mainNav.scrolled { background: var(--bg); box-shadow: 0 2px 8px rgba(61,44,30,0.06); }
  .nav-inner {
    max-width: 1080px; margin: 0 auto; height: 100%; display: flex; align-items: center;
    justify-content: space-between; padding: 0 1.25rem;
  }
  .nav-logo {
    display: flex; align-items: center; gap: 0.6rem; font-family: 'Fredoka', sans-serif;
    font-weight: 700; font-size: 1.05rem; color: var(--text); transition: color 0.4s;
  }
  .nav-logo-icon {
    width: 34px; height: 34px; border-radius: var(--radius-sm); background: var(--primary);
    border: 2.5px solid var(--text); display: flex; align-items: center; justify-content: center;
    box-shadow: 2px 2px 0 var(--text); transition: transform 0.3s var(--bounce), background 0.4s;
  }
  .nav-logo:hover .nav-logo-icon { transform: rotate(-8deg) scale(1.08); }
  .nav-links { display: flex; align-items: center; gap: 0.2rem; }
  .nav-links a {
    padding: 0.45rem 0.75rem; border-radius: var(--radius-sm); font-size: 0.8rem; font-weight: 700;
    color: var(--text-muted); transition: all 0.2s var(--smooth); border: 2px solid transparent;
  }
  .nav-links a:hover { color: var(--primary); background: var(--primary-light); }
  .nav-cta {
    padding: 0.45rem 1rem !important; background: var(--primary) !important; color: #fff !important;
    border: 2.5px solid var(--text) !important; border-radius: var(--radius-sm) !important;
    box-shadow: 2px 2px 0 var(--text); transition: all 0.25s var(--bounce) !important;
  }
  .nav-cta:hover { background: var(--primary-hover) !important; transform: translate(-1px, -1px); box-shadow: 3px 3px 0 var(--text) !important; }
  
  /* Theme Toggle */
  .theme-toggle {
    width: 38px; height: 38px; border-radius: 50%; background: var(--accent-light);
    border: 2.5px solid var(--card-border); cursor: pointer; display: flex; align-items: center;
    justify-content: center; transition: all 0.3s var(--bounce); position: relative; overflow: hidden; flex-shrink: 0;
  }
  .theme-toggle:hover { transform: scale(1.12) rotate(15deg); border-color: var(--accent-dark); }
  .theme-toggle .sun, .theme-toggle .moon { position: absolute; transition: all 0.45s var(--bounce); }
  .theme-toggle .sun { opacity: 1; transform: scale(1) rotate(0deg); }
  .theme-toggle .moon { opacity: 0; transform: scale(0.4) rotate(-90deg); }
  [data-theme="dark"] .theme-toggle .sun { opacity: 0; transform: scale(0.4) rotate(90deg); }
  [data-theme="dark"] .theme-toggle .moon { opacity: 1; transform: scale(1) rotate(0deg); }

  /* ===== DECORATIONS ===== */
  .cartoon-deco { position: absolute; pointer-events: none; z-index: 0; }
  .deco-star {
    width: 20px; height: 20px; background: var(--accent);
    clip-path: polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%);
    animation: twinkle 3s ease-in-out infinite;
  }
  @keyframes twinkle { 0%,100% { transform: scale(1) rotate(0deg); opacity: 0.75; } 50% { transform: scale(1.25) rotate(12deg); opacity: 1; } }
  .deco-heart {
    width: 18px; height: 16px; background: var(--pink); transform: rotate(-45deg);
    border-radius: 0 50% 0 50%; animation: floatHeart 4s ease-in-out infinite;
  }
  .deco-heart::before { content: ''; position: absolute; width: 18px; height: 16px; background: var(--pink); border-radius: 50% 50% 0 0; top: -8px; left: 0; }
  @keyframes floatHeart { 0%,100% { transform: rotate(-45deg) translateY(0) scale(1); } 50% { transform: rotate(-45deg) translateY(-8px) scale(1.12); } }
  .deco-cloud {
    width: 72px; height: 36px; background: var(--card); border-radius: 36px;
    border: 2.5px solid var(--card-border); box-shadow: 2px 2px 0 var(--card-border);
    animation: floatCloud 8s ease-in-out infinite; transition: background 0.4s, border-color 0.4s;
  }
  .deco-cloud::before {
    content: ''; position: absolute; width: 32px; height: 32px; background: var(--card);
    border-radius: 50%; border: 2.5px solid var(--card-border); border-bottom-color: transparent; top: -18px; left: 12px;
  }
  .deco-cloud::after {
    content: ''; position: absolute; width: 22px; height: 22px; background: var(--card);
    border-radius: 50%; border: 2.5px solid var(--card-border); border-bottom-color: transparent; top: -10px; left: 38px;
  }
  @keyframes floatCloud { 0%,100% { transform: translateY(0) translateX(0); } 50% { transform: translateY(-10px) translateX(6px); } }

  /* ===== GALLERY HERO & STATS ===== */
  .gallery-hero {
    position: relative; padding: calc(var(--nav-h) + 3rem) 1.25rem 3rem; text-align: center;
    max-width: 800px; margin: 0 auto; z-index: 1;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.45rem 0.9rem;
    border-radius: 999px; background: var(--card); border: 2.5px solid var(--card-border);
    box-shadow: 2px 2px 0 var(--card-border); font-size: 0.72rem; font-weight: 700;
    color: var(--text-muted); margin-bottom: 1.5rem; transition: all 0.4s;
  }
  .dot-live { width: 7px; height: 7px; border-radius: 50%; background: var(--green); border: 2px solid var(--text); animation: pulse 2s ease-in-out infinite; flex-shrink: 0; }
  @keyframes pulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.2); } }
  
  .gallery-hero h1 {
    font-size: clamp(2.2rem, 5.5vw, 3.25rem); font-weight: 700; color: var(--text);
    margin-bottom: 0.875rem; transition: color 0.4s;
  }
  .gallery-hero p {
    font-size: clamp(0.9rem, 2vw, 1.1rem); color: var(--text-muted); line-height: 1.7;
    max-width: 540px; margin: 0 auto 2rem; transition: color 0.4s;
  }

  .stats-bar {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; margin-bottom: 2rem;
  }
  @media(min-width: 640px) { .stats-bar { grid-template-columns: repeat(4, 1fr); } }
  .stat-card-lg {
    background: var(--card); border: 2.5px solid var(--card-border); border-radius: var(--radius-lg);
    padding: 1rem; text-align: center; box-shadow: var(--shadow-card);
    transition: transform 0.3s var(--bounce), border-color 0.3s;
  }
  .stat-card-lg:hover { transform: translateY(-3px) rotate(-1deg); border-color: var(--card-border-hover); }
  .stat-val { font-family: 'Fredoka', sans-serif; font-weight: 700; font-size: 1.75rem; color: var(--primary); line-height: 1.2; transition: color 0.4s; }
  .stat-lbl { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-light); margin-top: 0.25rem; }

  /* ===== GALLERY TOOLBAR ===== */
  .toolbar-wrap {
    max-width: 1200px; margin: 0 auto 2rem; padding: 0 1.25rem; position: relative; z-index: 2;
  }
  .toolbar {
    display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;
    background: var(--card); border: 2.5px solid var(--card-border); border-radius: var(--radius-lg);
    padding: 0.75rem; box-shadow: var(--shadow-card); transition: border-color 0.3s;
  }
  .toolbar:hover { border-color: var(--card-border-hover); }
  
  .toolbar-search { position: relative; flex: 1; min-width: 200px; }
  .toolbar-search svg { position: absolute; left: 0.85rem; top: 50%; transform: translateY(-50%); color: var(--text-light); width: 18px; height: 18px; pointer-events: none; }
  .toolbar-search input {
    width: 100%; background: var(--bg-alt); border: 2px solid var(--card-border); border-radius: var(--radius-md);
    padding: 0.65rem 1rem 0.65rem 2.6rem; font-family: 'Nunito', sans-serif; font-size: 0.85rem;
    font-weight: 700; color: var(--text); outline: none; transition: all 0.2s var(--bounce);
  }
  .toolbar-search input:focus { border-color: var(--primary); box-shadow: 2px 2px 0 var(--primary); transform: translate(-1px, -1px); }
  .toolbar-search input::placeholder { color: var(--text-light); }

  .toolbar-btn {
    display: inline-flex; align-items: center; gap: 0.4rem; background: var(--bg-alt);
    border: 2px solid var(--card-border); border-radius: var(--radius-md); padding: 0.6rem 1rem;
    font-family: 'Fredoka', sans-serif; font-size: 0.8rem; font-weight: 600; color: var(--text-muted);
    cursor: pointer; box-shadow: 2px 2px 0 var(--card-border); transition: all 0.2s var(--bounce);
  }
  .toolbar-btn:hover { transform: translate(-1px, -1px); border-color: var(--primary); color: var(--primary); box-shadow: 3px 3px 0 var(--primary); }
  .toolbar-btn.active { background: var(--pink-light); border-color: var(--pink); color: var(--pink); box-shadow: 2px 2px 0 var(--pink); }

  .view-toggle { display: flex; border-radius: var(--radius-md); overflow: hidden; border: 2px solid var(--card-border); }
  .view-btn { background: var(--bg-alt); padding: 0.5rem 0.75rem; border: none; border-right: 1px solid var(--card-border); cursor: pointer; transition: background 0.2s; color: var(--text-light); }
  .view-btn:last-child { border-right: none; }
  .view-btn.active { background: var(--primary); color: #fff; }
  .view-btn:hover:not(.active) { background: var(--bg); }

  /* ===== GALLERY GRID ===== */
  .gallery-root { position: relative; z-index: 1; padding-bottom: 4rem; }
  .gallery-grid {
    max-width: 1200px; margin: 0 auto; padding: 0 1.25rem; display: grid;
    grid-template-columns: 1fr; gap: 1.5rem;
  }
  @media(min-width: 768px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); } }
  @media(min-width: 1024px) { .gallery-grid { grid-template-columns: repeat(3, 1fr); } }
  
  .gallery-grid.list-view { grid-template-columns: 1fr; }
  .list-view .wallpaper-card { grid-column: 1 / -1; }
  .list-view .card-inner { display: grid; grid-template-columns: 300px 1fr; }
  .list-view .preview-area { border-bottom: none; border-right: 2.5px solid var(--card-border); aspect-ratio: auto; min-height: 200px; }
  @media(max-width: 640px) { .list-view .card-inner { grid-template-columns: 1fr; } .list-view .preview-area { aspect-ratio: 16/9; border-bottom: 2.5px solid var(--card-border); border-right: none; } }

  /* ===== WALLPAPER CARD ===== */
  .wallpaper-card { opacity: 0; transform: translateY(20px) scale(0.98); transition: opacity 0.6s var(--bounce), transform 0.6s var(--bounce); }
  .wallpaper-card.visible { opacity: 1; transform: translateY(0) scale(1); }
  .wallpaper-card.hidden-by-filter { display: none; }

  .card-inner {
    background: var(--card); border: 2.5px solid var(--card-border); border-radius: var(--radius-lg);
    overflow: hidden; box-shadow: var(--shadow-card); transition: all 0.3s var(--bounce);
    position: relative; display: flex; flex-direction: column;
  }
  .card-inner:hover { border-color: var(--card-border-hover); box-shadow: var(--shadow-card-hover); transform: translateY(-3px); }

  .preview-area {
    position: relative; aspect-ratio: 16/9; background: var(--bg-alt); overflow: hidden;
    border-bottom: 2.5px solid var(--card-border); transition: background 0.4s;
  }
  .preview-area iframe {
    position: absolute; left: 50%; top: 50%; width: 1280px; height: 720px;
    margin-left: -640px; margin-top: -360px; transform: scale(0.3125); border: none;
    pointer-events: none; transition: opacity 0.5s var(--smooth); opacity: 0.8;
  }
  .card-inner:hover .preview-area iframe { opacity: 1; }

  /* Card Actions Overlay */
  .hover-overlay {
    position: absolute; inset: 0; z-index: 20; background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(4px); opacity: 0; transition: opacity 0.3s;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem;
  }
  .card-inner:hover .hover-overlay { opacity: 1; }
  .overlay-btn {
    padding: 0.5rem 1.25rem; border-radius: 999px; font-family: 'Fredoka', sans-serif;
    font-weight: 600; font-size: 0.8rem; cursor: pointer; border: 2.5px solid;
    transition: all 0.25s var(--bounce); transform: translateY(8px); opacity: 0; color: #fff;
  }
  .card-inner:hover .overlay-btn { transform: translateY(0); opacity: 1; }
  .card-inner:hover .overlay-btn:nth-child(2) { transition-delay: 0.05s; }
  .overlay-btn-primary { background: var(--primary); border-color: var(--text); box-shadow: 2px 2px 0 var(--text); }
  .overlay-btn-primary:hover { transform: translateY(-2px) !important; background: var(--primary-hover); box-shadow: 3px 3px 0 var(--text); }
  .overlay-btn-secondary { background: var(--card); color: var(--text); border-color: var(--card-border); box-shadow: 2px 2px 0 var(--card-border); }
  .overlay-btn-secondary:hover { transform: translateY(-2px) !important; border-color: var(--primary); color: var(--primary); }

  /* Card Header/Body */
  .card-index {
    position: absolute; top: 0.75rem; left: 0.75rem; z-index: 30; padding: 0.2rem 0.6rem;
    border-radius: 999px; font-size: 0.6rem; font-weight: 800; background: var(--card);
    border: 2px solid var(--card-border); color: var(--text-muted); box-shadow: 1px 1px 0 var(--card-border);
  }
  .fav-btn {
    position: absolute; top: 0.75rem; right: 0.75rem; z-index: 30; width: 32px; height: 32px;
    border-radius: 50%; background: var(--card); border: 2.5px solid var(--card-border);
    box-shadow: 1px 1px 0 var(--card-border); display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all 0.3s var(--bounce);
  }
  .fav-btn:hover { transform: scale(1.15); border-color: var(--pink); box-shadow: 1px 1px 0 var(--pink); }
  .fav-btn.active { background: var(--pink-light); border-color: var(--pink); box-shadow: 1px 1px 0 var(--pink); }
  .fav-btn.active svg { fill: var(--pink); color: var(--pink); }
  .fav-btn.bounce { animation: favBounce 0.4s var(--bounce); }
  @keyframes favBounce { 0% { transform: scale(1); } 30% { transform: scale(1.35); } 60% { transform: scale(0.9); } 100% { transform: scale(1); } }

  .card-body { padding: 1.25rem; flex: 1; display: flex; flex-direction: column; }
  .card-head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem; }
  .card-head h3 { font-size: 1.05rem; font-weight: 600; color: var(--text); transition: color 0.4s; text-transform: capitalize; }
  .card-inner:hover .card-head h3 { color: var(--primary); }
  .live-tag { display: flex; align-items: center; gap: 0.25rem; }
  .live-tag-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--green); animation: pulse 2s infinite; }
  .live-tag span { font-size: 0.55rem; font-weight: 800; color: var(--green); letter-spacing: 0.05em; }

  .path-row {
    display: flex; align-items: center; font-size: 0.75rem; font-weight: 600; color: var(--text-muted);
    background: var(--bg-alt); padding: 0.5rem 0.75rem; border-radius: var(--radius-sm);
    border: 2px solid var(--card-border); cursor: pointer; transition: all 0.2s; gap: 0.5rem; margin-top: auto;
  }
  .path-row:hover { border-color: var(--primary); background: var(--primary-light); }
  .path-row svg { flex-shrink: 0; color: var(--primary); transition: color 0.4s; width: 16px; height: 16px; }
  .path-text { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-family: 'Courier New', monospace; }
  .copy-icon { flex-shrink: 0; color: var(--text-light); width: 16px; height: 16px; }
  .copy-icon.copied { color: var(--green); }

  /* ===== LIGHTBOX ===== */
  .lightbox-overlay {
    position: fixed; inset: 0; z-index: 9000; background: color-mix(in srgb, var(--bg) 90%, transparent);
    backdrop-filter: blur(16px); display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.35s var(--smooth);
  }
  .lightbox-overlay.active { opacity: 1; pointer-events: auto; }
  .lightbox-content {
    width: 90vw; height: 75vh; max-width: 1400px; border-radius: var(--radius-xl); overflow: hidden;
    border: 3px solid var(--card-border); box-shadow: 4px 4px 0 var(--card-border), 0 16px 48px rgba(0,0,0,.15);
    transform: scale(0.92); transition: transform 0.4s var(--bounce); position: relative;
  }
  .lightbox-overlay.active .lightbox-content { transform: scale(1); }
  .lightbox-content iframe { width: 100%; height: 100%; border: none; }
  .lightbox-bar {
    position: absolute; top: 0; left: 0; right: 0; padding: 0.75rem 1rem; display: flex; align-items: center;
    justify-content: space-between; background: linear-gradient(to bottom, color-mix(in srgb, var(--bg) 85%, transparent), transparent);
    z-index: 5;
  }
  .lb-nav-btn {
    position: absolute; top: 50%; transform: translateY(-50%); width: 44px; height: 44px;
    border-radius: 50%; background: var(--card); border: 2.5px solid var(--text);
    box-shadow: 2px 2px 0 var(--text); display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--text); transition: all 0.25s var(--bounce); z-index: 5;
  }
  .lb-nav-btn:hover { transform: translateY(-50%) translate(-1px, -1px); box-shadow: 3px 3px 0 var(--text); }
  .lb-nav-btn.prev { left: 1rem; }
  .lb-nav-btn.next { right: 1rem; }
  .lb-close {
    width: 32px; height: 32px; border-radius: var(--radius-sm); background: var(--card);
    border: 2.5px solid var(--card-border); box-shadow: 1px 1px 0 var(--card-border);
    display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--text-muted);
    transition: all 0.25s var(--bounce);
  }
  .lb-close:hover { color: var(--pink); border-color: var(--pink); box-shadow: 1px 1px 0 var(--pink); }

  /* ===== MASCOT & TOAST ===== */
  #mascot {
    position: fixed; bottom: 1.25rem; left: 1.25rem; z-index: 9989; width: 52px; height: 52px;
    border-radius: 50% 50% 50% 45%; background: var(--primary); border: 3px solid var(--text);
    box-shadow: 2px 2px 0 var(--text); cursor: pointer; overflow: hidden;
    transition: transform 0.4s var(--bounce), background 0.4s;
  }
  #mascot:hover { transform: scale(1.12) rotate(-5deg); }
  #mascot .eye { position: absolute; width: 7px; height: 9px; background: var(--text); border-radius: 50%; top: 17px; }
  #mascot .eye.left { left: 13px; } #mascot .eye.right { right: 13px; }
  #mascot .eye::after { content: ''; position: absolute; width: 3px; height: 3px; background: #fff; border-radius: 50%; top: 1px; right: 0; }
  #mascot .mouth { position: absolute; bottom: 13px; left: 50%; transform: translateX(-50%); width: 10px; height: 5px; border-bottom: 2.5px solid var(--text); border-radius: 0 0 50% 50%; }
  #mascot .blush { position: absolute; width: 9px; height: 5px; background: var(--pink); border-radius: 50%; top: 29px; opacity: 0.45; }
  #mascot .blush.left { left: 4px; } #mascot .blush.right { right: 4px; }
  #mascot.bounce { animation: mascotBounce 0.45s var(--bounce); }
  @keyframes mascotBounce { 0% { transform: scale(1); } 30% { transform: scale(1.25) rotate(8deg); } 60% { transform: scale(0.92) rotate(-4deg); } 100% { transform: scale(1) rotate(0deg); } }

  #mascotTip {
    position: fixed; bottom: 4.5rem; left: 1.25rem; z-index: 9989; background: var(--card);
    border: 2.5px solid var(--card-border); border-radius: var(--radius-sm); padding: 0.4rem 0.75rem;
    font-size: 0.72rem; font-weight: 700; color: var(--text-muted); box-shadow: 2px 2px 0 var(--card-border);
    opacity: 0; transform: translateY(6px); pointer-events: none; transition: all 0.3s var(--bounce);
  }
  #mascotTip.show { opacity: 1; transform: translateY(0); }
  #mascotTip::after { content: ''; position: absolute; bottom: -5px; left: 1rem; width: 9px; height: 9px; background: var(--card); border-right: 2.5px solid var(--card-border); border-bottom: 2.5px solid var(--card-border); transform: rotate(45deg); }

  .toast-container { position: fixed; bottom: 4.5rem; right: 1.25rem; z-index: 99999; display: flex; flex-direction: column; gap: 0.5rem; pointer-events: none; }
  .toast {
    pointer-events: auto; padding: 0.6rem 1rem; border-radius: var(--radius-sm); font-size: 0.78rem;
    font-weight: 700; border: 2.5px solid var(--text); box-shadow: 2px 2px 0 var(--text);
    animation: toastIn 0.4s var(--bounce), toastOut 0.3s ease 2.2s forwards;
  }
  .toast.success { background: var(--green); color: var(--green-dark); border-color: var(--green-dark); }
  .toast.info { background: var(--sky); color: var(--sky-dark); border-color: var(--sky-dark); }
  @keyframes toastIn { from { opacity: 0; transform: translateY(0.75rem) scale(0.9); } to { opacity: 1; transform: translateY(0) scale(1); } }
  @keyframes toastOut { to { opacity: 0; transform: translateY(-0.5rem) scale(0.9); } }

  /* ===== UTILS ===== */
  .reveal { opacity: 0; transform: translateY(28px) scale(0.97); transition: opacity 0.65s var(--bounce), transform 0.65s var(--bounce); }
  .reveal.visible { opacity: 1; transform: translateY(0) scale(1); }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }

  .empty-state {
    grid-column: 1/-1; padding: 3rem 1rem; text-align: center; background: var(--card);
    border: 3px dashed var(--card-border); border-radius: var(--radius-xl); color: var(--text-muted);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) { .nav-links { display: none; } #mascot, #mascotTip { display: none; } }
  @media (prefers-reduced-motion: reduce) { *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.15ms !important; } }
  ::-webkit-scrollbar { width: 7px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--card-border); border-radius: 4px; border: 2px solid var(--bg); }
</style>
{% endraw %}

