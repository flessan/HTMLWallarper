    <button id="filterFavBtn" class="toolbar-btn">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
      Favorites
    </button>
    <div class="view-toggle">
      <button id="viewGrid" class="view-btn active" aria-label="Grid View">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
      </button>
      <button id="viewList" class="view-btn" aria-label="List View">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>
</div>

<!-- GALLERY GRID -->
<div class="gallery-root">
  <div class="gallery-grid" id="galleryGrid">
    {% for wp in wallpapers %}
    {%- set wp_lower = wp.name | lower -%} <!-- FIXED LINE -->
    <div class="wallpaper-card" data-name="{{ wp_lower }}" data-index="{{ loop.index0 }}">
      <div class="card-inner">
        <div class="preview-area">
          <iframe src="{{ wp.htmlUrl }}" frameborder="0" scrolling="no" loading="lazy"></iframe>

          <div class="hover-overlay">
            <button onclick="openLightbox({{ loop.index0 }})" class="overlay-btn overlay-btn-primary">Live Preview</button>
            <a href="{{ wp.htmlUrl }}" target="_blank" class="overlay-btn overlay-btn-secondary">Fullscreen</a>
            <a href="{{ wp.url }}" target="_blank" class="overlay-btn overlay-btn-secondary">Source</a>
          </div>

          <div class="card-index">#{{ loop.index }}</div>
          <!-- Note: You might need to update the toggleFav call if you rely on strict casing, 
               but usually passing the variable is safer. -->
          <button onclick="toggleFav('{{ wp_lower | escape }}', this)" class="fav-btn" data-name="{{ wp_lower }}">
            <svg class="w-4 h-4" style="color:var(--text-light)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </button>
        </div>

        <div class="card-body">
          <div class="card-head">
            <h3>{{ wp.name }}</h3>
            <span class="live-tag"><span class="live-tag-dot"></span><span>LIVE</span></span>
          </div>
          <div class="path-row" onclick="copyPath('/wallpapers/{{ wp.folderName }}', this)">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
            <span class="path-text">/wallpapers/{{ wp.folderName }}</span>
            <svg class="copy-icon w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          </div>
        </div>
      </div>
    </div>
    {% else %}
    <div class="empty-state">
      <p>No wallpapers found. Make sure the `wallpapers` collection is available in your template data.</p>
    </div>
    {% endfor %}
  </div>
  
  <div id="noResults" style="display:none">
    <div class="empty-state">
      <p>No wallpapers match your search.</p>
      <button onclick="clearFilters()" class="toolbar-btn" style="margin:1rem auto;">Clear Filters</button>
    </div>
  </div>
</div>

<!-- LIGHTBOX -->
<div class="lightbox-overlay" id="lightbox" onclick="closeLightboxOnBg(event)">
  <div class="lightbox-bar">
    <span id="lightboxTitle" style="font-family:'Fredoka';font-weight:600;color:var(--text);">Preview</span>
    <button class="lb-close" onclick="closeLightbox()" aria-label="Close">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
  <button class="lb-nav-btn prev" onclick="lightboxNav(-1)" aria-label="Previous">
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
  </button>
  <div class="lightbox-content">
    <iframe id="lightboxFrame" src="" frameborder="0" scrolling="no"></iframe>
  </div>
  <button class="lb-nav-btn next" onclick="lightboxNav(1)" aria-label="Next">
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
  </button>
</div>

<!-- MASCOT -->
<div id="mascot" aria-hidden="true">
  <div class="eye left"></div><div class="eye right"></div>
  <div class="mouth"></div>
  <div class="blush left"></div><div class="blush right"></div>
</div>
<div id="mascotTip">Cari wallpaper favoritmu!</div>

<!-- TOAST CONTAINER -->
<div class="toast-container" id="toastContainer"></div>

{% raw %}
<script>
(function() {
  'use strict';

  /* ── Theme ── */
  var html = document.documentElement;
  var saved = localStorage.getItem('hw-theme');
  if (saved) html.setAttribute('data-theme', saved);
  else if (window.matchMedia('(prefers-color-scheme: dark)').matches) html.setAttribute('data-theme', 'dark');

  document.getElementById('themeToggle').addEventListener('click', function() {
    var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('hw-theme', next);
    showToast(next === 'dark' ? 'Dark mode!' : 'Light mode!', 'info');
  });

  /* ── Scroll Progress & Nav ── */
  var progressBar = document.getElementById('scrollProgress');
  var mainNav = document.getElementById('mainNav');
  var ticking = false;
  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(function() {
      var st = window.scrollY;
      var dh = document.documentElement.scrollHeight - window.innerHeight;
      progressBar.style.width = (dh > 0 ? (st / dh) * 100 : 0) + '%';
      mainNav.classList.toggle('scrolled', st > 50);
      ticking = false;
    });
  }
  window.addEventListener('scroll', onScroll, { passive: true });

  /* ── Data & Cards ── */
  var cards = Array.from(document.querySelectorAll('.wallpaper-card'));
  // Pre-populate data array based on DOM order
  var wallpaperData = cards.map(function(card) {
    var iframe = card.querySelector('.preview-area iframe');
    var nameEl = card.querySelector('h3');
    return {
      url: iframe ? iframe.src : '',
      name: card.dataset.name,
      fullName: nameEl ? nameEl.textContent.trim() : card.dataset.name
    };
  });

  /* ── Favorites ── */
  var FAV_KEY = 'hw_gallery_favs';
  var favorites = JSON.parse(localStorage.getItem(FAV_KEY) || '[]');

  function saveFavs() {
    localStorage.setItem(FAV_KEY, JSON.stringify(favorites));
    document.getElementById('favCount').textContent = favorites.length;
  }
  // Normalize check to lowercase
  function isFav(name) { 
    return favorites.indexOf(name.toLowerCase()) !== -1; 
  }

  function initFavs() {
    document.querySelectorAll('.fav-btn').forEach(function(btn) {
      if (isFav(btn.dataset.name)) btn.classList.add('active');
    });
    saveFavs();
  }

  window.toggleFav = function(name, btn) {
    name = name.toLowerCase(); // Ensure lowercase consistency
    if (isFav(name)) {
      favorites = favorites.filter(function(f) { return f !== name; });
      btn.classList.remove('active');
      showToast('Removed from favorites', 'info');
    } else {
      favorites.push(name);
      btn.classList.add('active');
      showToast('Added to favorites', 'success');
    }
    btn.classList.remove('bounce');
    void btn.offsetWidth; // Trigger reflow
    btn.classList.add('bounce');
    saveFavs();
    if (favFilterOn) applyFilters();
  };

  /* ── Filters ── */
  var searchTerm = '';
  var favFilterOn = false;
  
  document.getElementById('searchInput').addEventListener('input', function() {
    searchTerm = this.value.toLowerCase().trim();
    applyFilters();
  });
  
  document.getElementById('filterFavBtn').addEventListener('click', function() {
    favFilterOn = !favFilterOn;
    this.classList.toggle('active', favFilterOn);
    applyFilters();
  });

  window.clearFilters = function() {
    document.getElementById('searchInput').value = '';
    searchTerm = '';
    favFilterOn = false;
    document.getElementById('filterFavBtn').classList.remove('active');
    applyFilters();
  };

  function applyFilters() {
    var visible = cards.filter(function(c) {
      var matchSearch = c.dataset.name.indexOf(searchTerm) !== -1;
      var matchFav = !favFilterOn || isFav(c.dataset.name);
      return matchSearch && matchFav;
    });

    cards.forEach(function(c) { c.classList.add('hidden-by-filter'); });
    visible.forEach(function(c) { c.classList.remove('hidden-by-filter'); });

    var noResults = document.getElementById('noResults');
    noResults.style.display = visible.length > 0 ? 'none' : 'block';
  }

  /* ── View Toggle ── */
  var grid = document.getElementById('galleryGrid');
  document.getElementById('viewGrid').addEventListener('click', function() {
    grid.classList.remove('list-view');
    this.classList.add('active');
    document.getElementById('viewList').classList.remove('active');
  });
  document.getElementById('viewList').addEventListener('click', function() {
    grid.classList.add('list-view');
    this.classList.add('active');
    document.getElementById('viewGrid').classList.remove('active');
  });

  /* ── Lightbox ── */
  var currentIdx = -1;
  var lightbox = document.getElementById('lightbox');
  var frame = document.getElementById('lightboxFrame');
  var title = document.getElementById('lightboxTitle');

  function getVisibleCards() {
    return Array.from(document.querySelectorAll('.wallpaper-card:not(.hidden-by-filter)'));
  }

  window.openLightbox = function(idx) {
    var visible = getVisibleCards();
    // Find the card that has the data-index matching idx
    var target = visible.find(function(c) { return parseInt(c.dataset.index, 10) === idx; });
    
    // If not found (maybe filtered out?), default to the first visible or return
    if (!target) {
       if(visible.length > 0) target = visible[0];
       else return;
    }
    
    var vIdx = visible.indexOf(target);
    showLightbox(vIdx, visible);
  };

  function showLightbox(vIdx, visibleArr) {
    currentIdx = vIdx;
    var card = visibleArr[vIdx];
    var idx = parseInt(card.dataset.index, 10); // Retrieve original index
    
    // Use original index to get data from the master list
    frame.src = wallpaperData[idx].url;
    title.textContent = wallpaperData[idx].fullName;
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  window.lightboxNav = function(dir) {
    var visible = getVisibleCards();
    if (visible.length === 0) return;
    var next = currentIdx + dir;
    if (next < 0) next = visible.length - 1;
    if (next >= visible.length) next = 0;
    showLightbox(next, visible);
  };

  window.closeLightbox = function() {
    lightbox.classList.remove('active');
    frame.src = '';
    document.body.style.overflow = '';
  };

  window.closeLightboxOnBg = function(e) {
    if (e.target === lightbox) closeLightbox();
  };

  document.addEventListener('keydown', function(e) {
    if (!lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') lightboxNav(-1);
    if (e.key === 'ArrowRight') lightboxNav(1);
  });

  /* ── Copy Path ── */
  window.copyPath = function(path, el) {
    var doSuccess = function() {
      var icon = el.querySelector('.copy-icon');
      if(icon) icon.style.color = 'var(--green)';
      showToast('Copied: ' + path, 'success');
      setTimeout(function() { if(icon) icon.style.color = ''; }, 1500);
    };
    if (navigator.clipboard) {
      navigator.clipboard.writeText(path).then(doSuccess).catch(function() {
        var ta = document.createElement('textarea'); ta.value = path;
        document.body.appendChild(ta); ta.select(); document.execCommand('copy');
        document.body.removeChild(ta); doSuccess();
      });
    } else {
        // Fallback for older browsers
        var ta = document.createElement('textarea'); ta.value = path;
        document.body.appendChild(ta); ta.select(); document.execCommand('copy');
        document.body.removeChild(ta); doSuccess();
    }
  };

  /* ── Toast ── */
  window.showToast = function(msg, type) {
    var c = document.getElementById('toastContainer');
    var t = document.createElement('div');
    t.className = 'toast ' + (type || 'info');
    t.textContent = msg;
    c.appendChild(t);
    setTimeout(function() { if (t.parentNode) t.remove(); }, 2600);
  };

  /* ── Reveal Animation ── */
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal, .wallpaper-card').forEach(function(el) { obs.observe(el); });

  /* ── Mascot ── */
  var mascot = document.getElementById('mascot');
  var tip = document.getElementById('mascotTip');
  var msgs = ['Cari wallpaper favoritmu!','Klik hati ya!','Zero CPU lho!','Coba dark mode!'];
  var mIdx = 0;

  function showTip() {
    tip.textContent = msgs[mIdx % msgs.length]; mIdx++;
    tip.classList.add('show');
    setTimeout(function() { tip.classList.remove('show'); }, 3000);
  }

  if (mascot) {
    mascot.addEventListener('click', function() {
      mascot.classList.remove('bounce'); void mascot.offsetWidth; mascot.classList.add('bounce');
      showTip();
    });
    setTimeout(showTip, 2000);
  }

  initFavs();
})();
</script>
{% endraw %}
