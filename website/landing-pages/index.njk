      <div class="stat-val">{{ wallpapers | length }}</div>
      <div class="stat-lbl">Wallpapers</div>
    </div>
    <div class="stat-card-lg">
      <div class="stat-val" id="favCount">0</div>
      <div class="stat-lbl">Favorites</div>
    </div>
