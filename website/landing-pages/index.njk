{% raw %}
<style>
  /* ═══════════════════════════════════════════════════════════════
     CSS CUSTOM PROPERTIES - Design Tokens
     ═══════════════════════════════════════════════════════════════ */
  :root {
    --bg: #FEF8F0;
    --bg-alt: #FFF5E6;
    --bg-warm: #FFECD2;
    --bg-dot: #F5E1C8;
    
    --card: #FFFFFF;
    --card-alt: #FFFCF7;
    --card-border: #E8D5B8;
    --card-border-hover: #E8A85C;
    --card-shadow: rgba(61, 44, 30, 0.06);
    
    --text: #2D1810;
    --text-soft: #4A3228;
    --text-muted: #7A5D4A;
    --text-light: #A08570;
    --text-faint: #C4A88A;
    
    --primary: #FF6B35;
    --primary-hover: #E85A24;
    --primary-light: rgba(255, 107, 53, 0.12);
    --primary-pale: rgba(255, 107, 53, 0.06);
    
    --secondary: #00B4A0;
    --secondary-hover: #009688;
    --secondary-light: rgba(0, 180, 160, 0.12);
    
    --tertiary: #7C4DFF;
    --tertiary-light: rgba(124, 77, 255, 0.12);
    
    --accent: #FFB300;
    --accent-light: rgba(255, 179, 0, 0.12);
    --accent-dark: #E65100;
    
    --coral: #FF7043;
    --coral-light: rgba(255, 112, 67, 0.12);
    --mint: #4DB6AC;
    --mint-light: rgba(77, 182, 172, 0.12);
    --lavender: #B388FF;
    --lavender-light: rgba(179, 136, 255, 0.12);
    --rose: #F06292;
    --rose-light: rgba(240, 98, 146, 0.12);
    --sky: #42A5F5;
    --sky-light: rgba(66, 165, 245, 0.12);
    --lime: #9CCC65;
    --lime-light: rgba(156, 204, 101, 0.12);
    --amber: #FFCA28;
    --amber-light: rgba(255, 202, 40, 0.12);
    
    --success: #66BB6A;
    --success-light: rgba(102, 187, 106, 0.12);
    --warning: #FFA726;
    --warning-light: rgba(255, 167, 38, 0.12);
    --info: #29B6F6;
    --info-light: rgba(41, 182, 246, 0.12);
    
    --shadow-xs: 0 2px 6px var(--card-shadow);
    --shadow-sm: 0 4px 12px var(--card-shadow);
    --shadow-md: 0 6px 20px var(--card-shadow);
    --shadow-lg: 0 12px 40px var(--card-shadow);
    --shadow-xl: 0 20px 60px var(--card-shadow);
    
    --shadow-card: 0 4px 0 0 var(--card-border), 0 6px 20px var(--card-shadow);
    --shadow-card-hover: 0 4px 0 0 var(--card-border-hover), 0 10px 30px rgba(255, 107, 53, 0.12);
    --shadow-button: 0 3px 0 0 var(--text), 0 4px 12px var(--card-shadow);
    
    --radius-xs: 0.375rem;
    --radius-sm: 0.625rem;
    --radius-md: 0.875rem;
    --radius-lg: 1.25rem;
    --radius-xl: 1.75rem;
    --radius-2xl: 2.25rem;
    --radius-full: 9999px;
    
    --space-xs: 0.25rem;
    --space-sm: 0.5rem;
    --space-md: 1rem;
    --space-lg: 1.5rem;
    --space-xl: 2rem;
    --space-2xl: 3rem;
    --space-3xl: 4rem;
    --space-4xl: 6rem;
    
    --font-display: 'Fredoka', sans-serif;
    --font-body: 'Nunito', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
    
    --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
    --ease-in-out: cubic-bezier(0.4, 0, 0.2, 1);
    --bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);
    --spring: cubic-bezier(0.175, 0.885, 0.32, 1.275);
    
    --duration-fast: 150ms;
    --duration-normal: 250ms;
    --duration-slow: 400ms;
    --duration-slower: 600ms;
    
    --nav-height: 72px;
    --container-max: 1200px;
    --container-narrow: 800px;
  }

  [data-theme="dark"] {
    --bg: #0F0D12;
    --bg-alt: #161318;
    --bg-warm: #1A161D;
    --bg-dot: #201D24;
    
    --card: #1C1920;
    --card-alt: #221E26;
    --card-border: #3A3542;
    --card-border-hover: #FF8A65;
    --card-shadow: rgba(0, 0, 0, 0.35);
    
    --text: #F5F0E8;
    --text-soft: #DED5C8;
    --text-muted: #9E918A;
    --text-light: #6E635C;
    --text-faint: #4A4340;
    
    --primary: #FF8A65;
    --primary-hover: #FFAB91;
    --primary-light: rgba(255, 138, 101, 0.14);
    --primary-pale: rgba(255, 138, 101, 0.06);
    
    --secondary: #4DD0C4;
    --secondary-light: rgba(77, 208, 196, 0.14);
    
    --tertiary: #B388FF;
    --tertiary-light: rgba(179, 136, 255, 0.14);
    
    --shadow-card: 0 4px 0 0 var(--card-border), 0 6px 24px var(--card-shadow);
    --shadow-card-hover: 0 4px 0 0 var(--card-border-hover), 0 10px 35px rgba(255, 138, 101, 0.14);
  }

  /* ═══════════════════════════════════════════════════════════════
     BASE RESET & TYPOGRAPHY
     ═══════════════════════════════════════════════════════════════ */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.7;
    background: var(--bg);
    color: var(--text);
    overflow-x: hidden;
    transition: background-color var(--duration-slow) var(--ease-in-out), color var(--duration-slow) var(--ease-in-out);
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: radial-gradient(var(--bg-dot) 1.2px, transparent 1.2px);
    background-size: 28px 28px;
    opacity: 0.5;
    transition: opacity var(--duration-slow);
  }

  [data-theme="dark"] body::before {
    opacity: 0.25;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-display);
    font-weight: 600;
    line-height: 1.25;
    color: var(--text);
  }

  h1 { font-size: clamp(2.25rem, 6vw, 4rem); font-weight: 700; }
  h2 { font-size: clamp(1.75rem, 4vw, 2.75rem); }
  h3 { font-size: clamp(1.25rem, 2.5vw, 1.5rem); }
  h4 { font-size: 1.125rem; }

  p { color: var(--text-muted); }

  a {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  button {
    font-family: inherit;
    cursor: pointer;
    border: none;
    background: transparent;
  }

  code, pre {
    font-family: var(--font-mono);
  }

  ::selection {
    background: var(--primary);
    color: #fff;
  }

  :focus-visible {
    outline: 3px solid var(--primary);
    outline-offset: 3px;
    border-radius: var(--radius-xs);
  }

  .skip-link {
    position: fixed;
    top: -100px;
    left: var(--space-md);
    z-index: 99999;
    padding: var(--space-sm) var(--space-md);
    background: var(--primary);
    color: #fff;
    font-weight: 700;
    border-radius: var(--radius-sm);
    transition: top var(--duration-normal);
  }

  .skip-link:focus {
    top: var(--space-md);
  }

  /* ═══════════════════════════════════════════════════════════════
     UTILITY CLASSES
     ═══════════════════════════════════════════════════════════════ */
  .container {
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .container-narrow {
    max-width: var(--container-narrow);
  }

  .text-center { text-align: center; }
  .text-left { text-align: left; }
  .text-right { text-align: right; }

  .flex { display: flex; }
  .flex-col { flex-direction: column; }
  .items-center { align-items: center; }
  .justify-center { justify-content: center; }
  .justify-between { justify-content: space-between; }
  .gap-sm { gap: var(--space-sm); }
  .gap-md { gap: var(--space-md); }
  .gap-lg { gap: var(--space-lg); }

  .grid { display: grid; }

  .section {
    position: relative;
    padding: var(--space-4xl) 0;
    z-index: 1;
  }

  /* ═══════════════════════════════════════════════════════════════
     SCROLL PROGRESS
     ═══════════════════════════════════════════════════════════════ */
  #scrollProgress {
    position: fixed;
    top: 0;
    left: 0;
    height: 4px;
    z-index: 10001;
    background: linear-gradient(90deg, var(--primary), var(--secondary), var(--tertiary), var(--accent), var(--primary));
    background-size: 400% 100%;
    animation: progressGradient 6s linear infinite;
    width: 0%;
    transition: width 80ms linear;
  }

  @keyframes progressGradient {
    to { background-position: 400% 0; }
  }

  /* ═══════════════════════════════════════════════════════════════
     NAVIGATION
     ═══════════════════════════════════════════════════════════════ */
  #mainNav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--nav-height);
    z-index: 10000;
    background: rgba(254, 248, 240, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 2px solid var(--card-border);
    transition: background-color var(--duration-normal), border-color var(--duration-normal), box-shadow var(--duration-normal);
  }

  [data-theme="dark"] #mainNav {
    background: rgba(15, 13, 18, 0.88);
  }

  #mainNav.scrolled {
    background: var(--bg);
    box-shadow: var(--shadow-sm);
  }

  .nav-inner {
    max-width: var(--container-max);
    height: 100%;
    margin: 0 auto;
    padding: 0 var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--text);
    transition: color var(--duration-fast);
  }

  .nav-logo:hover {
    color: var(--primary);
  }

  .nav-logo-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, var(--primary), var(--coral));
    border: 2.5px solid var(--text);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 3px 3px 0 var(--text);
    transition: transform var(--duration-normal) var(--bounce);
    flex-shrink: 0;
  }

  .nav-logo:hover .nav-logo-icon {
    transform: rotate(-8deg) scale(1.08);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .nav-links a {
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-muted);
    transition: all var(--duration-fast);
    border: 2px solid transparent;
  }

  .nav-links a:hover {
    color: var(--primary);
    background: var(--primary-light);
  }

  .nav-cta {
    padding: var(--space-sm) var(--space-lg) !important;
    background: var(--primary) !important;
    color: #fff !important;
    border: 2.5px solid var(--text) !important;
    border-radius: var(--radius-sm) !important;
    box-shadow: 3px 3px 0 var(--text);
    transition: all var(--duration-normal) var(--bounce) !important;
  }

  .nav-cta:hover {
    background: var(--primary-hover) !important;
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--text) !important;
  }

  .theme-toggle {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    background: var(--card);
    border: 2px solid var(--card-border);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--duration-normal) var(--bounce);
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    transform: scale(1.08) rotate(8deg);
    border-color: var(--accent);
  }

  .theme-toggle .icon-sun,
  .theme-toggle .icon-moon {
    position: absolute;
    transition: all var(--duration-slow) var(--bounce);
  }

  .theme-toggle .icon-sun {
    opacity: 1;
    transform: scale(1) rotate(0deg);
    color: var(--accent);
  }

  .theme-toggle .icon-moon {
    opacity: 0;
    transform: scale(0.4) rotate(-90deg);
    color: var(--lavender);
  }

  [data-theme="dark"] .theme-toggle .icon-sun {
    opacity: 0;
    transform: scale(0.4) rotate(90deg);
  }

  [data-theme="dark"] .theme-toggle .icon-moon {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  .hamburger {
    display: none;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    background: var(--card);
    border: 2px solid var(--card-border);
    cursor: pointer;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    flex-shrink: 0;
    transition: all var(--duration-normal);
  }

  .hamburger:hover {
    border-color: var(--primary);
  }

  .hamburger span {
    display: block;
    width: 20px;
    height: 2.5px;
    background: var(--text);
    border-radius: 2px;
    transition: all var(--duration-normal);
    transform-origin: center;
  }

  .hamburger.open span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .hamburger.open span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .hamburger.open span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: var(--nav-height);
    left: 0;
    right: 0;
    background: var(--bg);
    border-bottom: 3px solid var(--card-border);
    padding: var(--space-md);
    z-index: 9999;
    box-shadow: var(--shadow-lg);
    transform: translateY(-12px);
    opacity: 0;
    pointer-events: none;
    transition: all var(--duration-normal) var(--bounce);
  }

  .mobile-menu.open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu a {
    display: block;
    padding: var(--space-md);
    border-radius: var(--radius-sm);
    font-weight: 700;
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: var(--space-xs);
    transition: all var(--duration-fast);
  }

  .mobile-menu a:hover {
    background: var(--primary-light);
    color: var(--primary);
  }

  .mobile-menu a.mobile-cta {
    background: var(--primary);
    color: #fff;
    text-align: center;
    margin-top: var(--space-sm);
  }

  @media (max-width: 900px) {
    .nav-links { display: none !important; }
    .hamburger { display: flex; }
    .mobile-menu { display: block; }
  }

  /* ═══════════════════════════════════════════════════════════════
     DECORATIVE ELEMENTS
     ═══════════════════════════════════════════════════════════════ */
  .deco {
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }

  .deco-cloud {
    width: 90px;
    height: 45px;
    background: var(--card);
    border-radius: 45px;
    border: 2.5px solid var(--card-border);
    box-shadow: 4px 4px 0 var(--card-border);
    animation: floatCloud 10s ease-in-out infinite;
    transition: background var(--duration-slow), border-color var(--duration-slow);
  }

  .deco-cloud::before,
  .deco-cloud::after {
    content: '';
    position: absolute;
    background: var(--card);
    border: 2.5px solid var(--card-border);
    border-bottom-color: transparent;
  }

  .deco-cloud::before {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    top: -22px;
    left: 16px;
  }

  .deco-cloud::after {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    top: -14px;
    left: 46px;
  }

  @keyframes floatCloud {
    0%, 100% { transform: translateY(0) translateX(0); }
    50% { transform: translateY(-15px) translateX(10px); }
  }

  .deco-star {
    width: 20px;
    height: 20px;
    background: var(--accent);
    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
    animation: twinkle 3.5s ease-in-out infinite;
  }

  @keyframes twinkle {
    0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.75; }
    50% { transform: scale(1.25) rotate(12deg); opacity: 1; }
  }

  .deco-heart {
    width: 18px;
    height: 16px;
    background: var(--rose);
    transform: rotate(-45deg);
    border-radius: 0 50% 0 50%;
    animation: floatHeart 4.5s ease-in-out infinite;
  }

  .deco-heart::before,
  .deco-heart::after {
    content: '';
    position: absolute;
    background: var(--rose);
  }

  .deco-heart::before {
    width: 18px;
    height: 16px;
    border-radius: 50% 50% 0 0;
    top: -8px;
    left: 0;
  }

  @keyframes floatHeart {
    0%, 100% { transform: rotate(-45deg) translateY(0) scale(1); }
    50% { transform: rotate(-45deg) translateY(-10px) scale(1.12); }
  }

  .deco-bubble {
    border-radius: 50%;
    border: 2px solid var(--card-border);
    animation: floatBubble 6s ease-in-out infinite;
    transition: border-color var(--duration-slow);
  }

  @keyframes floatBubble {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-20px) scale(1.05); }
  }

  .deco-sparkle {
    width: 14px;
    height: 14px;
    background: var(--accent);
    clip-path: polygon(50% 0%, 55% 40%, 100% 50%, 55% 60%, 50% 100%, 45% 60%, 0% 50%, 45% 40%);
    animation: sparklePulse 2s ease-in-out infinite;
  }

  @keyframes sparklePulse {
    0%, 100% { transform: scale(1) rotate(0deg); }
    50% { transform: scale(1.4) rotate(45deg); }
  }

  .deco-triangle {
    width: 0;
    height: 0;
    border-left: 12px solid transparent;
    border-right: 12px solid transparent;
    border-bottom: 20px solid var(--mint);
    animation: floatTriangle 5s ease-in-out infinite;
  }

  @keyframes floatTriangle {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-12px) rotate(10deg); }
  }

  .deco-diamond {
    width: 16px;
    height: 16px;
    background: var(--lavender);
    transform: rotate(45deg);
    animation: floatDiamond 4s ease-in-out infinite;
  }

  @keyframes floatDiamond {
    0%, 100% { transform: rotate(45deg) translateY(0); }
    50% { transform: rotate(45deg) translateY(-8px); }
  }

  /* ═══════════════════════════════════════════════════════════════
     REVEAL ANIMATIONS
     ═══════════════════════════════════════════════════════════════ */
  .reveal {
    opacity: 0;
    transform: translateY(35px) scale(0.96);
    transition: opacity var(--duration-slower) var(--ease-out), transform var(--duration-slower) var(--ease-out);
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .reveal.d-1 { transition-delay: 80ms; }
  .reveal.d-2 { transition-delay: 160ms; }
  .reveal.d-3 { transition-delay: 240ms; }
  .reveal.d-4 { transition-delay: 320ms; }
  .reveal.d-5 { transition-delay: 400ms; }
  .reveal.d-6 { transition-delay: 480ms; }
  .reveal.d-7 { transition-delay: 560ms; }
  .reveal.d-8 { transition-delay: 640ms; }

  /* ═══════════════════════════════════════════════════════════════
     BUTTONS
     ═══════════════════════════════════════════════════════════════ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-xl);
    border-radius: var(--radius-md);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    border: 2.5px solid var(--text);
    transition: all var(--duration-normal) var(--bounce);
    position: relative;
    overflow: hidden;
    white-space: nowrap;
  }

  .btn:active {
    transform: scale(0.96) !important;
  }

  .btn-primary {
    background: var(--primary);
    color: #fff;
    box-shadow: 4px 4px 0 var(--text);
  }

  .btn-primary:hover {
    background: var(--primary-hover);
    transform: translateY(-3px);
    box-shadow: 6px 6px 0 var(--text);
  }

  .btn-secondary {
    background: var(--card);
    color: var(--text);
    box-shadow: 4px 4px 0 var(--card-border);
    transition: all var(--duration-normal) var(--bounce), background var(--duration-slow), color var(--duration-slow);
  }

  .btn-secondary:hover {
    transform: translateY(-3px);
    box-shadow: 6px 6px 0 var(--card-border-hover);
    border-color: var(--primary);
    color: var(--primary);
  }

  .btn-sm {
    padding: var(--space-sm) var(--space-md);
    font-size: 0.875rem;
  }

  .btn-lg {
    padding: var(--space-lg) var(--space-2xl);
    font-size: 1.125rem;
  }

  /* ═══════════════════════════════════════════════════════════════
     BADGES & LABELS
     ═══════════════════════════════════════════════════════════════ */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-xs);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid;
    transition: all var(--duration-slow);
  }

  .badge-primary {
    color: var(--primary);
    background: var(--primary-light);
    border-color: var(--primary);
  }

  .badge-secondary {
    color: var(--secondary);
    background: var(--secondary-light);
    border-color: var(--secondary);
  }

  .badge-tertiary {
    color: var(--tertiary);
    background: var(--tertiary-light);
    border-color: var(--tertiary);
  }

  .badge-accent {
    color: var(--accent-dark);
    background: var(--accent-light);
    border-color: var(--accent);
  }

  .badge-rose {
    color: var(--rose);
    background: var(--rose-light);
    border-color: var(--rose);
  }

  .badge-mint {
    color: var(--mint);
    background: var(--mint-light);
    border-color: var(--mint);
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border: 2px solid;
    margin-bottom: var(--space-md);
    transition: all var(--duration-slow);
  }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--success);
    border: 2px solid var(--text);
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(102, 187, 106, 0.4); }
    50% { transform: scale(1.15); box-shadow: 0 0 0 6px rgba(102, 187, 106, 0); }
  }

  /* ═══════════════════════════════════════════════════════════════
     HERO SECTION
     ═══════════════════════════════════════════════════════════════ */
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc(var(--nav-height) + var(--space-2xl)) var(--space-lg) var(--space-4xl);
    overflow: hidden;
  }

  .hero-blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(100px);
    opacity: 0.35;
    transition: background var(--duration-slow);
  }

  .hero-blob-1 {
    width: 600px;
    height: 600px;
    background: var(--primary);
    top: -15%;
    right: -10%;
  }

  .hero-blob-2 {
    width: 500px;
    height: 500px;
    background: var(--secondary);
    bottom: -10%;
    left: -8%;
  }

  .hero-blob-3 {
    width: 300px;
    height: 300px;
    background: var(--tertiary);
    top: 45%;
    left: 55%;
    opacity: 0.2;
  }

  .hero-blob-4 {
    width: 200px;
    height: 200px;
    background: var(--accent);
    bottom: 20%;
    right: 20%;
    opacity: 0.25;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-full);
    background: var(--card);
    border: 2.5px solid var(--card-border);
    box-shadow: 3px 3px 0 var(--card-border);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-muted);
    margin-bottom: var(--space-xl);
    transition: all var(--duration-slow);
  }

  .hero-title {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: var(--space-md);
    line-height: 1.1;
    transition: color var(--duration-slow);
  }

  .hero-title-accent {
    color: var(--primary);
    position: relative;
    display: inline-block;
    transition: color var(--duration-slow);
  }

  .hero-title-accent::after {
    content: '';
    position: absolute;
    bottom: 0.1em;
    left: 0;
    right: 0;
    height: 0.18em;
    background: var(--primary-light);
    border-radius: var(--radius-full);
    z-index: -1;
    transition: background var(--duration-slow);
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--text-muted);
    line-height: 1.8;
    max-width: 600px;
    margin: 0 auto var(--space-2xl);
    transition: color var(--duration-slow);
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    justify-content: center;
    margin-bottom: var(--space-lg);
  }

  .hero-hint {
    font-size: 0.8rem;
    color: var(--text-light);
    font-weight: 600;
    transition: color var(--duration-slow);
  }

  .hero-hint kbd {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    background: var(--card);
    border: 2px solid var(--card-border);
    border-radius: var(--radius-xs);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    box-shadow: 2px 2px 0 var(--card-border);
    color: var(--text-muted);
    margin: 0 0.15rem;
  }

  .preview-window {
    position: absolute;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 3px solid var(--card-border);
    box-shadow: 6px 6px 0 var(--card-border);
    transition: transform var(--duration-slow) var(--bounce), border-color var(--duration-slow);
    backdrop-filter: blur(4px);
  }

  .preview-window:hover {
    transform: rotate(0deg) scale(1.05) !important;
    border-color: var(--primary);
  }

  .pw-titlebar {
    height: 26px;
    background: rgba(0, 0, 0, 0.04);
    border-bottom: 2px solid var(--card-border);
    display: flex;
    align-items: center;
    padding: 0 var(--space-sm);
    gap: 4px;
    transition: background var(--duration-slow), border-color var(--duration-slow);
  }

  [data-theme="dark"] .pw-titlebar {
    background: rgba(0, 0, 0, 0.25);
  }

  .pw-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid var(--text);
    flex-shrink: 0;
  }

  .pw-dot.close { background: #EF5350; }
  .pw-dot.minimize { background: #FFCA28; }
  .pw-dot.maximize { background: #66BB6A; }

  .pw-content {
    transition: background var(--duration-slow);
  }

  .scroll-indicator {
    position: absolute;
    bottom: var(--space-2xl);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    animation: scrollBounce 2.5s ease-in-out infinite;
    color: var(--text-light);
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 1; }
    50% { transform: translateX(-50%) translateY(12px); opacity: 0.5; }
  }

  /* ═══════════════════════════════════════════════════════════════
     CAROUSEL
     ═══════════════════════════════════════════════════════════════ */
  .carousel-wrapper {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 3px solid var(--card-border);
    box-shadow: 6px 6px 0 var(--card-border);
    background: var(--card);
    transition: all var(--duration-slow);
  }

  .carousel-wrapper:hover {
    border-color: var(--card-border-hover);
  }

  .carousel-viewport {
    overflow: hidden;
    position: relative;
    aspect-ratio: 16/9;
    background: var(--bg-alt);
    transition: background var(--duration-slow);
  }

  .carousel-track {
    display: flex;
    height: 100%;
    transition: transform var(--duration-slow) var(--bounce);
  }

  .carousel-slide {
    min-width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-controls {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-md);
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 5;
  }

  .carousel-controls::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.35), transparent);
    pointer-events: none;
    z-index: -1;
  }

  .carousel-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--card);
    border: 2.5px solid var(--text);
    box-shadow: 2px 2px 0 var(--text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
    transition: all var(--duration-fast) var(--bounce);
    flex-shrink: 0;
  }

  .carousel-btn:hover {
    transform: scale(1.1);
    box-shadow: 3px 3px 0 var(--text);
    border-color: var(--primary);
    color: var(--primary);
  }

  .carousel-dots {
    display: flex;
    gap: 6px;
  }

  .carousel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.25);
    border: 2px solid rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: all var(--duration-normal) var(--bounce);
  }

  .carousel-dot.active {
    background: var(--primary);
    border-color: #fff;
    transform: scale(1.3);
  }

  .carousel-dot:hover:not(.active) {
    transform: scale(1.15);
    background: rgba(255, 255, 255, 0.5);
  }

  /* ═══════════════════════════════════════════════════════════════
     FEATURE CARDS
     ═══════════════════════════════════════════════════════════════ */
  .feature-card {
    background: var(--card);
    border: 2.5px solid var(--card-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-card);
    transition: all var(--duration-normal);
    position: relative;
    overflow: hidden;
    cursor: default;
  }

  .feature-card:hover {
    border-color: var(--card-border-hover);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-5px);
  }

  .feature-icon {
    width: 60px;
    height: 60px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2.5px solid;
    margin-bottom: var(--space-lg);
    box-shadow: 4px 4px 0 currentColor;
    flex-shrink: 0;
    transition: all var(--duration-slow);
  }

  .fc-primary {
    background: var(--primary-light);
    border-color: var(--primary);
    color: var(--primary);
  }

  .fc-secondary {
    background: var(--secondary-light);
    border-color: var(--secondary);
    color: var(--secondary);
  }

  .fc-tertiary {
    background: var(--tertiary-light);
    border-color: var(--tertiary);
    color: var(--tertiary);
  }

  .fc-accent {
    background: var(--accent-light);
    border-color: var(--accent-dark);
    color: var(--accent-dark);
  }

  .fc-rose {
    background: var(--rose-light);
    border-color: var(--rose);
    color: var(--rose);
  }

  .fc-sky {
    background: var(--sky-light);
    border-color: var(--sky);
    color: var(--sky);
  }

  .fc-mint {
    background: var(--mint-light);
    border-color: var(--mint);
    color: var(--mint);
  }

  .fc-lavender {
    background: var(--lavender-light);
    border-color: var(--lavender);
    color: var(--lavender);
  }

  .fc-lime {
    background: var(--lime-light);
    border-color: var(--lime);
    color: var(--lime);
  }

  .feature-card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
    color: var(--text);
    transition: color var(--duration-slow);
  }

  .feature-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
    transition: color var(--duration-slow);
  }

  /* ═══════════════════════════════════════════════════════════════
     STATS SECTION
     ═══════════════════════════════════════════════════════════════ */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .stat-item {
    text-align: center;
    padding: var(--space-md);
    background: var(--card);
    border: 2px solid var(--card-border);
    border-radius: var(--radius-md);
    transition: all var(--duration-normal);
  }

  .stat-item:hover {
    transform: translateY(-3px);
    border-color: var(--card-border-hover);
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  /* ═══════════════════════════════════════════════════════════════
     CATEGORY CARDS
     ═══════════════════════════════════════════════════════════════ */
  .category-card {
    background: var(--card);
    border: 2.5px solid var(--card-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: all var(--duration-normal);
    cursor: pointer;
  }

  .category-card:hover {
    border-color: var(--card-border-hover);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-5px);
  }

  .category-preview {
    aspect-ratio: 16/10;
    background: var(--bg-alt);
    position: relative;
    overflow: hidden;
  }

  .category-info {
    padding: var(--space-lg);
  }

  .category-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--text);
    margin-bottom: var(--space-xs);
  }

  .category-count {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  /* ═══════════════════════════════════════════════════════════════
     COMPARISON SLIDER
     ═══════════════════════════════════════════════════════════════ */
  .comparison-container {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    border: 3px solid var(--card-border);
    box-shadow: 6px 6px 0 var(--card-border);
    cursor: col-resize;
    user-select: none;
    aspect-ratio: 16/9;
    transition: border-color var(--duration-slow);
  }

  .comparison-container:hover {
    border-color: var(--card-border-hover);
  }

  .comp-layer {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .comp-slider-line {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--primary);
    z-index: 10;
    box-shadow: 0 0 0 3px var(--text);
    transition: background var(--duration-slow);
  }

  .comp-handle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--primary);
    border: 3px solid var(--text);
    box-shadow: 3px 3px 0 var(--text);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: background var(--duration-slow);
  }

  .comp-label {
    position: absolute;
    top: var(--space-md);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 2px solid var(--text);
    box-shadow: 2px 2px 0 var(--text);
    z-index: 5;
    transition: background var(--duration-slow);
  }

  .comp-label-before {
    left: var(--space-md);
    background: var(--bg-alt);
    color: var(--text-muted);
  }

  .comp-label-after {
    right: var(--space-md);
    background: var(--primary);
    color: #fff;
  }

  /* ═══════════════════════════════════════════════════════════════
     INSTALLATION STEPS
     ═══════════════════════════════════════════════════════════════ */
  .steps-container {
    position: relative;
  }

  .step-item {
    margin-bottom: var(--space-md);
  }

  .step-number {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.3rem;
    background: var(--card);
    border: 3px solid var(--card-border);
    color: var(--text-muted);
    box-shadow: 4px 4px 0 var(--card-border);
    transition: all var(--duration-slow) var(--bounce);
    flex-shrink: 0;
  }

  .step-item.active .step-number {
    background: var(--primary);
    border-color: var(--text);
    color: #fff;
    box-shadow: 4px 4px 0 var(--text);
  }

  .step-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.15rem;
    color: var(--text);
    margin-bottom: var(--space-xs);
    transition: color var(--duration-slow);
  }

  .step-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: var(--space-md);
    transition: color var(--duration-slow);
  }

  .code-block {
    background: #1A1A2E;
    border: 2.5px solid var(--card-border);
    border-radius: var(--radius-sm);
    padding: var(--space-md) var(--space-lg);
    font-size: 0.85rem;
    color: #A5D6FF;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    box-shadow: 3px 3px 0 var(--card-border);
    transition: border-color var(--duration-fast);
    overflow-x: auto;
  }

  .code-block:hover {
    border-color: var(--primary);
  }

  .code-block code {
    font-family: var(--font-mono);
  }

  .code-keyword { color: #FF79C6; font-weight: 600; }
  .code-string { color: #F1FA8C; }
  .code-func { color: #8BE9FD; }
  .code-comment { color: #6272A4; font-style: italic; }

  .copy-btn {
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-xs);
    background: var(--card);
    border: 2px solid var(--card-border);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 800;
    font-family: var(--font-body);
    cursor: pointer;
    transition: all var(--duration-fast) var(--bounce);
    box-shadow: 2px 2px 0 var(--card-border);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .copy-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
    transform: translate(-1px, -1px);
  }

  .copy-btn.copied {
    background: var(--success-light);
    border-color: var(--success);
    color: var(--success);
  }

  /* ═══════════════════════════════════════════════════════════════
     FAQ SECTION
     ═══════════════════════════════════════════════════════════════ */
  .faq-item {
    border: 2.5px solid var(--card-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--card);
    box-shadow: 4px 4px 0 var(--card-border);
    transition: all var(--duration-normal) var(--bounce);
    cursor: pointer;
    margin-bottom: var(--space-md);
  }

  .faq-item:hover {
    border-color: var(--card-border-hover);
  }

  .faq-item.open {
    border-color: var(--primary);
    box-shadow: 4px 4px 0 var(--primary);
  }

  .faq-question {
    padding: var(--space-lg);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--text);
    transition: color var(--duration-fast);
    gap: var(--space-md);
  }

  .faq-item.open .faq-question {
    color: var(--primary);
  }

  .faq-chevron {
    transition: transform var(--duration-slow) var(--bounce);
    color: var(--text-light);
    flex-shrink: 0;
  }

  .faq-item.open .faq-chevron {
    transform: rotate(180deg);
    color: var(--primary);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--duration-slow) var(--ease-out), padding var(--duration-normal);
    padding: 0 var(--space-lg);
    cursor: default;
  }

  .faq-item.open .faq-answer {
    max-height: 400px;
    padding: 0 var(--space-lg) var(--space-lg);
  }

  .faq-answer p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.8;
  }

  .faq-answer code {
    background: var(--primary-light);
    color: var(--primary);
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-xs);
    font-size: 0.85rem;
    font-weight: 600;
    border: 1.5px solid var(--primary);
  }

  .faq-answer ul {
    margin: var(--space-sm) 0;
    padding-left: var(--space-lg);
  }

  .faq-answer li {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: var(--space-xs);
  }

  /* ═══════════════════════════════════════════════════════════════
     CTA SECTION
     ═══════════════════════════════════════════════════════════════ */
  .cta-section {
    position: relative;
    overflow: hidden;
    padding: var(--space-4xl) var(--space-lg);
    background: var(--bg-alt);
    border-top: 3px solid var(--card-border);
    transition: background var(--duration-slow), border-color var(--duration-slow);
  }

  .cta-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--primary-light);
    border: 3px solid var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-lg);
    box-shadow: 4px 4px 0 var(--primary);
  }

  .cta-section h2 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: var(--space-md);
    transition: color var(--duration-slow);
  }

  .cta-section p {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: var(--space-xl);
    transition: color var(--duration-slow);
  }

  /* ═══════════════════════════════════════════════════════════════
     FOOTER
     ═══════════════════════════════════════════════════════════════ */
  .site-footer {
    border-top: 3px solid var(--card-border);
    padding: var(--space-xl) var(--space-lg);
    background: var(--bg);
    transition: background var(--duration-slow), border-color var(--duration-slow);
  }

  .footer-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .footer-logo-icon {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-xs);
    background: var(--primary);
    border: 2px solid var(--text);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 2px 2px 0 var(--text);
  }

  .footer-logo span {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .footer-links {
    display: flex;
    gap: var(--space-lg);
  }

  .footer-links a {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-light);
    transition: color var(--duration-fast);
  }

  .footer-links a:hover {
    color: var(--primary);
  }

  .footer-copy {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-light);
  }

  /* ═══════════════════════════════════════════════════════════════
     BACK TO TOP BUTTON
     ═══════════════════════════════════════════════════════════════ */
  #backToTop {
    position: fixed;
    bottom: var(--space-lg);
    right: var(--space-lg);
    z-index: 9990;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--primary);
    border: 2.5px solid var(--text);
    box-shadow: 3px 3px 0 var(--text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: all var(--duration-normal) var(--bounce), background var(--duration-slow);
    opacity: 0;
    transform: translateY(20px) scale(0.85);
    pointer-events: none;
  }

  #backToTop.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  #backToTop:hover {
    transform: translateY(-4px) scale(1.1);
    box-shadow: 5px 5px 0 var(--text);
  }

  /* ═══════════════════════════════════════════════════════════════
     TOAST NOTIFICATIONS
     ═══════════════════════════════════════════════════════════════ */
  .toast-container {
    position: fixed;
    bottom: 6rem;
    right: var(--space-lg);
    z-index: 99999;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    pointer-events: none;
  }

  .toast {
    pointer-events: auto;
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 700;
    border: 2.5px solid var(--text);
    box-shadow: 3px 3px 0 var(--text);
    animation: toastIn 0.4s var(--bounce), toastOut 0.3s ease 2.2s forwards;
  }

  .toast.success {
    background: var(--success);
    color: #fff;
    border-color: #2E7D32;
    box-shadow: 3px 3px 0 #2E7D32;
  }

  .toast.info {
    background: var(--info);
    color: #fff;
    border-color: #0288D1;
    box-shadow: 3px 3px 0 #0288D1;
  }

  @keyframes toastIn {
    from { opacity: 0; transform: translateY(1rem) scale(0.9); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes toastOut {
    to { opacity: 0; transform: translateY(-0.5rem) scale(0.9); }
  }

  /* ═══════════════════════════════════════════════════════════════
     MASCOT
     ═══════════════════════════════════════════════════════════════ */
  #mascot {
    position: fixed;
    bottom: var(--space-lg);
    left: var(--space-lg);
    z-index: 9989;
    width: 60px;
    height: 60px;
    border-radius: 50% 50% 50% 45%;
    background: var(--primary);
    border: 3px solid var(--text);
    box-shadow: 4px 4px 0 var(--text);
    cursor: pointer;
    overflow: hidden;
    transition: transform var(--duration-slow) var(--bounce), background var(--duration-slow);
  }

  #mascot:hover {
    transform: scale(1.15) rotate(-5deg);
  }

  #mascot .eye {
    position: absolute;
    width: 9px;
    height: 11px;
    background: var(--text);
    border-radius: 50%;
    top: 18px;
  }

  #mascot .eye.left { left: 14px; }
  #mascot .eye.right { right: 14px; }

  #mascot .eye::after {
    content: '';
    position: absolute;
    width: 4px;
    height: 4px;
    background: #fff;
    border-radius: 50%;
    top: 1px;
    right: 0;
  }

  #mascot .mouth {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 6px;
    border-bottom: 3px solid var(--text);
    border-radius: 0 0 50% 50%;
  }

  #mascot .blush {
    position: absolute;
    width: 12px;
    height: 6px;
    background: var(--rose);
    border-radius: 50%;
    top: 32px;
    opacity: 0.5;
  }

  #mascot .blush.left { left: 4px; }
  #mascot .blush.right { right: 4px; }

  #mascot.bounce {
    animation: mascotBounce 0.6s var(--bounce);
  }

  @keyframes mascotBounce {
    0% { transform: scale(1); }
    30% { transform: scale(1.25) rotate(12deg); }
    60% { transform: scale(0.95) rotate(-5deg); }
    100% { transform: scale(1) rotate(0); }
  }

  #mascotTip {
    position: fixed;
    bottom: 5rem;
    left: var(--space-lg);
    z-index: 9989;
    background: var(--card);
    border: 2.5px solid var(--card-border);
    border-radius: var(--radius-sm);
    padding: var(--space-sm) var(--space-md);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text-muted);
    box-shadow: 3px 3px 0 var(--card-border);
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: all var(--duration-normal) var(--bounce);
    white-space: nowrap;
  }

  #mascotTip.show {
    opacity: 1;
    transform: translateY(0);
  }

  #mascotTip::after {
    content: '';
    position: absolute;
    bottom: -7px;
    left: 1.2rem;
    width: 12px;
    height: 12px;
    background: var(--card);
    border-right: 2.5px solid var(--card-border);
    border-bottom: 2.5px solid var(--card-border);
    transform: rotate(45deg);
  }

  /* ═══════════════════════════════════════════════════════════════
     RESPONSIVE STYLES
     ═══════════════════════════════════════════════════════════════ */
  @media (max-width: 768px) {
    .preview-window { display: none !important; }
    .hero-buttons { flex-direction: column; align-items: center; }
    .btn { width: 100%; max-width: 300px; justify-content: center; }
    #mascot, #mascotTip { display: none; }
    
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    #mascot, #mascotTip { display: none; }
  }

  /* ═══════════════════════════════════════════════════════════════
     REDUCED MOTION
     ═══════════════════════════════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.15ms !important;
    }
  }

  /* ═══════════════════════════════════════════════════════════════
     CUSTOM SCROLLBAR
     ═══════════════════════════════════════════════════════════════ */
  ::-webkit-scrollbar {
    width: 10px;
  }

  ::-webkit-scrollbar-track {
    background: var(--bg);
  }

  ::-webkit-scrollbar-thumb {
    background: var(--card-border);
    border-radius: 5px;
    border: 2px solid var(--bg);
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--primary);
  }

  /* Utility for spin animation */
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @keyframes ping {
    0% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.5); opacity: 0.2; }
    100% { transform: scale(1); opacity: 0.4; }
  }
</style>
