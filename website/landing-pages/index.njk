<style>
  /* ===== BASE OVERRIDES ===== */
  body { background: #000; overflow-x: hidden; }

  /* ===== SCROLL PROGRESS ===== */
  #scrollProgress {
    position: fixed; top: 0; left: 0; height: 2px; z-index: 10001;
    background: linear-gradient(90deg, #2563EB, #22D3EE, #2563EB);
    background-size: 200% 100%;
    animation: progressShimmer 2s linear infinite;
    width: 0%; transition: width 0.05s linear;
  }
  @keyframes progressShimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

  /* ===== STICKY NAV ===== */
  #stickyNav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 10000;
    padding: 0.75rem 1.5rem;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transform: translateY(-100%);
    transition: transform 0.35s cubic-bezier(0.16,1,0.3,1), background 0.3s;
  }
  #stickyNav.visible { transform: translateY(0); }
  #stickyNav.scrolled { background: rgba(0,0,0,0.85); }

  /* ===== HERO ===== */
  #heroCanvas {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
  }
  .hero-gradient-text {
    background: linear-gradient(135deg, #60A5FA, #22D3EE, #A78BFA, #F472B6, #60A5FA);
    background-size: 300% 300%;
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientShift 6s ease infinite;
  }
  @keyframes gradientShift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* ===== HERO LIVE PREVIEW WINDOWS ===== */
  .preview-window {
    position: absolute;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
    box-shadow: 0 20px 60px rgba(0,0,0,0.6), 0 0 40px rgba(37,99,235,0.08);
    transition: transform 0.6s cubic-bezier(0.16,1,0.3,1), opacity 0.6s ease;
  }
  .preview-window .window-bar {
    height: 28px; background: rgba(13,17,23,0.9); border-bottom: 1px solid rgba(255,255,255,0.06);
    display: flex; align-items: center; padding: 0 10px; gap: 5px;
  }
  .preview-window .dot { width: 7px; height: 7px; border-radius: 50%; }
  .preview-window .dot.r { background: #EF4444; }
  .preview-window .dot.y { background: #F59E0B; }
  .preview-window .dot.g { background: #22C55E; }

  /* ===== SECTION REVEAL ===== */
  .reveal {
    opacity: 0; transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1);
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }
  .reveal-delay-5 { transition-delay: 0.5s; }

  /* ===== FEATURE CARDS ===== */
  .feature-card {
    background: #0A0A0A; border: 1px solid rgba(255,255,255,0.06);
    border-radius: 1.25rem; padding: 2rem;
    transition: all 0.4s cubic-bezier(0.16,1,0.3,1);
    position: relative; overflow: hidden;
  }
  .feature-card::before {
    content: ''; position: absolute; inset: 0; border-radius: inherit;
    background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(37,99,235,0.06), transparent 40%);
    opacity: 0; transition: opacity 0.4s;
  }
  .feature-card:hover::before { opacity: 1; }
  .feature-card:hover {
    border-color: rgba(37,99,235,0.3);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 30px rgba(37,99,235,0.05);
  }

  /* ===== CAROUSEL ===== */
  .carousel-track {
    display: flex; transition: transform 0.7s cubic-bezier(0.16,1,0.3,1);
  }
  .carousel-slide { min-width: 100%; }
  .carousel-dot {
    width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.15);
    cursor: pointer; transition: all 0.3s;
  }
  .carousel-dot.active { background: #2563EB; width: 24px; border-radius: 4px; }

  /* ===== INSTALL STEPS ===== */
  .step-connector {
    width: 2px; height: 3rem;
    background: linear-gradient(to bottom, rgba(37,99,235,0.5), rgba(37,99,235,0.05));
    margin: 0 auto;
  }
  .step-number {
    width: 2.5rem; height: 2.5rem; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 0.875rem;
    background: rgba(37,99,235,0.1); border: 2px solid rgba(37,99,235,0.3);
    color: #60A5FA; transition: all 0.4s;
  }
  .step-item.active .step-number {
    background: #2563EB; border-color: #2563EB; color: #fff;
    box-shadow: 0 0 20px rgba(37,99,235,0.4);
  }
  .step-item.completed .step-number {
    background: #22C55E; border-color: #22C55E; color: #fff;
  }
  .code-block {
    background: #0d1117; border: 1px solid rgba(255,255,255,0.06);
    border-radius: 0.75rem; padding: 1rem 1.25rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8125rem; color: #9CA3AF;
    display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
    transition: border-color 0.3s;
  }
  .code-block:hover { border-color: rgba(37,99,235,0.3); }
  .code-block .cmd-key { color: #60A5FA; }
  .code-block .cmd-flag { color: #22D3EE; }
  .code-block .cmd-path { color: #F59E0B; }
  .copy-btn {
    padding: 0.375rem 0.75rem; border-radius: 0.5rem;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
    color: #6B7280; font-size: 0.6875rem; font-weight: 600;
    cursor: pointer; transition: all 0.2s; white-space: nowrap;
  }
  .copy-btn:hover { background: rgba(37,99,235,0.1); border-color: rgba(37,99,235,0.3); color: #60A5FA; }
  .copy-btn.copied { background: rgba(34,197,94,0.1); border-color: rgba(34,197,94,0.3); color: #22C55E; }

  /* ===== COUNTER ===== */
  .counter-value {
    font-variant-numeric: tabular-nums;
    text-shadow: 0 0 30px rgba(37,99,235,0.3);
  }

  /* ===== FAQ ===== */
  .faq-item {
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 1rem; overflow: hidden;
    background: #0A0A0A;
    transition: border-color 0.3s;
  }
  .faq-item.open { border-color: rgba(37,99,235,0.2); }
  .faq-question {
    padding: 1.25rem 1.5rem; cursor: pointer;
    display: flex; align-items: center; justify-content: space-between;
    font-weight: 600; color: #D1D5DB; transition: color 0.3s;
  }
  .faq-item.open .faq-question { color: #fff; }
  .faq-chevron {
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
    color: #4B5563;
  }
  .faq-item.open .faq-chevron { transform: rotate(180deg); color: #2563EB; }
  .faq-answer {
    max-height: 0; overflow: hidden;
    transition: max-height 0.5s cubic-bezier(0.16,1,0.3,1), padding 0.3s;
    padding: 0 1.5rem;
  }
  .faq-item.open .faq-answer {
    max-height: 300px;
    padding: 0 1.5rem 1.25rem;
  }

  /* ===== CTA GLOW ===== */
  .cta-glow {
    position: relative;
  }
  .cta-glow::before {
    content: ''; position: absolute; inset: -2px;
    background: linear-gradient(135deg, #2563EB, #22D3EE, #A78BFA, #2563EB);
    background-size: 300% 300%;
    border-radius: inherit; z-index: -1; opacity: 0;
    filter: blur(12px);
    animation: gradientShift 4s ease infinite;
    transition: opacity 0.4s;
  }
  .cta-glow:hover::before { opacity: 0.6; }

  /* ===== TOAST ===== */
  .toast-container {
    position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 99999;
    display: flex; flex-direction: column; gap: 0.5rem; pointer-events: none;
  }
  .toast {
    pointer-events: auto; padding: 0.75rem 1.25rem; border-radius: 0.75rem;
    font-size: 0.8125rem; font-weight: 600; color: #fff;
    backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.1);
    animation: toastIn 0.35s cubic-bezier(0.16,1,0.3,1), toastOut 0.3s ease 2.2s forwards;
    box-shadow: 0 10px 40px rgba(0,0,0,0.4);
  }
  .toast.success { background: rgba(16,185,129,0.9); }
  .toast.info    { background: rgba(37,99,235,0.9); }
  .toast.warn    { background: rgba(245,158,11,0.9); color: #1a1a1a; }
  @keyframes toastIn { from { opacity:0; transform: translateY(1rem) scale(0.95); } to { opacity:1; transform: translateY(0) scale(1); } }
  @keyframes toastOut { to { opacity:0; transform: translateY(-0.5rem) scale(0.95); } }

  /* ===== FLOATING SHAPES ===== */
  .float-shape {
    position: absolute; border-radius: 50%; pointer-events: none;
    filter: blur(80px); opacity: 0.15;
  }

  /* ===== COMPARISON SLIDER ===== */
  .comparison-container {
    position: relative; overflow: hidden; border-radius: 1rem;
    border: 1px solid rgba(255,255,255,0.06);
    cursor: col-resize; user-select: none;
  }
  .comparison-container .comp-layer {
    position: absolute; inset: 0;
  }
  .comparison-container .comp-slider {
    position: absolute; top: 0; bottom: 0; width: 3px;
    background: #2563EB; z-index: 10;
    box-shadow: 0 0 12px rgba(37,99,235,0.5);
  }
  .comparison-container .comp-handle {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
    width: 36px; height: 36px; border-radius: 50%;
    background: #2563EB; border: 3px solid #fff;
    box-shadow: 0 0 20px rgba(37,99,235,0.4);
    display: flex; align-items: center; justify-content: center;
  }

  /* ===== SCROLLBAR ===== */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #0a0a0a; }
  ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #555; }
</style>

