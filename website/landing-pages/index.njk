  <div class="cartoon-deco deco-star" style="top:18%;right:6%;animation-delay:0.5s;"></div>
  <div class="cartoon-deco deco-heart" style="top:65%;right:8%;animation-delay:1.5s;"></div>

  <div class="reveal hero-badge">
    <span class="dot-live"></span> ON-THE-LINE • KDE COMPATIBLE
  </div>
  <h1 class="reveal reveal-delay-1">Project Gallery</h1>
  <p class="reveal reveal-delay-2">Explore the collection of lightweight, animated, and zero-CPU HTML wallpapers for your desktop.</p>

  <div class="reveal reveal-delay-2 stats-bar">
